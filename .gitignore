node_modules/
dist/
.astro/
# Ephemeral per-run quarantine: build-resilient.mts moves a Read that fails to
# build here so the deploy still ships. Never committed — the source Read stays
# in git; CI's strict build flags it red.
apps/site/.quarantine/
.env
.env.*
.dev.vars
.wrangler/
*.log
.DS_Store
# Ingest on-disk caches (content-addressed, safe to delete; a cold cache just
# does full work). Restored/saved via actions/cache in the ingest workflow.
# Scoped to the ingest namespace so the committed .cache/transformers model
# cache is unaffected.
.cache/ingest/
.superpowers/
data/sources.json
data/sources.pending.json
data/scout/
data/feed/
data/taste.json
# Transient per-run generation artifacts (briefs, per-slug citation ledgers, verify
# report). The committed output is apps/site/src/content/blog/*.mdx, never these.
data/generation/
# Per-package build/test caches (the committed .cache/transformers model cache above
# is the deliberate exception, scoped via .cache/ingest/).
packages/*/.cache/
screenshots/
videos/
