---
import "../styles/global.css";
// Preload hints for the two most-used font subsets (both basic-Latin, normal
// style/weight — the display titles + the reading column render these on
// every single page). `?url` forces Vite to resolve the import to the
// build's hashed asset URL rather than inlining it, so the <link rel=preload>
// below always points at the SAME file the @font-face rules in global.css
// end up fetching — no hardcoded, build-fragile hashed path. This is on top
// of `font-display: swap` (global.css); preload just gets the browser
// fetching the bytes before it has parsed the stylesheet that names them,
// closing the gap that causes a visible reflow on the large display titles.
import frauncesPreloadUrl from "@fontsource-variable/fraunces/files/fraunces-latin-wght-normal.woff2?url";
import newsreaderPreloadUrl from "@fontsource-variable/newsreader/files/newsreader-latin-opsz-normal.woff2?url";
import Wordmark from "../components/Wordmark.astro";
import Ticker from "../components/Ticker.astro";
import Beacon from "../components/Beacon.astro";
import CommandPalette from "../components/cmdk/CommandPalette.tsx";
import SiteGate from "../components/SiteGate.astro";
import NavRail from "../components/header/NavRail.tsx";
import SiteNav from "../components/nav/SiteNav.tsx";
import FeedFilterBar from "../components/nav/FeedFilterBar.astro";
import { ClientRouter } from "astro:transitions";
import { CHANNELS } from "@khazana/core";

// Liquid-glass toggle (single source of truth). Flip to `false` to remove the
// optional dark-glass treatment site-wide; it adds `class="glass"` to <html>.
// See p8-polish-report.md → "How to toggle glass off".
const GLASS = true;

interface Props {
  title: string;
  description?: string;
  active?: "feed" | "reads" | "workshop" | "graph" | "sources" | "taste";
  tickerTitles?: string[];
  /** Live instrument readout in the bezel (total + fresh signal counts). */
  signalCount?: number;
  freshCount?: number;
  /**
   * When true, the header channel row renders as an interactive feed filter
   * (JS-driven; no page reload). Only meaningful on the feed page.
   */
  feedPage?: boolean;
  /** The currently active channel filter (empty string = all). */
  activeChannel?: string;
  /**
   * Which of the two atmospheres this page belongs to. SSR-stamped onto
   * `<html data-face>` so the cold Atlas delta in atmosphere.css cascades over
   * the warm base tokens with ZERO runtime JS — no face-detection script, no
   * FOUC. Study is the default; Atlas layouts thread `face="atlas"` through.
   */
  face?: "study" | "atlas";
}
const {
  title,
  description = "A personal signal terminal: a self-curating feed of the world's best signal and gorgeous, AI-authored interactive reads.",
  active,
  tickerTitles = [],
  signalCount,
  freshCount,
  feedPage = false,
  activeChannel = "",
  face = "study",
} = Astro.props;

const base = import.meta.env.BASE_URL;
const withBase = (p: string) => `${base.replace(/\/$/, "")}/${p.replace(/^\//, "")}`;

// CHANNELS grouped sensibly for the nav (canonical vocab, never redefined).
const channelGroups: { label: string; channels: readonly string[] }[] = [
  { label: "world", channels: ["history", "geopolitics", "politics", "geography"] },
  { label: "science", channels: ["science", "tech", "ai", "quantum"] },
  { label: "data", channels: ["data-science", "ds-sports", "data-strategy", "finance"] },
  { label: "make", channels: ["ideas", "diy", "3d-printing", "iot", "embedded", "ai-projects"] },
];

// Build-time drift guard: every channel in CHANNELS must appear in at least one group.
const grouped = new Set(channelGroups.flatMap((g) => g.channels));
const missing = CHANNELS.filter((c) => !grouped.has(c));
if (missing.length) throw new Error(`Shell nav missing channels: ${missing.join(", ")}`);

// Preconnect to the Worker origin when this build actually has one configured
// (mirrors index.astro/Beacon.astro's own build-time PUBLIC_WORKER_URL gate).
// Both Beacon's taste-capture POST and the Feed's /summary personalization
// fetch hit this origin on load, so an early preconnect buys back the
// DNS+TLS+TCP handshake before either fires. Renders nothing when unset —
// most deployments (and local dev) have no Worker, so this must stay inert.
const workerUrl = (import.meta.env.PUBLIC_WORKER_URL ?? "").trim();
let workerOrigin = "";
if (workerUrl) {
  try {
    workerOrigin = new URL(workerUrl).origin;
  } catch {
    workerOrigin = ""; // malformed env value → no-op, never break the build
  }
}

const buildTime = new Date().toISOString();
const nav: { id: "feed" | "reads" | "workshop" | "graph" | "sources" | "taste"; label: string; href: string }[] = [
  { id: "feed", label: "feed", href: withBase("/") },
  { id: "reads", label: "reads", href: withBase("/reads") },
  { id: "workshop", label: "workshop", href: withBase("/workshop") },
  { id: "graph", label: "observatory", href: withBase("/graph") },
  { id: "sources", label: "sources", href: withBase("/sources") },
  { id: "taste", label: "taste", href: withBase("/taste") },
];
---

<!doctype html>
<html lang="en" data-face={face} class:list={[{ glass: GLASS }]}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0b" />
    {/* Font preloads — BEFORE global.css's stylesheet link, so the browser
        starts fetching these two woff2s while it's still parsing CSS instead
        of waiting to discover them inside it (the visible reflow this avoids
        happens on the large display titles + the reading column). */}
    <link rel="preload" as="font" type="font/woff2" href={frauncesPreloadUrl} crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={newsreaderPreloadUrl} crossorigin />
    {
      workerOrigin && (
        <link rel="preconnect" href={workerOrigin} crossorigin />
      )
    }
    <link rel="manifest" href={withBase("/manifest.webmanifest")} />
    <link rel="icon" href={withBase("/icon.svg")} type="image/svg+xml" />
    <meta name="generator" content={Astro.generator} />
    {/* Optional client-side access gate. Renders nothing when
        PUBLIC_SITE_GATE_HASH is unset; when set, its inline critical CSS + JS
        run before body paint so the page never flashes before unlock. */}
    <SiteGate />
    {/* Signature face-switch transition (two-faces spec §4). The
        `@view-transition` opt-in is render-blocking + inline here so it is in
        the served <head> with zero bundling indirection; the direction-branched
        choreography, shared-element name, reduced-motion gate, and no-VT fade all
        live in styles/face-switch.css (imported via global.css). */}
    <style is:inline>@view-transition { navigation: auto; }</style>
    <ClientRouter />
    {/* The ONLY JS in the transition: sets the cross-document VT `type`
        (to-atlas / to-study) in pageswap, echoes it + lands focus in pagereveal,
        listens for the TimeoutError, and drives the no-VT data-just-crossed fade.
        Inert unless a genuine face crossing fires (spec §7). */}
    <script>
      import "../lib/face-switch.ts";
    </script>
    <script is:inline>
      // Gate the reveal hidden-state ASAP (before paint) so JS-on visitors
      // don't flash the final layout, while no-JS/SSR keeps everything visible.
      // Skipped under reduced-motion so those users never get opacity:0.
      if (!matchMedia("(prefers-reduced-motion: reduce)").matches) {
        document.documentElement.classList.add("reveal-ready");
        // HARD FAIL-SAFE: this inline script just committed to hiding every
        // [data-reveal]. The deferred module that un-hides them might fail to
        // load entirely (bundle 404, parse error, an unrelated throw). So set an
        // independent backstop HERE that un-hides everything if the reveal system
        // never took over — content must NEVER stay permanently invisible.
        window.addEventListener("load", function () {
          setTimeout(function () {
            if (document.documentElement.hasAttribute("data-reveals-armed")) return;
            for (var el of document.querySelectorAll("[data-reveal]:not(.is-in)")) {
              el.classList.add("is-in");
            }
          }, 3000);
        });
      }
    </script>
  </head>
  <body>
    <!-- The decorative mesh-gradient background was removed (art-direction §2.1:
         it is the #1 vibecoded tell). The ONLY WebGL on the site is the Feed's
         "First Light" hero (art-direction.md §1, Signature Moment A) — a
         data-driven OGL point-field behind the Feed masthead only (see
         pages/index.astro + components/FirstLight.tsx), entrance-once then
         settled, never a permanent background here in the shell. Everywhere
         else, empty space stays warm, near-black, grain-textured stillness
         (global.css) — confidence, not filler. -->
    <a class="skip-link" href="#main">Skip to content</a>
    <Ticker titles={tickerTitles} />
    <header class="topbar metal">
      <div class="topbar-inner">
        <Wordmark />
        <nav class="nav" aria-label="Surfaces">
          <NavRail items={nav} active={active} client:load />
        </nav>
        {
          signalCount != null && (
            <p class="readout" aria-label="signal readout">
              <span class="readout-n tnum">{signalCount}</span>
              <span class="readout-l">signals</span>
              {freshCount != null && freshCount > 0 && (
                <>
                  <span class="readout-sep" aria-hidden="true">
                    ·
                  </span>
                  <span class="readout-n readout-fresh tnum">
                    {String(freshCount).padStart(2, "0")}
                  </span>
                  <span class="readout-l">fresh</span>
                </>
              )}
            </p>
          )
        }
        {/* The bezel face-switch — a plain link, zero JS, degrades to a link
            with JS disabled. STUDY is lit; atlas is dim; it crosses to the
            Atlas root as a full-document load (data-astro-reload). The reload
            attribute is inert without the signature transition (a separate
            future task); adding it now means that task needs no markup change. */}
        <a
          class="face-switch"
          href={withBase("/atlas")}
          data-astro-reload
          aria-label="Switch to Atlas"
        >
          <span class="face-opt is-current">STUDY</span>
          <span class="face-swap" aria-hidden="true">⟷</span>
          <span class="face-opt">atlas</span>
        </a>
        <button
          class="cmdk"
          type="button"
          data-magnetic
          aria-label="Open command palette"
          aria-keyshortcuts="Meta+K Control+K"
        >
          <span class="cmdk-icon" aria-hidden="true">⌘</span>
          <span class="cmdk-label">command</span>
          <kbd class="cmdk-keys" aria-hidden="true">⌘K</kbd>
        </button>
      </div>
      {feedPage ? (
        <FeedFilterBar channelGroups={channelGroups} activeChannel={activeChannel} />
      ) : (
        <nav
          class="channels"
          aria-label="Channels"
        >
          {channelGroups.map((g) => (
            <span class="chgroup">
              <span class="chgroup-label">{g.label}/</span>
              {g.channels.map((c) => (
                <a class="ch" href={`${withBase("/")}?channel=${c}`} data-channel={c}>
                  {c}
                </a>
              ))}
            </span>
          ))}
        </nav>
      )}
    </header>

    <main id="main" class="shell-main">
      <slot />
    </main>

    <footer class="footer">
      <span>khazana — a personal treasury · static, $0, open source</span>
      <span class="build">
        build <time datetime={buildTime}>{buildTime.slice(0, 16).replace("T", " ")}Z</time>
      </span>
    </footer>

    <CommandPalette base={base} face={face} client:idle />
    <!-- The three quiet navigation affordances (back / scroll-top / section
         tick-rail). Self-contained island that detects sections at runtime, so
         it needs no per-page wiring and lives entirely here in the shell. -->
    <SiteNav base={base} client:idle />
    <Beacon />

    <!-- v2 motion foundation: Lenis smooth scroll + GSAP/ScrollTrigger, wired to
         the View Transitions lifecycle. Reduced-motion → native scroll, no smooth.
         Bundled module (no CDN). -->
    <script>
      import "../scripts/motion-core";
      import "../scripts/magnetic-hover";
    </script>

    <script>
      // ── Shared scroll-reveal observer ───────────────────────────────────
      // ONE IntersectionObserver for the whole page. Adds `.is-in` to
      // `[data-reveal]` elements as they enter, then unobserves (one-shot).
      // No scroll handlers. Re-runs after View Transition navigations.
      // Reduced-motion + no-IO browsers: reveal everything immediately.
      const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;

      function revealAll() {
        document.documentElement.classList.add("reveal-ready");
        for (const el of document.querySelectorAll("[data-reveal]")) {
          el.classList.add("is-in");
        }
      }

      let observerLive = false;

      function initReveals() {
        observerLive = false;
        if (reduce || !("IntersectionObserver" in window)) {
          revealAll();
          return;
        }
        const io = new IntersectionObserver(
          (entries, obs) => {
            for (const entry of entries) {
              if (!entry.isIntersecting) continue;
              entry.target.classList.add("is-in");
              obs.unobserve(entry.target);
            }
          },
          { rootMargin: "400px 0px 400px 0px", threshold: 0 },
        );
        for (const el of document.querySelectorAll("[data-reveal]:not(.is-in)")) {
          io.observe(el);
        }
        observerLive = true; // only reached if observe() didn't throw
        // Tell the inline-head backstop the reveal system is live so it stands
        // down (it only un-hides if THIS never ran).
        document.documentElement.setAttribute("data-reveals-armed", "");
      }

      // FAIL-SAFE: the inline head script set `reveal-ready` (which hides every
      // [data-reveal] at opacity:0) before paint. The reveal is a PURE progressive
      // enhancement that must NEVER leave content permanently hidden. So:
      //   • try/catch the init — any throw immediately un-hides everything;
      //   • a short backstop un-hides everything if the observer never came up
      //     (e.g. init was aborted by an unrelated error) — but when the observer
      //     IS live we let it run so the scroll-reveal stays intact.
      function safeInit() {
        try {
          initReveals();
        } catch {
          revealAll();
        }
      }
      // Content must NEVER stay hidden. The IO gives an on-scroll entrance for
      // what is seen first, but anything below the fold that the reader never
      // scrolls to would otherwise stay at opacity:0 forever (a sparse-looking
      // feed). So unconditionally reveal everything shortly after load — the
      // page is always fully populated; the scroll entrance is a bonus, not a
      // gate on visibility.
      safeInit();
      window.addEventListener("load", () => setTimeout(revealAll, 1100));
      setTimeout(revealAll, 1800);
      // View Transitions swaps the DOM without a full reload — re-init each nav.
      document.addEventListener("astro:page-load", safeInit);
    </script>
  </body>
</html>

<style>
  .skip-link {
    position: absolute;
    left: -9999px;
    top: 0;
    background: var(--accent);
    color: #000;
    padding: var(--s-2) var(--s-4);
    z-index: 10000;
    font-family: var(--font-mono);
  }
  .skip-link:focus-visible {
    left: var(--s-3);
    top: var(--s-3);
  }

  /* the instrument bezel — a single hairline-ruled bar, thin & always present.
     `.metal` (global.css) gives it the machined anodized grain; a faint top
     edge-light lifts it as a physical surface catching the instrument light. */
  .topbar {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in oklab, var(--bg) 70%, transparent);
    backdrop-filter: blur(8px);
    border-bottom: var(--hair) solid transparent;
    box-shadow: inset 0 var(--hair) 0 color-mix(in oklab, var(--ink) 5%, transparent);
    /* condense on scroll is a transform/opacity-only affair: we animate an
       inner padding token via a custom prop + the inner's transform, never the
       bar's own box. The border/blur deepen as a class flip (cheap). */
    transition:
      background var(--dur) var(--ease-out),
      border-color var(--dur) var(--ease-out);
  }
  /* reading-progress hairline along the very top edge of the header (amber),
     scaleX-driven by the --read-progress custom prop set in Shell's script. */
  .topbar::before {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--accent), var(--editorial));
    transform: scaleX(var(--read-progress, 0));
    transform-origin: left;
    opacity: 0;
    transition: opacity var(--dur) var(--ease-out);
    z-index: 1;
  }
  :global(html.is-scrolled) .topbar::before {
    opacity: 0.9;
  }
  :global(html.is-scrolled) .topbar {
    background: color-mix(in oklab, var(--bg) 86%, transparent);
    border-bottom-color: var(--rule);
  }
  /* the inner row eases up + tightens (translate/scale only) when condensed */
  .topbar-inner {
    transition: transform var(--dur) var(--ease-out);
  }
  :global(html.is-scrolled) .topbar-inner {
    transform: translateY(-1px) scale(0.985);
    transform-origin: left center;
  }
  /* channel row tucks away gracefully on scroll — opacity + a slight lift,
     and we clip it with a max-height that is NOT transitioned (set instantly)
     to avoid animating layout; the fade is the perceived motion. */
  .channels {
    transition:
      opacity var(--dur) var(--ease-out),
      transform var(--dur) var(--ease-out);
    transform-origin: top;
  }
  :global(html.is-scrolled) .channels {
    opacity: 0;
    transform: translateY(-4px);
    pointer-events: none;
    /* COLLAPSE the layout box, don't just fade it. Previously the condensed
       channel row kept `display:flex` + its full height (≈316px when the taxonomy
       wraps on mobile), so the sticky `.topbar` still measured ~420px even though
       only the ~100px header band was visible — a phantom band that pushed
       topbar-height-anchored UI (e.g. the ScrollyTimeline sticky spine) far down
       the screen, and wasted mobile layout. The fade is still the perceived
       motion; the box then collapses to zero height (height not transitioned, per
       the row's existing "set instantly" approach) so the topbar measures only its
       visible band. Reduced-motion keeps the row fully present (below). */
    height: 0;
    padding-block: 0;
    margin-block: 0;
    border: 0;
    overflow: hidden;
  }
  @media (prefers-reduced-motion: reduce) {
    :global(html.is-scrolled) .channels {
      opacity: 1;
      transform: none;
      pointer-events: auto;
      /* reduced-motion keeps the row fully present — undo the collapse entirely,
         restoring the base box (.channels pads bottom by --s-3, no top pad, no
         border, auto-centred margins). FeedFilterBar.astro carries its own
         copy of this same rule for its `.feed-filter`-classed root. */
      height: auto;
      overflow: visible;
      padding-block: 0 var(--s-3);
      margin-block: 0;
    }
    :global(html.is-scrolled) .topbar-inner {
      transform: none;
    }
  }
  /* glass top bar: deeper blur + a faint lit top edge so content scrolls under
     it premium-ly. Falls back to the matte translucent bar where unsupported. */
  :global(html.glass) .topbar {
    background: color-mix(in oklab, var(--bg) 78%, transparent);
  }
  @supports (backdrop-filter: blur(1px)) {
    :global(html.glass) .topbar {
      backdrop-filter: blur(12px) saturate(118%);
      box-shadow: inset 0 var(--hair) 0
        color-mix(in oklab, var(--ink) calc(var(--glass) * 8%), transparent);
    }
  }
  .topbar-inner {
    position: relative;
    z-index: 1; /* above the .metal grain (z-index:0) */
    max-width: var(--maxw);
    margin-inline: auto;
    display: flex;
    align-items: center;
    gap: var(--s-5);
    padding: var(--s-3) var(--s-5);
  }
  /* nav sits just right of the wordmark; the readout + ⌘K hug the far right
     (the live readout is the instrument telemetry — "the instrument is on"). */
  .nav {
    display: flex;
    margin-left: var(--s-2);
    /* nav consumes the free space to its right so the readout + face-switch +
       ⌘K cluster hard against the right edge on EVERY page (feed pages carry a
       readout; the rest don't) — one coherent right-cluster behaviour. */
    margin-right: auto;
  }
  /* the bezel face-switch — a plain link, STUDY lit (amber), atlas dim. Mono
     small-caps segmented control; degrades to a link with JS disabled. */
  .face-switch {
    flex: none;
    display: inline-flex;
    align-items: center;
    gap: var(--s-2);
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-faint);
    border: var(--hair) solid var(--rule);
    border-radius: var(--r-md);
    padding: var(--s-2) var(--s-3);
    transition:
      border-color var(--dur-fast) var(--ease-out),
      background var(--dur-fast) var(--ease-out);
  }
  .face-switch:hover {
    text-decoration: none;
    border-color: color-mix(in oklab, var(--accent) 45%, var(--rule));
    background: color-mix(in oklab, var(--accent) 8%, transparent);
  }
  .face-switch:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .face-opt {
    color: var(--ink-faint);
  }
  .face-opt.is-current {
    color: var(--accent);
    text-shadow: 0 0 8px color-mix(in oklab, var(--accent) 35%, transparent);
  }
  .face-swap {
    color: var(--ink-faint);
    opacity: 0.7;
  }
  /* Compact the switch to just its lit label from the tablet band DOWN: above
     the 860px wrap breakpoint the wordmark + 6-link NavRail + ⌘K already fill
     the row, so the full `STUDY ⟷ atlas` control would overflow the 860–960px
     tablet range. The crossing is still reachable (its label links to /atlas,
     plus the ⌘K crossing command). */
  @media (max-width: 960px) {
    .face-switch .face-opt:not(.is-current),
    .face-switch .face-swap {
      display: none;
    }
  }
  /* live signal readout — tabular mono telemetry in the bezel (art-direction §3) */
  .readout {
    margin: 0;
    display: inline-flex;
    align-items: baseline;
    gap: 0.45ch;
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    color: var(--ink-faint);
    white-space: nowrap;
  }
  .readout-n {
    color: var(--ink-dim);
  }
  .readout-fresh {
    color: var(--accent);
    text-shadow: 0 0 8px color-mix(in oklab, var(--accent) 35%, transparent);
  }
  .readout-l {
    letter-spacing: 0.04em;
  }
  .readout-sep {
    color: var(--ink-faint);
    margin: 0 0.1ch;
  }
  /* condense on scroll: the readout tucks to just the fresh-count (art-direction
     §3). The "signals" label + total fade; fresh stays as the live pulse. */
  :global(html.is-scrolled) .readout :is(.readout-l):first-of-type,
  :global(html.is-scrolled) .readout > .readout-n:first-of-type,
  :global(html.is-scrolled) .readout .readout-sep {
    opacity: 0;
  }
  .readout :is(.readout-n, .readout-l, .readout-sep) {
    transition: opacity var(--dur) var(--ease-out);
  }
  @media (max-width: 880px) {
    .readout {
      display: none;
    }
  }
  /* ⌘K — prominent, crafted trigger. Magnetic (data-magnetic, header script).
     A faint amber wash + lit edge so it reads as the primary affordance. */
  .cmdk {
    flex: none;
    display: inline-flex;
    align-items: center;
    gap: var(--s-2);
    background: color-mix(in oklab, var(--accent) 7%, var(--bg-raised));
    border: var(--hair) solid color-mix(in oklab, var(--accent) 22%, var(--rule));
    border-radius: var(--r-md);
    color: var(--ink-dim);
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    padding: var(--s-2) var(--s-3);
    cursor: pointer;
    will-change: transform;
    transition:
      color var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out),
      background var(--dur-fast) var(--ease-out),
      transform var(--dur) var(--ease-overshoot);
  }
  .cmdk:hover {
    color: var(--ink);
