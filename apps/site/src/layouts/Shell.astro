---
import "../styles/global.css";
import Wordmark from "../components/Wordmark.astro";
import Ticker from "../components/Ticker.astro";
import Beacon from "../components/Beacon.astro";
import CommandPalette from "../components/cmdk/CommandPalette.tsx";
import NavRail from "../components/header/NavRail.tsx";
import SiteNav from "../components/nav/SiteNav.tsx";
import { ClientRouter } from "astro:transitions";
import { CHANNELS } from "@khazana/core";

// Liquid-glass toggle (single source of truth). Flip to `false` to remove the
// optional dark-glass treatment site-wide; it adds `class="glass"` to <html>.
// See p8-polish-report.md → "How to toggle glass off".
const GLASS = true;

interface Props {
  title: string;
  description?: string;
  active?: "feed" | "reads" | "workshop" | "graph" | "sources" | "taste";
  tickerTitles?: string[];
  /** Live instrument readout in the bezel (total + fresh signal counts). */
  signalCount?: number;
  freshCount?: number;
  /**
   * When true, the header channel row renders as an interactive feed filter
   * (JS-driven; no page reload). Only meaningful on the feed page.
   */
  feedPage?: boolean;
  /** The currently active channel filter (empty string = all). */
  activeChannel?: string;
}
const {
  title,
  description = "A personal signal terminal: a self-curating feed of the world's best signal and gorgeous, AI-authored interactive reads.",
  active,
  tickerTitles = [],
  signalCount,
  freshCount,
  feedPage = false,
  activeChannel = "",
} = Astro.props;

const base = import.meta.env.BASE_URL;
const withBase = (p: string) => `${base.replace(/\/$/, "")}/${p.replace(/^\//, "")}`;

// CHANNELS grouped sensibly for the nav (canonical vocab, never redefined).
const channelGroups: { label: string; channels: readonly string[] }[] = [
  { label: "world", channels: ["history", "geopolitics", "politics", "geography"] },
  { label: "science", channels: ["science", "tech", "ai", "quantum"] },
  { label: "data", channels: ["data-science", "ds-sports", "data-strategy", "finance"] },
  { label: "make", channels: ["ideas", "diy", "3d-printing", "iot", "embedded", "ai-projects"] },
];

// Build-time drift guard: every channel in CHANNELS must appear in at least one group.
const grouped = new Set(channelGroups.flatMap((g) => g.channels));
const missing = CHANNELS.filter((c) => !grouped.has(c));
if (missing.length) throw new Error(`Shell nav missing channels: ${missing.join(", ")}`);

const buildTime = new Date().toISOString();
const nav: { id: "feed" | "reads" | "workshop" | "graph" | "sources" | "taste"; label: string; href: string }[] = [
  { id: "feed", label: "feed", href: withBase("/") },
  { id: "reads", label: "reads", href: withBase("/reads") },
  { id: "workshop", label: "workshop", href: withBase("/workshop") },
  { id: "graph", label: "observatory", href: withBase("/graph") },
  { id: "sources", label: "sources", href: withBase("/sources") },
  { id: "taste", label: "taste", href: withBase("/taste") },
];
---

<!doctype html>
<html lang="en" class:list={[{ glass: GLASS }]}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0b" />
    <link rel="manifest" href={withBase("/manifest.webmanifest")} />
    <link rel="icon" href={withBase("/icon.svg")} type="image/svg+xml" />
    <meta name="generator" content={Astro.generator} />
    <ClientRouter />
    <script is:inline>
      // Gate the reveal hidden-state ASAP (before paint) so JS-on visitors
      // don't flash the final layout, while no-JS/SSR keeps everything visible.
      // Skipped under reduced-motion so those users never get opacity:0.
      if (!matchMedia("(prefers-reduced-motion: reduce)").matches) {
        document.documentElement.classList.add("reveal-ready");
        // HARD FAIL-SAFE: this inline script just committed to hiding every
        // [data-reveal]. The deferred module that un-hides them might fail to
        // load entirely (bundle 404, parse error, an unrelated throw). So set an
        // independent backstop HERE that un-hides everything if the reveal system
        // never took over — content must NEVER stay permanently invisible.
        window.addEventListener("load", function () {
          setTimeout(function () {
            if (document.documentElement.hasAttribute("data-reveals-armed")) return;
            for (var el of document.querySelectorAll("[data-reveal]:not(.is-in)")) {
              el.classList.add("is-in");
            }
          }, 3000);
        });
      }
    </script>
  </head>
  <body>
    <!-- The decorative mesh-gradient background was removed (art-direction §2.1:
         it is the #1 vibecoded tell). The only WebGL on the site now is the
         data-carrying constellation. Empty space is warm, near-black, grain-
         textured stillness (global.css) — confidence, not filler. -->
    <a class="skip-link" href="#main">Skip to content</a>
    <Ticker titles={tickerTitles} />
    <header class="topbar metal">
      <div class="topbar-inner">
        <Wordmark />
        <nav class="nav" aria-label="Surfaces">
          <NavRail items={nav} active={active} client:load />
        </nav>
        {
          signalCount != null && (
            <p class="readout" aria-label="signal readout">
              <span class="readout-n tnum">{signalCount}</span>
              <span class="readout-l">signals</span>
              {freshCount != null && freshCount > 0 && (
                <>
                  <span class="readout-sep" aria-hidden="true">
                    ·
                  </span>
                  <span class="readout-n readout-fresh tnum">
                    {String(freshCount).padStart(2, "0")}
                  </span>
                  <span class="readout-l">fresh</span>
                </>
              )}
            </p>
          )
        }
        <button
          class="cmdk"
          type="button"
          data-magnetic
          aria-label="Open command palette"
          aria-keyshortcuts="Meta+K Control+K"
        >
          <span class="cmdk-icon" aria-hidden="true">⌘</span>
          <span class="cmdk-label">command</span>
          <kbd class="cmdk-keys" aria-hidden="true">⌘K</kbd>
        </button>
      </div>
      {feedPage ? (
        <!-- FEED PAGE: hierarchical two-level filter.
             Top row: group tabs (all · world · science · data · make) with a
             sliding amber indicator matching the NavRail aesthetic.
             Bottom row: sub-channel chips for the active group, animating in. -->
        <div
          class="channels channels-feed feed-filter"
          aria-label="Filter by topic"
          data-feed-channels=""
          data-feed-filter=""
        >
          <!-- GROUP TAB ROW -->
          <div class="filter-groups" role="tablist" aria-label="Topic groups">
            <div class="filter-group-indicator" aria-hidden="true"></div>
            <a
              class:list={["filter-group-tab", activeChannel === "" && "fg-active"]}
              href={withBase("/")}
              data-group-tab=""
              data-group-channels=""
              role="tab"
              aria-selected={activeChannel === "" ? "true" : "false"}
              aria-controls="filter-subchannels"
            >all</a>
            {channelGroups.map((g) => {
              const isGroupActive = activeChannel !== "" && g.channels.includes(activeChannel);
              return (
                <a
                  class:list={["filter-group-tab", isGroupActive && "fg-active"]}
                  href={`${withBase("/")}?channel=${g.channels[0]}`}
                  data-group-tab={g.label}
                  data-group-channels={g.channels.join(",")}
                  role="tab"
                  aria-selected={isGroupActive ? "true" : "false"}
                  aria-controls="filter-subchannels"
                >{g.label}</a>
              );
            })}
          </div>
          <!-- SUB-CHANNEL CHIP ROW — populated + animated by JS -->
          <div
            class="filter-subchannels"
            id="filter-subchannels"
            role="tabpanel"
            aria-label="Channels in group"
          >
            {/* Rendered by JS; SSR provides the active channel's group for no-JS fallback */}
            {channelGroups.map((g) => {
              const isActive = g.channels.includes(activeChannel);
              return (
                <span
                  class:list={["filter-subgroup", isActive && "is-visible"]}
                  data-subgroup={g.label}
                  aria-hidden={!isActive ? "true" : "false"}
                >
                  {g.channels.map((c) => (
                    <a
                      class:list={["filter-sub-ch", c === activeChannel && "fsc-active"]}
                      href={`${withBase("/")}?channel=${c}`}
                      data-filter={c}
                      data-filter-sub=""
                    >{c}</a>
                  ))}
                </span>
              );
            })}
          </div>
        </div>
      ) : (
        <nav
          class="channels"
          aria-label="Channels"
        >
          {channelGroups.map((g) => (
            <span class="chgroup">
              <span class="chgroup-label">{g.label}/</span>
              {g.channels.map((c) => (
                <a class="ch" href={`${withBase("/")}?channel=${c}`} data-channel={c}>
                  {c}
                </a>
              ))}
            </span>
          ))}
        </nav>
      )}
    </header>

    <main id="main" class="shell-main">
      <slot />
    </main>

    <footer class="footer">
      <span>khazana — a personal treasury · static, $0, open source</span>
      <span class="build">
        build <time datetime={buildTime}>{buildTime.slice(0, 16).replace("T", " ")}Z</time>
      </span>
    </footer>

    <CommandPalette base={base} client:idle />
    <!-- The three quiet navigation affordances (back / scroll-top / section
         tick-rail). Self-contained island that detects sections at runtime, so
         it needs no per-page wiring and lives entirely here in the shell. -->
    <SiteNav base={base} client:idle />
    <Beacon />

    <!-- Feed-page hierarchical channel filter.
         Group tabs dispatch khz:channelchange with a `channels` array (union of
         the group's sub-channels). Sub-channel chips dispatch with a single
         `channel` string. "all" clears both.
         Progressive enhancement: all links are real hrefs; JS adds live filtering. -->
    <script>
      // The channelGroups definition mirrored here so JS can derive group→channels
      // without needing to parse the DOM on every interaction.
      const FILTER_GROUPS: { label: string; channels: string[] }[] = [
        { label: "world",   channels: ["history", "geopolitics", "politics", "geography"] },
        { label: "science", channels: ["science", "tech", "ai", "quantum"] },
        { label: "data",    channels: ["data-science", "ds-sports", "data-strategy", "finance"] },
        { label: "make",    channels: ["ideas", "diy", "3d-printing", "iot", "embedded", "ai-projects"] },
      ];

      function groupForChannel(ch: string): string | null {
        for (const g of FILTER_GROUPS) {
          if (g.channels.includes(ch)) return g.label;
        }
        return null;
      }

      function channelsForGroup(groupLabel: string): string[] {
        return FILTER_GROUPS.find((g) => g.label === groupLabel)?.channels ?? [];
      }

      function initFeedChannelFilter(): void {
        const root = document.querySelector<HTMLElement>("[data-feed-filter]");
        if (!root) return;
        if (root.dataset.filterReady === "1") return;
        root.dataset.filterReady = "1";

        const params = new URLSearchParams(location.search);
        const initial = params.get("channel") ?? "";

        // Set active group + sub-channels from URL at load time
        activateGroup(initial ? (groupForChannel(initial) ?? "") : "", initial);

        // Position the group-tab sliding indicator on load
        requestAnimationFrame(() => positionGroupIndicator(root));

        // GROUP TAB clicks
        root.addEventListener("click", (ev) => {
          const groupTab = (ev.target as HTMLElement | null)?.closest<HTMLAnchorElement>("[data-group-tab]");
          if (groupTab) {
            ev.preventDefault();
            const groupLabel = groupTab.dataset.groupTab ?? "";
            // Clicking a group tab again navigates INTO that group (shows sub-channels),
            // but the feed filters to the full group (union), not a single channel.
            const groupChannels = channelsForGroup(groupLabel);
            // Update URL: clear to "all" or pick first channel as the group representative
            const url = new URL(location.href);
            if (!groupLabel) {
              url.searchParams.delete("channel");
            } else {
              // Store the group label as the "active" URL param
              // so SSR renders correct state on reload. We use the group's first channel
              // as the URL value because URL has no "group" concept — the filter
              // JS re-derives the group from the channel on load.
              // But for group-level filters we want ALL channels in the group
              // to show — we store a sentinel: "group:<label>" — NO, that breaks
              // SSR rendering. Instead, keep the url param empty for group-level
              // so the url is just "?". The JS-state machine handles it: store
              // the active group in a data attr on root.
              url.searchParams.delete("channel");
            }
            history.replaceState(null, "", url.toString());
            activateGroup(groupLabel, "");
            positionGroupIndicator(root);

            // Dispatch to all feed sections: for group tabs we pass the channels array
            document.dispatchEvent(new CustomEvent("khz:channelchange", {
              detail: {
                channel: "",          // single-channel filter is empty
                channels: groupChannels, // group union filter
                group: groupLabel,
              },
            }));
            return;
          }

          // SUB-CHANNEL chip clicks
          const subChip = (ev.target as HTMLElement | null)?.closest<HTMLAnchorElement>("[data-filter-sub]");
          if (subChip) {
            ev.preventDefault();
            const ch = subChip.dataset.filter ?? "";
            const url = new URL(location.href);
            if (ch) {
              url.searchParams.set("channel", ch);
            } else {
              url.searchParams.delete("channel");
            }
            history.replaceState(null, "", url.toString());

            const groupLabel = ch ? (groupForChannel(ch) ?? "") : "";
            activateGroup(groupLabel, ch);
            positionGroupIndicator(root);

            // Single-channel dispatch — back-compat with consumers expecting `channel`
            document.dispatchEvent(new CustomEvent("khz:channelchange", {
              detail: {
                channel: ch,
                channels: ch ? [ch] : [],
                group: groupLabel,
              },
            }));
          }
        });
      }

      function activateGroup(groupLabel: string, activeChannel: string): void {
        const root = document.querySelector<HTMLElement>("[data-feed-filter]");
        if (!root) return;

        // Mark active group tab
        root.querySelectorAll<HTMLElement>("[data-group-tab]").forEach((tab) => {
          const isActive =
            (groupLabel === "" && (tab.dataset.groupTab ?? "") === "") ||
            (groupLabel !== "" && tab.dataset.groupTab === groupLabel);
          tab.classList.toggle("fg-active", isActive);
          tab.setAttribute("aria-selected", isActive ? "true" : "false");
        });

        // Show/hide sub-channel rows
        root.querySelectorAll<HTMLElement>("[data-subgroup]").forEach((sg) => {
          const isVisible = sg.dataset.subgroup === groupLabel && groupLabel !== "";
          sg.classList.toggle("is-visible", isVisible);
          sg.setAttribute("aria-hidden", isVisible ? "false" : "true");
        });

        // Mark active sub-channel chip
        root.querySelectorAll<HTMLElement>("[data-filter-sub]").forEach((chip) => {
          chip.classList.toggle("fsc-active", (chip.dataset.filter ?? "") === activeChannel && activeChannel !== "");
        });
      }

      function positionGroupIndicator(root: HTMLElement): void {
        const indicator = root.querySelector<HTMLElement>(".filter-group-indicator");
        const groupRow = root.querySelector<HTMLElement>(".filter-groups");
        if (!indicator || !groupRow) return;

        const activeTab = groupRow.querySelector<HTMLElement>(".fg-active");
        if (!activeTab) {
          indicator.style.opacity = "0";
          return;
        }

        const rowRect = groupRow.getBoundingClientRect();
        const tabRect = activeTab.getBoundingClientRect();
        const x = tabRect.left - rowRect.left;
        const w = tabRect.width;

        indicator.style.opacity = "1";
        indicator.style.width = `${w}px`;
        indicator.style.transform = `translateX(${x}px)`;

        const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        indicator.style.transitionDuration = reduced ? "0ms" : "";
      }

      initFeedChannelFilter();
      document.addEventListener("astro:page-load", () => {
        initFeedChannelFilter();
        // Re-position indicator after fonts + layout settle
        requestAnimationFrame(() => {
          const root = document.querySelector<HTMLElement>("[data-feed-filter]");
          if (root) positionGroupIndicator(root);
        });
      });

      // Re-position on resize (same pattern as NavRail)
      window.addEventListener("resize", () => {
        const root = document.querySelector<HTMLElement>("[data-feed-filter]");
        if (root) positionGroupIndicator(root);
      });
    </script>

    <!-- v2 motion foundation: Lenis smooth scroll + GSAP/ScrollTrigger, wired to
         the View Transitions lifecycle. Reduced-motion → native scroll, no smooth.
         Bundled module (no CDN). -->
    <script>
      import "../scripts/motion-core";
      import "../scripts/magnetic-hover";
    </script>

    <script>
      // ── Shared scroll-reveal observer ───────────────────────────────────
      // ONE IntersectionObserver for the whole page. Adds `.is-in` to
      // `[data-reveal]` elements as they enter, then unobserves (one-shot).
      // No scroll handlers. Re-runs after View Transition navigations.
      // Reduced-motion + no-IO browsers: reveal everything immediately.
      const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;

      function revealAll() {
        document.documentElement.classList.add("reveal-ready");
        for (const el of document.querySelectorAll("[data-reveal]")) {
          el.classList.add("is-in");
        }
      }

      let observerLive = false;

      function initReveals() {
        observerLive = false;
        if (reduce || !("IntersectionObserver" in window)) {
          revealAll();
          return;
        }
        const io = new IntersectionObserver(
          (entries, obs) => {
            for (const entry of entries) {
              if (!entry.isIntersecting) continue;
              entry.target.classList.add("is-in");
              obs.unobserve(entry.target);
            }
          },
          { rootMargin: "400px 0px 400px 0px", threshold: 0 },
        );
        for (const el of document.querySelectorAll("[data-reveal]:not(.is-in)")) {
          io.observe(el);
        }
        observerLive = true; // only reached if observe() didn't throw
        // Tell the inline-head backstop the reveal system is live so it stands
        // down (it only un-hides if THIS never ran).
        document.documentElement.setAttribute("data-reveals-armed", "");
      }

      // FAIL-SAFE: the inline head script set `reveal-ready` (which hides every
      // [data-reveal] at opacity:0) before paint. The reveal is a PURE progressive
      // enhancement that must NEVER leave content permanently hidden. So:
      //   • try/catch the init — any throw immediately un-hides everything;
      //   • a short backstop un-hides everything if the observer never came up
      //     (e.g. init was aborted by an unrelated error) — but when the observer
      //     IS live we let it run so the scroll-reveal stays intact.
      function safeInit() {
        try {
          initReveals();
        } catch {
          revealAll();
        }
      }
      // Content must NEVER stay hidden. The IO gives an on-scroll entrance for
      // what is seen first, but anything below the fold that the reader never
      // scrolls to would otherwise stay at opacity:0 forever (a sparse-looking
      // feed). So unconditionally reveal everything shortly after load — the
      // page is always fully populated; the scroll entrance is a bonus, not a
      // gate on visibility.
      safeInit();
      window.addEventListener("load", () => setTimeout(revealAll, 1100));
      setTimeout(revealAll, 1800);
      // View Transitions swaps the DOM without a full reload — re-init each nav.
      document.addEventListener("astro:page-load", safeInit);
    </script>
  </body>
</html>

<style>
  .skip-link {
    position: absolute;
    left: -9999px;
    top: 0;
    background: var(--accent);
    color: #000;
    padding: var(--s-2) var(--s-4);
    z-index: 10000;
    font-family: var(--font-mono);
  }
  .skip-link:focus-visible {
    left: var(--s-3);
    top: var(--s-3);
  }

  /* the instrument bezel — a single hairline-ruled bar, thin & always present.
     `.metal` (global.css) gives it the machined anodized grain; a faint top
     edge-light lifts it as a physical surface catching the instrument light. */
  .topbar {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in oklab, var(--bg) 70%, transparent);
    backdrop-filter: blur(8px);
    border-bottom: var(--hair) solid transparent;
    box-shadow: inset 0 var(--hair) 0 color-mix(in oklab, var(--ink) 5%, transparent);
    /* condense on scroll is a transform/opacity-only affair: we animate an
       inner padding token via a custom prop + the inner's transform, never the
       bar's own box. The border/blur deepen as a class flip (cheap). */
    transition:
      background var(--dur) var(--ease-out),
      border-color var(--dur) var(--ease-out);
  }
  /* reading-progress hairline along the very top edge of the header (amber),
     scaleX-driven by the --read-progress custom prop set in Shell's script. */
  .topbar::before {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--accent), var(--editorial));
    transform: scaleX(var(--read-progress, 0));
    transform-origin: left;
    opacity: 0;
    transition: opacity var(--dur) var(--ease-out);
    z-index: 1;
  }
  :global(html.is-scrolled) .topbar::before {
    opacity: 0.9;
  }
  :global(html.is-scrolled) .topbar {
    background: color-mix(in oklab, var(--bg) 86%, transparent);
    border-bottom-color: var(--rule);
  }
  /* the inner row eases up + tightens (translate/scale only) when condensed */
  .topbar-inner {
    transition: transform var(--dur) var(--ease-out);
  }
  :global(html.is-scrolled) .topbar-inner {
    transform: translateY(-1px) scale(0.985);
    transform-origin: left center;
  }
  /* channel row tucks away gracefully on scroll — opacity + a slight lift,
     and we clip it with a max-height that is NOT transitioned (set instantly)
     to avoid animating layout; the fade is the perceived motion. */
  .channels {
    transition:
      opacity var(--dur) var(--ease-out),
      transform var(--dur) var(--ease-out);
    transform-origin: top;
  }
  :global(html.is-scrolled) .channels {
    opacity: 0;
    transform: translateY(-4px);
    pointer-events: none;
  }
  @media (prefers-reduced-motion: reduce) {
    :global(html.is-scrolled) .channels {
      opacity: 1;
      transform: none;
      pointer-events: auto;
    }
    :global(html.is-scrolled) .topbar-inner {
      transform: none;
    }
  }
  /* glass top bar: deeper blur + a faint lit top edge so content scrolls under
     it premium-ly. Falls back to the matte translucent bar where unsupported. */
  :global(html.glass) .topbar {
    background: color-mix(in oklab, var(--bg) 78%, transparent);
  }
  @supports (backdrop-filter: blur(1px)) {
    :global(html.glass) .topbar {
      backdrop-filter: blur(12px) saturate(118%);
      box-shadow: inset 0 var(--hair) 0
        color-mix(in oklab, var(--ink) calc(var(--glass) * 8%), transparent);
    }
  }
  .topbar-inner {
    position: relative;
    z-index: 1; /* above the .metal grain (z-index:0) */
    max-width: var(--maxw);
    margin-inline: auto;
    display: flex;
    align-items: center;
    gap: var(--s-5);
    padding: var(--s-3) var(--s-5);
  }
  /* nav sits just right of the wordmark; the readout + ⌘K hug the far right
     (the live readout is the instrument telemetry — "the instrument is on"). */
  .nav {
    display: flex;
    margin-left: var(--s-2);
  }
  /* live signal readout — tabular mono telemetry in the bezel (art-direction §3) */
  .readout {
    margin: 0 0 0 auto;
    display: inline-flex;
    align-items: baseline;
    gap: 0.45ch;
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    color: var(--ink-faint);
    white-space: nowrap;
  }
  .readout-n {
    color: var(--ink-dim);
  }
  .readout-fresh {
    color: var(--accent);
    text-shadow: 0 0 8px color-mix(in oklab, var(--accent) 35%, transparent);
  }
  .readout-l {
    letter-spacing: 0.04em;
  }
  .readout-sep {
    color: var(--ink-faint);
    margin: 0 0.1ch;
  }
  /* condense on scroll: the readout tucks to just the fresh-count (art-direction
     §3). The "signals" label + total fade; fresh stays as the live pulse. */
  :global(html.is-scrolled) .readout :is(.readout-l):first-of-type,
  :global(html.is-scrolled) .readout > .readout-n:first-of-type,
  :global(html.is-scrolled) .readout .readout-sep {
    opacity: 0;
  }
