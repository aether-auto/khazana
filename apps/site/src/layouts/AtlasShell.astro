---
import "../styles/global.css";
// Preload the two most-used font subsets (same two the Study preloads — the
// reading room is invariant across faces). `?url` resolves to the build's
// hashed asset URL so the preload always matches the @font-face fetch.
import frauncesPreloadUrl from "@fontsource-variable/fraunces/files/fraunces-latin-wght-normal.woff2?url";
import newsreaderPreloadUrl from "@fontsource-variable/newsreader/files/newsreader-latin-opsz-normal.woff2?url";
import Wordmark from "../components/Wordmark.astro";
import CommandPalette from "../components/cmdk/CommandPalette.tsx";
import SiteGate from "../components/SiteGate.astro";
import SiteNav from "../components/nav/SiteNav.tsx";
import InstrumentRail from "../components/atlas/InstrumentRail.astro";
import Breadcrumb from "../components/atlas/Breadcrumb.astro";
import FaceLandingWarmup from "../components/FaceLandingWarmup.astro";
import { ClientRouter } from "astro:transitions";

// AtlasShell — the Atlas counterpart to Shell.astro. It SSR-stamps
// `data-face="atlas"` onto <html> (zero runtime JS, no FOUC; the cold Atlas
// delta in atmosphere.css cascades from the root), renders <SiteGate /> in
// <head> so every /atlas/* route sits behind the SAME access curtain as the
// Study, and provides the vertical instrument rail + mono breadcrumb.
//
// The signature cross-face view-transition (@view-transition, pageswap/
// pagereveal, direction-branched CSS) is a SEPARATE future task — the bezel
// switch here is a plain <a data-astro-reload> link that does a full-document
// navigation. The data-astro-reload attribute is inert without step 3's
// wiring; adding it now means step 3 needs no markup change to this control.
const GLASS = true;

interface Props {
  title: string;
  description?: string;
  /** Which of the seven Atlas surfaces is the current page (lit in the rail). */
  active: "globe" | "reports" | "browser" | "bias" | "theaters" | "structure" | "sources";
  /** Breadcrumb segments AFTER the always-present leading `atlas` crumb. */
  crumbs?: string[];
}
const {
  title,
  description = "khazana Atlas — a cold instrument atmosphere for the world's data: country reports, indicators, bias, conflict theaters, and government structure.",
  active,
  crumbs = [],
} = Astro.props;

const base = import.meta.env.BASE_URL;
const withBase = (p: string) => `${base.replace(/\/$/, "")}/${p.replace(/^\//, "")}`;

const buildTime = new Date().toISOString();
---

<!doctype html>
<html lang="en" data-face="atlas" class:list={[{ glass: GLASS }]}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#08090b" />
    <link rel="preload" as="font" type="font/woff2" href={frauncesPreloadUrl} crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={newsreaderPreloadUrl} crossorigin />
    <link rel="manifest" href={withBase("/manifest.webmanifest")} />
    <link rel="icon" href={withBase("/icon.svg")} type="image/svg+xml" />
    <meta name="generator" content={Astro.generator} />
    {/* SAME access curtain as the Study. Renders nothing when
        PUBLIC_SITE_GATE_HASH is unset; when set, gates every /atlas/* route. */}
    <SiteGate />
    {/* Signature face-switch transition (two-faces spec §4) — same wiring as the
        Study shell so a crossing in EITHER direction is choreographed. The
        `@view-transition` opt-in is render-blocking + inline; the direction-
        branched choreography lives in styles/face-switch.css. */}
    <style is:inline>@view-transition { navigation: auto; }</style>
    <ClientRouter />
    {/* The ONLY JS in the transition: sets the VT `type` in pageswap, echoes it
        + lands focus in pagereveal, listens for the TimeoutError, and drives the
        no-VT data-just-crossed fade. Inert unless a face crossing fires. */}
    <script>
      import "../lib/face-switch.ts";
    </script>
    {/* Moderated cross-face warmup (faces-prerender-polish). Prerenders ONLY
        the opposite landing (/ from here) via inline Speculation Rules, with
        a bezel-scoped `<link rel="prefetch">` fallback on engines without
        Speculation Rules support. Never touches face-switch.ts, the VT
        choreography, or data-astro-reload semantics. */}
    <FaceLandingWarmup face="atlas" />
    <script is:inline>
      // Gate the reveal hidden-state before paint (JS-on only, reduced-motion
      // opted out), with a load backstop that un-hides everything if the reveal
      // module never took over — content must NEVER stay permanently invisible.
      if (!matchMedia("(prefers-reduced-motion: reduce)").matches) {
        document.documentElement.classList.add("reveal-ready");
        window.addEventListener("load", function () {
          setTimeout(function () {
            if (document.documentElement.hasAttribute("data-reveals-armed")) return;
            for (var el of document.querySelectorAll("[data-reveal]:not(.is-in)")) {
              el.classList.add("is-in");
            }
          }, 3000);
        });
      }
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="bezel metal">
      <div class="bezel-inner">
        <Wordmark />
        <span class="bezel-face" aria-hidden="true">atlas</span>
        {/* The bezel face-switch — a plain link, zero JS, degrades to a link
            with JS disabled. Atlas is lit; STUDY is dim; it navigates back to
            the Study root as a full-document load (data-astro-reload). */}
        <a
          class="face-switch"
          href={withBase("/")}
          data-astro-reload
          data-face-switch
          aria-label="Switch to the Study"
        >
          <span class="face-opt is-current">atlas</span>
          <span class="face-swap" aria-hidden="true">⟷</span>
          <span class="face-opt">STUDY</span>
        </a>
        <button
          class="cmdk"
          type="button"
          data-magnetic
          aria-label="Open command palette"
          aria-keyshortcuts="Meta+K Control+K"
        >
          <span class="cmdk-icon" aria-hidden="true">⌘</span>
          <span class="cmdk-label">command</span>
          <kbd class="cmdk-keys" aria-hidden="true">⌘K</kbd>
        </button>
      </div>
    </header>

    <div class="atlas-frame">
      <aside class="atlas-rail">
        <InstrumentRail active={active} />
      </aside>
      <main id="main" class="atlas-main">
        <Breadcrumb crumbs={crumbs} />
        <slot />
      </main>
    </div>

    <footer class="footer">
      <span>khazana atlas — the world's data, one instrument · static, $0, open source</span>
      <span class="build">
        build <time datetime={buildTime}>{buildTime.slice(0, 16).replace("T", " ")}Z</time>
      </span>
    </footer>

    <CommandPalette base={base} face="atlas" client:idle />
    <SiteNav base={base} client:idle />

    <script>
      import "../scripts/motion-core";
      import "../scripts/magnetic-hover";
    </script>

    <script>
      // Shared scroll-reveal observer (one IntersectionObserver; one-shot).
      // Reduced-motion + no-IO → reveal everything immediately. Re-runs after
      // View Transition navigations. Content must NEVER stay hidden.
      const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;
      function revealAll() {
        document.documentElement.classList.add("reveal-ready");
        for (const el of document.querySelectorAll("[data-reveal]")) {
          el.classList.add("is-in");
        }
      }
      function initReveals() {
        if (reduce || !("IntersectionObserver" in window)) {
          revealAll();
          return;
        }
        const io = new IntersectionObserver(
          (entries, obs) => {
            for (const entry of entries) {
              if (!entry.isIntersecting) continue;
              entry.target.classList.add("is-in");
              obs.unobserve(entry.target);
            }
          },
          { rootMargin: "400px 0px 400px 0px", threshold: 0 },
        );
        for (const el of document.querySelectorAll("[data-reveal]:not(.is-in)")) {
          io.observe(el);
        }
        document.documentElement.setAttribute("data-reveals-armed", "");
      }
      function safeInit() {
        try {
          initReveals();
        } catch {
          revealAll();
        }
      }
      safeInit();
      window.addEventListener("load", () => setTimeout(revealAll, 1100));
      setTimeout(revealAll, 1800);
      document.addEventListener("astro:page-load", safeInit);
    </script>
  </body>
</html>

<style>
  .skip-link {
    position: absolute;
    left: -9999px;
    top: 0;
    background: var(--info);
    color: #000;
    padding: var(--s-2) var(--s-4);
    z-index: 10000;
    font-family: var(--font-mono);
  }
  .skip-link:focus-visible {
    left: var(--s-3);
    top: var(--s-3);
  }

  /* the Atlas bezel — the cold instrument counterpart to the Study topbar. */
  .bezel {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in oklab, var(--bg) 70%, transparent);
    backdrop-filter: blur(8px);
    border-bottom: var(--hair) solid var(--rule);
    box-shadow: inset 0 var(--hair) 0 color-mix(in oklab, var(--info) 6%, transparent);
  }
  @supports (backdrop-filter: blur(1px)) {
    :global(html.glass) .bezel {
      backdrop-filter: blur(12px) saturate(112%);
    }
  }
  .bezel-inner {
    position: relative;
    z-index: 1;
    max-width: var(--maxw);
    margin-inline: auto;
    display: flex;
    align-items: center;
    gap: var(--s-4);
    padding: var(--s-3) var(--s-5);
  }
  .bezel-face {
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--info);
  }

  /* the segmented face-switch — two mono small-caps, current lit (cool slate),
     the other dim. A real link; works with JS disabled. */
  .face-switch {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: var(--s-2);
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-faint);
    border: var(--hair) solid var(--rule);
    border-radius: var(--r-md);
    padding: var(--s-2) var(--s-3);
    transition:
      border-color var(--dur-fast) var(--ease-out),
      background var(--dur-fast) var(--ease-out);
  }
  .face-switch:hover {
    text-decoration: none;
    border-color: color-mix(in oklab, var(--info) 45%, var(--rule));
    background: color-mix(in oklab, var(--info) 8%, transparent);
  }
  .face-switch:focus-visible {
    outline: 2px solid var(--info);
    outline-offset: 2px;
  }
  .face-opt {
    color: var(--ink-faint);
  }
  .face-opt.is-current {
    color: var(--info);
    text-shadow: 0 0 8px color-mix(in oklab, var(--info) 35%, transparent);
  }
  .face-swap {
    color: var(--ink-faint);
    opacity: 0.7;
  }

  .cmdk {
    flex: none;
    display: inline-flex;
    align-items: center;
    gap: var(--s-2);
    background: color-mix(in oklab, var(--info) 7%, var(--bg-raised));
    border: var(--hair) solid color-mix(in oklab, var(--info) 22%, var(--rule));
    border-radius: var(--r-md);
    color: var(--ink-dim);
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    padding: var(--s-2) var(--s-3);
    cursor: pointer;
    will-change: transform;
    transition:
      color var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out),
      background var(--dur-fast) var(--ease-out),
      transform var(--dur) var(--ease-overshoot);
  }
  .cmdk:hover {
    color: var(--ink);
    border-color: color-mix(in oklab, var(--info) 45%, var(--rule));
    background: color-mix(in oklab, var(--info) 12%, var(--bg-raised));
  }
  .cmdk:active {
    transform: scale(0.97);
  }
  .cmdk:focus-visible {
    outline: 2px solid var(--info);
    outline-offset: 2px;
  }
  .cmdk-icon {
    color: var(--info);
    font-size: var(--t-sm);
    line-height: 1;
  }
  .cmdk-label {
    letter-spacing: 0.04em;
  }
  .cmdk-keys {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.05em;
    color: var(--ink-faint);
    background: color-mix(in oklab, var(--ink) 7%, transparent);
    border: var(--hair) solid var(--rule);
    border-radius: var(--r-sm);
    padding: 0.05em 0.3em;
  }
  @media (max-width: 760px) {
    .cmdk-label {
      display: none;
    }
    .cmdk-keys {
      display: none;
    }
  }
  /* MOBILE: the bezel's min-content width (wordmark + `atlas` label + full
     switch + ⌘K) exceeds 320–414px viewports. Compact it: drop the standalone
     face label + the switch's dim option/arrow, tighten gaps, and let the row
     wrap so nothing clips or forces a horizontal scroll. The crossing stays
     reachable (the lit label links to /, plus the ⌘K crossing command). */
  @media (max-width: 560px) {
    .bezel-inner {
      flex-wrap: wrap;
      gap: var(--s-3);
      padding: var(--s-3) var(--s-4);
    }
    .bezel-face {
      display: none;
    }
    .face-switch .face-opt:not(.is-current),
    .face-switch .face-swap {
      display: none;
    }
  }

  /* two-column instrument frame: the vertical rail, then the surface body. */
  .atlas-frame {
    max-width: var(--maxw);
    margin-inline: auto;
    display: grid;
    grid-template-columns: 220px minmax(0, 1fr);
    gap: var(--s-6);
    padding: var(--s-5);
    align-items: start;
  }
  .atlas-rail {
    position: sticky;
    top: calc(var(--s-6) + 3rem);
    align-self: start;
  }
  .atlas-main {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: var(--s-5);
  }
  @media (max-width: 820px) {
    .atlas-frame {
      grid-template-columns: minmax(0, 1fr);
      gap: var(--s-4);
    }
    .atlas-rail {
      position: static;
    }
  }

  .footer {
    max-width: var(--maxw);
    margin-inline: auto;
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: var(--s-3);
    padding: var(--s-6) var(--s-5);
    border-top: var(--hair) solid var(--rule);
    color: var(--ink-faint);
    font-size: var(--t-xs);
  }
  .build time {
    color: var(--ink-dim);
  }
</style>
