---
// "First Light" hero — the signature moment.
//
// The constellation is the day's real signal (each star = a curated FeedItem,
// positioned by channel/recency/rank). The brightest stars ARE the lead feed
// cards below; the field settles forward INTO the feed (continuity, not a
// separate banner — art-direction §1, §4).
//
// Render order is the perf contract made literal:
//   1. SSR: the baked static SVG star-field + the headline render immediately
//      (first paint never waits on WebGL; no-JS / no-WebGL / reduced-motion /
//      mobile get a complete, beautiful hero).
//   2. The OGL <Constellation> island mounts client-only and fades IN over the
//      baked field, plays First Light, then settles.
import type { FeedItem } from "@khazana/core";
import { buildConstellation } from "./lib/constellation.js";
import { bakeStarFieldSVG } from "./lib/bake.js";
import Constellation from "./Constellation.tsx";

interface Props {
  items: FeedItem[];
  /** ISO build time → deterministic recency so SSR + island agree. */
  now: string;
}
const { items, now } = Astro.props;

// One source of truth: build the constellation once, server-side. The island
// receives the SAME stars (no client re-derivation, no hydration drift).
const stars = buildConstellation(items, Date.parse(now));
const bakedSVG = bakeStarFieldSVG(stars);
const fresh = items.filter(
  (it) => Date.parse(now) - Date.parse(it.publishedAt) < 24 * 60 * 60 * 1000,
).length;
---

<section class="first-light" aria-label="First Light — today's signal">
  <!-- baked static field: ALWAYS present (first paint, no-JS, no-WebGL,
       reduced-motion, mobile). The live canvas fades in over it. -->
  <div class="constellation-stage" set:html={bakedSVG} />

  <!-- live OGL field — client only; never blocks first paint -->
  <Constellation stars={stars} client:only="react" />

  <!-- a faint lens-vignette so the field reads as seen through an instrument -->
  <div class="first-light-vignette" aria-hidden="true"></div>

  <div class="first-light-copy">
    <p class="fl-eyebrow">
      <span class="fl-dot" aria-hidden="true"></span>
      the observatory · <span class="tnum">{items.length}</span> signals
      {fresh > 0 && (
        <>
          {" · "}<span class="fl-fresh tnum">{String(fresh).padStart(2, "0")}</span> fresh
        </>
      )}
    </p>
    <h1 class="fl-title display">
      first light<span class="fl-stop">.</span>
    </h1>
    <p class="fl-sub reading">
      The day&rsquo;s signal, caught and ranked — the brightest catches lead the feed below.
    </p>
  </div>
</section>

<style>
  .first-light {
    position: relative;
    /* a tall-ish stage that the feed settles out of — generous on desktop,
       compact on phones (where the baked field carries it). */
    min-height: clamp(340px, 56vh, 560px);
    margin: calc(-1 * var(--s-4)) calc(-1 * var(--s-5)) var(--s-8);
    padding: var(--s-10) var(--s-5) var(--s-8);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    overflow: hidden;
    isolation: isolate;
  }

  /* the baked SVG + the live canvas share this absolutely-positioned stage */
  .constellation-stage,
  .first-light :global(.constellation-canvas) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
  }
  .constellation-stage :global(svg) {
    width: 100%;
    height: 100%;
    display: block;
  }
  /* baked field gently breathes in on load (one-shot; calm) */
  .constellation-stage {
    opacity: 0;
    animation: fl-bake-in 1200ms var(--ease-out) 80ms forwards;
  }
  @keyframes fl-bake-in {
    to {
      opacity: 1;
    }
  }
  /* once the live canvas is up, dim the baked field beneath it so we don't
     double-expose the stars (the island adds .constellation--live to the host) */
  .first-light :global(.constellation-canvas) {
    opacity: 0;
    transition: opacity 900ms var(--ease-out);
  }
  .first-light :global(.constellation-canvas.is-live) {
    opacity: 1;
  }
  .first-light.constellation--live .constellation-stage,
  .first-light :global(.constellation--live) .constellation-stage {
    opacity: 0.18;
  }

  /* lens vignette — focus the eye toward the warm center */
  .first-light-vignette {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      radial-gradient(120% 100% at 50% 42%, transparent 45%, rgba(7, 7, 5, 0.55) 100%),
      radial-gradient(60% 50% at 50% 40%, rgba(255, 182, 39, 0.05), transparent 70%);
  }

  .first-light-copy {
    position: relative;
    z-index: 2;
    max-width: 56ch;
  }
  .fl-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5ch;
    margin: 0 0 var(--s-3);
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    letter-spacing: 0.06em;
    text-transform: lowercase;
    color: var(--ink-faint);
  }
  .fl-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: var(--halo-star);
    animation: fl-pulse 2.6s ease-in-out infinite;
  }
  @keyframes fl-pulse {
    0%,
    100% {
      opacity: 0.55;
    }
    50% {
      opacity: 1;
    }
  }
  .fl-fresh {
    color: var(--accent);
  }
  .fl-title {
    margin: 0 0 var(--s-3);
    font-size: var(--t-display);
    color: var(--ink);
    line-height: 0.95;
  }
  .fl-stop {
    color: var(--accent);
    text-shadow: var(--halo-display);
  }
  .fl-sub {
    margin: 0;
    color: var(--ink-dim);
    font-size: var(--t-md);
    max-width: 48ch;
  }

  @media (max-width: 600px) {
    .first-light {
      min-height: 320px;
      padding-top: var(--s-8);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .constellation-stage,
    .fl-dot {
      animation: none;
      opacity: 1;
    }
  }
</style>
