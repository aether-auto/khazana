---
import { FORMATS, type FormatName } from "@khazana/core";
interface Props {
  format: string;
}
const { format } = Astro.props;
const meta = FORMATS[format as FormatName];
const intent = meta?.intent ?? "";
---

<span class="fmt" data-format={format} title={intent ? `intent: ${intent}` : undefined}>
  <span class="fmt-bracket" aria-hidden="true">«</span>{format}<span
    class="fmt-bracket"
    aria-hidden="true">»</span>
</span>

<style>
  .fmt {
    position: relative;
    display: inline-block;
    overflow: hidden;
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--editorial);
    border: var(--hair) solid color-mix(in oklab, var(--editorial) 45%, var(--rule));
    border-radius: var(--r-sm);
    padding: 0.12em 0.5em;
    white-space: nowrap;
  }
  /* thin diagonal specular sheen (glass-gated) sweeping on hover of the
     enclosing card/link — transform-translated pseudo, no bg thrash. */
  .fmt::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(
      105deg,
      transparent 35%,
      var(--glass-sheen) 50%,
      transparent 65%
    );
    opacity: calc(var(--glass) * 1);
    transform: translateX(-130%);
    transition: transform var(--dur-slow) var(--ease-out);
  }
  .fmt:hover::after {
    transform: translateX(130%);
  }
  .fmt-bracket {
    color: color-mix(in oklab, var(--editorial) 70%, transparent);
  }
</style>
