---
import { FORMATS, type FormatName } from "@khazana/core";
interface Props {
  format: string;
}
const { format } = Astro.props;
const meta = FORMATS[format as FormatName];
const intent = meta?.intent ?? "";
---

<span class="fmt" data-format={format} title={intent ? `intent: ${intent}` : undefined}>
  <span class="fmt-bracket" aria-hidden="true">«</span>{format}<span
    class="fmt-bracket"
    aria-hidden="true">»</span>
</span>

<style>
  .fmt {
    position: relative;
    display: inline-block;
    overflow: hidden;
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--editorial);
    border: var(--hair) solid color-mix(in oklab, var(--editorial) 45%, var(--rule));
    border-radius: var(--r-sm);
    padding: 0.12em 0.5em;
    white-space: nowrap;
    /* glass-gated: subtle dark translucent background + always-on lit top edge */
    background: color-mix(in oklab, var(--glass-bg) calc(var(--glass) * 80%), transparent);
    box-shadow: inset 0 var(--hair) 0 color-mix(in oklab, var(--editorial) calc(var(--glass) * 28%), transparent);
  }
  /* always-on faint specular highlight (glass-gated): a static diagonal glint
     sits in the upper-left corner so the badge reads as glass even at rest. */
  .fmt::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(
      135deg,
      color-mix(in oklab, var(--ink) calc(var(--glass) * 12%), transparent) 0%,
      transparent 50%
    );
  }
  /* hover sweep — bolder than the resting glint */
  .fmt::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(
      105deg,
      transparent 30%,
      color-mix(in oklab, var(--editorial) 32%, transparent) 48%,
      transparent 64%
    );
    opacity: calc(var(--glass) * 1);
    transform: translateX(-130%);
    transition: transform var(--dur-slow) var(--ease-out);
  }
  .fmt:hover::after {
    transform: translateX(130%);
  }
  .fmt-bracket {
    color: color-mix(in oklab, var(--editorial) 70%, transparent);
  }
</style>
