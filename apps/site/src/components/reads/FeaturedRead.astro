---
// The FEATURED hero for the /reads index — the most recent read, presented large.
// CRITICAL View-Transition contract: this hero's title (an <h2> — content under
// the page <h1>, see a11y heading order) owns `read-title-${slug}` for the
// featured read, so the morph runs into the read page's title. The transition:name
// is carried on the tag regardless of level. Exactly ONE element per page may carry
// a given transition:name, so the featured read is EXCLUDED from the gallery grid
// (buildReadsIndex enforces the disjoint split).
//
// Atmosphere: a restrained, format-keyed amber/clay glow that drifts slowly behind
// the masthead (transform/opacity only, GPU-cheap, 60fps; stilled under
// prefers-reduced-motion). No WebGL, no rainbow — a single living detail. The
// second glow (`.atmos-clay`) is tinted with THIS read's format accent
// (lib/format-style.ts — the same centralized map the gallery cards use), so
// the hero's atmosphere genuinely shifts hue with what's featured, not just its
// badge text — a chronicle glows clay, a teardown glows a cooler technical tone.
import FormatBadge from "../FormatBadge.astro";
import ChannelChip from "../ChannelChip.astro";
import { formatStyle } from "./lib/format-style.js";

interface Props {
  slug: string;
  title: string;
  format: string;
  channels: string[];
  summary: string;
  href: string;
  publishedAt: string;
  dateLabel: string;
  readMin: number;
  sourceCount: number;
}
const { slug, title, format, channels, summary, href, publishedAt, dateLabel, readMin, sourceCount } =
  Astro.props;
const fmt = formatStyle(format);
// A stable issue number derived from the slug — the same hand-built-artifact
// detail the Article masthead uses (Article.astro), so the hero and the read agree.
const issueNo = (Array.from(slug).reduce((a, c) => (a + c.charCodeAt(0)) % 999, 0) + 1);
const issueLabel = `No. ${String(issueNo).padStart(3, "0")}`;
---

<!-- The featured read carries its facet metadata for completeness/consistency
     with the gallery cards, but it lives OUTSIDE [data-reads-grid] and is never a
     filter target (it is always the latest read, shown regardless of filter). -->
<section
  class="featured"
  data-reveal
  data-reads-featured
  data-format={format}
  data-channels={channels.join(",")}
  data-published={publishedAt}
  aria-labelledby="featured-title"
  style={`--fmt-accent:${fmt.color};`}
>
  <a class="featured-link" href={href}>
    <!-- the living atmosphere: two slow-drifting amber/clay glows behind the
         masthead. Pure transform/opacity, paused under reduced-motion. -->
    <div class="featured-atmos" aria-hidden="true">
      <span class="atmos-glow atmos-amber"></span>
      <span class="atmos-glow atmos-clay"></span>
    </div>

    <div class="featured-inner">
      <p class="featured-kicker">
        <span class="featured-flag">latest read</span>
        <span class="featured-issue">{issueLabel}</span>
        <span class="ksep" aria-hidden="true">·</span>
        <span class="featured-code tnum" aria-hidden="true">{fmt.code}</span>
        <FormatBadge format={format} />
        <span
          class="featured-new"
          data-new-badge
          hidden
          aria-label="new since your last visit"
        >
          <span class="featured-new-dot" aria-hidden="true"></span>new
        </span>
        <span class="ksep" aria-hidden="true">·</span>
        <time class="tnum" datetime={dateLabel}>{dateLabel}</time>
      </p>

      <!-- This is content UNDER the page <h1>, not a second document title, so it
           is an <h2> (a11y heading order). The view-transition name is carried on
           the tag regardless of level, so the morph into the read is unaffected. -->
      <h2 class="featured-title display" id="featured-title" transition:name={`read-title-${slug}`}>
        {title}
      </h2>

      <p class="featured-standfirst">{summary}</p>

      <div class="featured-foot">
        <div class="featured-channels">
          {channels.map((c) => <ChannelChip channel={c} />)}
        </div>
        <p class="featured-telemetry tnum" aria-label="reading telemetry">
          <span>{readMin} min read</span>
          <span class="tsep" aria-hidden="true">·</span>
          <span>{sourceCount} source{sourceCount === 1 ? "" : "s"}</span>
        </p>
      </div>

      <span class="featured-cta">
        read the latest <span class="cta-arrow" aria-hidden="true">→</span>
      </span>
    </div>
  </a>
</section>

<style>
  .featured {
    position: relative;
    margin-bottom: var(--s-10);
    /* the hero is a filter target: when the active chip doesn't match it, the
       ReadsFilter island adds .is-filtered-out and we dim it back (opacity +
       grayscale) and shrink it slightly — "this read is filtered away", while
       keeping it in the DOM so its view-transition title persists. */
    transition:
      opacity var(--dur) var(--ease-out),
      filter var(--dur) var(--ease-out),
      transform var(--dur) var(--ease-out);
  }
  .featured.is-filtered-out {
    opacity: 0.32;
    filter: grayscale(0.6);
    transform: scale(0.992);
    pointer-events: none;
  }
  /* stop the living atmosphere from drifting while dimmed — it's "asleep" */
  .featured.is-filtered-out .atmos-glow {
    animation-play-state: paused;
    opacity: 0.25;
  }
  @media (prefers-reduced-motion: reduce) {
    .featured {
      transition: opacity var(--dur) var(--ease-out);
    }
    .featured.is-filtered-out {
      transform: none;
    }
  }
  .featured-link {
    position: relative;
    display: block;
    overflow: hidden;
    border: var(--hair) solid var(--rule);
    border-radius: var(--r-md);
    /* deep instrument-panel surface with a warm top-edge light — same family as
       the read masthead (Article .article-head). */
    background:
      radial-gradient(130% 120% at 16% 0%, color-mix(in oklab, var(--accent) 8%, transparent), transparent 56%),
      var(--bg-card);
    box-shadow:
      inset 0 var(--hair) 0 color-mix(in oklab, var(--accent) 18%, transparent),
      inset 0 0 0 var(--hair) var(--rule);
    transition:
      border-color var(--dur) var(--ease-out),
      transform var(--dur) var(--ease-out),
      box-shadow var(--dur) var(--ease-out);
  }
  .featured-link:hover {
    text-decoration: none;
    border-color: color-mix(in oklab, var(--accent) 40%, var(--rule));
    transform: translateY(-2px);
    box-shadow:
      inset 0 var(--hair) 0 color-mix(in oklab, var(--accent) 26%, transparent),
      inset 0 0 0 var(--hair) var(--rule),
      0 18px 50px -28px color-mix(in oklab, var(--accent) 40%, transparent);
  }
  .featured-link:active {
    transform: translateY(0);
  }

  /* ── living atmosphere — slow-drifting glows, transform/opacity only ─────── */
  .featured-atmos {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 0;
  }
  .atmos-glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(46px);
    opacity: 0.5;
    will-change: transform;
  }
  .atmos-amber {
    width: 42%;
    height: 130%;
    top: -28%;
    left: 4%;
    background: radial-gradient(circle, color-mix(in oklab, var(--accent) 30%, transparent), transparent 66%);
    animation: drift-amber 19s var(--ease-out) infinite alternate;
  }
  .atmos-clay {
    width: 38%;
    height: 130%;
    top: -10%;
    right: 2%;
    /* tinted with THIS read's format accent (--fmt-accent, set inline from
       lib/format-style.ts) rather than a fixed clay — the hero's atmosphere
       shifts hue with whatever format is currently featured. */
    background: radial-gradient(circle, color-mix(in oklab, var(--fmt-accent) 26%, transparent), transparent 66%);
    animation: drift-clay 23s var(--ease-out) infinite alternate;
  }
  @keyframes drift-amber {
    from { transform: translate3d(0, 0, 0) scale(1); }
    to { transform: translate3d(8%, 6%, 0) scale(1.12); }
  }
  @keyframes drift-clay {
    from { transform: translate3d(0, 4%, 0) scale(1.05); }
    to { transform: translate3d(-7%, -5%, 0) scale(0.95); }
  }
  /* a faint amber lift on hover — the atmosphere responds to attention */
  .featured-link:hover .atmos-glow {
    opacity: 0.7;
  }
  .atmos-glow {
    transition: opacity var(--dur-slow) var(--ease-out);
  }

  .featured-inner {
    position: relative;
    z-index: 1;
    padding: clamp(var(--s-6), 5vw, var(--s-10)) clamp(var(--s-5), 5vw, var(--s-10));
    max-width: 62ch;
  }

  .featured-kicker {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--s-2);
    margin: 0 0 var(--s-5);
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    color: var(--ink-faint);
  }
  .featured-flag {
    color: var(--bg-inset);
    background: var(--accent);
    border-radius: var(--r-sm);
    padding: 0.18em 0.55em;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 600;
    box-shadow: 0 0 16px -4px color-mix(in oklab, var(--accent) 70%, transparent);
  }
  .featured-issue {
    color: var(--accent);
    letter-spacing: 0.04em;
  }
  .ksep {
    color: var(--rule-bright);
  }
  /* the mono ticker code — same identity mark the gallery cards wear */
  .featured-code {
    letter-spacing: 0.1em;
    color: var(--fmt-accent);
    opacity: 0.85;
  }
  /* "new since your last visit" — hidden by default; the page script un-hides
     it after checking localStorage (mirrors ReadGalleryCard's .gcard-new). */
  .featured-new {
    display: inline-flex;
    align-items: center;
    gap: 0.4ch;
    color: var(--accent);
    text-shadow: 0 0 8px color-mix(in oklab, var(--accent) 35%, transparent);
  }
  /* see ReadGalleryCard's .gcard-new[hidden] — same reasoning: an author
     `display` rule otherwise beats the UA `[hidden]` rule at equal specificity. */
  .featured-new[hidden] {
    display: none;
  }
  .featured-new-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 3px color-mix(in oklab, var(--accent) 22%, transparent);
    animation: featured-new-pulse 2.4s ease-in-out infinite;
  }
  @keyframes featured-new-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.45; }
  }
  @media (prefers-reduced-motion: reduce) {
    .featured-new-dot {
      animation: none;
    }
  }

  .featured-title {
    margin: 0 0 var(--s-5);
    font-size: var(--t-display-sm);
    line-height: 1.02;
    color: var(--ink);
    font-variation-settings: "opsz" 120, "SOFT" 0, "WONK" 0;
    letter-spacing: -0.02em;
    text-wrap: balance;
  }

  .featured-standfirst {
    margin: 0 0 var(--s-6);
    font-family: var(--font-read);
    font-optical-sizing: auto;
    font-size: var(--t-lg);
    line-height: 1.45;
    color: var(--read);
    font-style: italic;
    max-width: 52ch;
  }

  .featured-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--s-3);
    margin-bottom: var(--s-6);
  }
  .featured-channels {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-2);
  }
  .featured-telemetry {
    margin: 0;
    display: inline-flex;
    align-items: baseline;
    gap: 0.6ch;
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    color: var(--ink-faint);
    white-space: nowrap;
  }
  .tsep {
    color: var(--rule-bright);
  }

  .featured-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5ch;
    font-family: var(--font-mono);
    font-size: var(--t-sm);
    letter-spacing: 0.04em;
    color: var(--accent);
  }
  .cta-arrow {
    display: inline-block;
    transition: transform var(--dur) var(--ease-overshoot);
  }
  .featured-link:hover .cta-arrow {
    transform: translateX(5px);
  }

  @media (prefers-reduced-motion: reduce) {
    .atmos-amber,
    .atmos-clay {
      animation: none;
    }
    .cta-arrow,
    .featured-link {
      transition: none;
    }
  }
</style>
