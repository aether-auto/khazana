---
// A refined gallery card for the /reads index — a sibling of ReadCard that adds
// the channels, real read-time and source-count telemetry the collection wants.
// It keeps the house glass/sheen/hover micro-interactions and the per-slug
// `transition:name` on its title (so navigating into the read morphs the title).
// The card is a filter target: it carries data-read / data-format / data-channels
// so the ReadsFilter island can show/hide it by facet without re-rendering.
import FormatBadge from "../FormatBadge.astro";
import ChannelChip from "../ChannelChip.astro";

interface Props {
  slug: string;
  title: string;
  format: string;
  channels: string[];
  summary: string;
  href: string;
  dateLabel: string;
  readMin: number;
  sourceCount: number;
  revealDelay?: number;
}
const {
  slug,
  title,
  format,
  channels,
  summary,
  href,
  dateLabel,
  readMin,
  sourceCount,
  revealDelay = 0,
} = Astro.props;
---

<article
  class="gcard"
  data-reveal
  data-read
  data-format={format}
  data-channels={channels.join(",")}
  style={`--reveal-delay:${revealDelay}ms`}
>
  <a class="gcard-link" href={href}>
    <div class="gcard-top">
      <FormatBadge format={format} />
      <time class="gcard-date tnum" datetime={dateLabel}>{dateLabel}</time>
    </div>

    <h3 class="gcard-title" transition:name={`read-title-${slug}`}>{title}</h3>
    <p class="gcard-summary">{summary}</p>

    <div class="gcard-foot">
      <div class="gcard-channels">
        {channels.map((c) => <ChannelChip channel={c} />)}
      </div>
      <p class="gcard-telemetry tnum" aria-label="reading telemetry">
        <span>{readMin} min</span>
        <span class="gcard-sep" aria-hidden="true">·</span>
        <span>{sourceCount} source{sourceCount === 1 ? "" : "s"}</span>
      </p>
    </div>

    <span class="gcard-cta" aria-hidden="true">read →</span>
  </a>
</article>

<style>
  .gcard {
    position: relative;
    border: var(--hair) solid var(--rule);
    border-radius: var(--r-md);
    /* glass surface: dark translucent panel + lit top edge (matches ReadCard) */
    background: color-mix(
      in oklab,
      var(--glass-bg) calc(var(--glass) * 100%),
      var(--bg-raised) calc(100% - var(--glass) * 100%)
    );
    box-shadow: inset 0 var(--hair) 0
      color-mix(in oklab, var(--ink) calc(var(--glass) * 10%), transparent);
    backdrop-filter: blur(calc(var(--glass) * 10px)) saturate(calc(1 + var(--glass) * 0.15));
    overflow: hidden;
    transition:
      border-color var(--dur) var(--ease-out),
      transform var(--dur) var(--ease-out);
  }
  .gcard:hover {
    border-color: var(--editorial);
    transform: translateY(-2px) scale(1.005);
  }
  .gcard:active {
    transform: translateY(0) scale(1);
  }
  /* specular sheen sweep — diagonal amber band translated across on hover */
  .gcard::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(
      105deg,
      transparent 28%,
      color-mix(in oklab, var(--accent) 26%, transparent) 46%,
      transparent 60%
    );
    opacity: calc(var(--glass) * 1);
    transform: translateX(-120%);
    transition: transform var(--dur-slow) var(--ease-out);
  }
  .gcard:hover::after {
    transform: translateX(120%);
  }
  .gcard-link {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
    padding: var(--s-5);
    height: 100%;
  }
  .gcard-link:hover {
    text-decoration: none;
  }
  .gcard-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--s-3);
  }
  .gcard-date {
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    color: var(--ink-faint);
  }
  .gcard-title {
    margin: 0;
    font-family: var(--font-read);
    font-size: var(--t-lg);
    line-height: var(--lh-tight);
    color: var(--ink);
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .gcard-summary {
    margin: 0;
    font-family: var(--font-read);
    color: var(--ink-dim);
    font-size: var(--t-base);
    line-height: 1.5;
    /* clamp long summaries so cards keep an even height in the grid */
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .gcard-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--s-2) var(--s-3);
    margin-top: var(--s-1);
  }
  .gcard-channels {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-2);
  }
  .gcard-telemetry {
    margin: 0;
    display: inline-flex;
    align-items: baseline;
    gap: 0.55ch;
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    color: var(--ink-faint);
    white-space: nowrap;
  }
  .gcard-sep {
    color: var(--rule-bright);
  }
  .gcard-cta {
    margin-top: auto;
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    color: var(--editorial);
    letter-spacing: 0.04em;
    transition: transform var(--dur) var(--ease-out);
  }
  .gcard:hover .gcard-cta {
    transform: translateX(3px);
  }
</style>
