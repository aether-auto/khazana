---
interface Props {
  href?: string;
}
const { href = Astro.url.pathname } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<a class="wordmark" href={href === Astro.url.pathname ? base : href} aria-label="khazana — home">
  <span class="prompt" aria-hidden="true">›</span><span class="name">khazana</span>
</a>

<style>
  .wordmark {
    display: inline-flex;
    align-items: baseline;
    gap: 0.35em;
    font-family: var(--font-mono);
    font-size: var(--t-lg);
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--ink);
    text-decoration: none;
  }
  .wordmark:hover {
    text-decoration: none;
    text-shadow: none;
  }
  .prompt {
    color: var(--accent);
  }
  .name {
    color: var(--ink);
  }
</style>
