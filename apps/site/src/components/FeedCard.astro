---
import type { FeedItem } from "@khazana/core";
import ChannelChip from "./ChannelChip.astro";
import SourceBadge from "./SourceBadge.astro";
import Metric from "./Metric.astro";
import TimeAgo from "./TimeAgo.astro";
import type { BentoSize } from "../lib/bento.js";
import { readTimeFromHtml } from "../lib/read-time.js";
import { extractYouTubeId, buildYouTubeThumbnail } from "../lib/media.js";

interface Props {
  item: FeedItem;
  now: string;
  /** Scroll-reveal stagger delay in ms (capped by the caller). */
  revealDelay?: number;
  /** Bento cell size — drives the grid span (see index.astro grid CSS). */
  size?: BentoSize;
}
const { item, now, revealDelay = 0, size = "regular" } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const channelHref = (c: string) => `${base}/?channel=${c}`;
const readHref = `${base}/item/${item.id}`;
// Only show reading time for items with real full-text body (on-khazana reads).
const readMin = item.body ? readTimeFromHtml(item.body) : null;

// Video affordance: extract videoId at build time for the thumbnail + play glyph.
const videoId = item.kind === "video" ? extractYouTubeId(item.url) : null;
const thumbnailUrl = videoId ? buildYouTubeThumbnail(videoId) : null;
const isAudio = item.kind === "audio";
---

<article
  class="card paper"
  data-channels={item.topics.join(" ")}
  data-kind={item.kind}
  data-bento={size}
  data-item-id={item.id}
  data-reveal
  style={`--reveal-delay:${revealDelay}ms`}
>
  <div class="card-meta">
    <SourceBadge source={item.source} sourceType={item.sourceType} trustScore={item.trustScore} />
    <TimeAgo iso={item.publishedAt} now={now} />
  </div>

  {/* Video thumbnail with hairline frame + amber ▶ — only when we have a videoId */}
  {thumbnailUrl && (
    <a href={readHref} class="card-thumb-wrap" tabindex="-1" aria-hidden="true">
      <img
        class="card-thumb"
        src={thumbnailUrl}
        alt=""
        loading="lazy"
        decoding="async"
        width="480"
        height="270"
        onerror="this.parentElement.style.display='none'"
      />
      <span class="card-play" aria-hidden="true">▶</span>
    </a>
  )}

  {/* Audio glyph — headphone mark in mono/amber for podcast items */}
  {isAudio && !thumbnailUrl && (
    <span class="card-audio-mark" aria-label="podcast" title="audio / podcast">
      <svg class="card-audio-icon" viewBox="0 0 20 20" fill="none" aria-hidden="true" width="18" height="18">
        <path d="M10 2a7 7 0 0 0-7 7v3a2 2 0 0 0 2 2h1a1 1 0 0 0 1-1V9a1 1 0 0 0-1-1H4.07A6.002 6.002 0 0 1 16 9v4a1 1 0 0 0 1 1h1a2 2 0 0 0 2-2V9a7 7 0 0 0-7-7z" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </span>
  )}

  <h2 class="card-title">
    <!-- Primary target is the in-app reader; the ↗ source affordance below keeps
         a one-click jump to the original. -->
    <a href={readHref}>
      {item.title}
    </a>
  </h2>

  {item.summary && <p class="card-summary">{item.summary}</p>}

  <div class="card-foot">
    <span class="chips">
      {item.topics.slice(0, 4).map((c) => <ChannelChip channel={c} href={channelHref(c)} />)}
    </span>
    <span class="foot-end">
      {readMin !== null && (
        <span class="read-min tnum">{readMin} min</span>
      )}
      <!-- SEAM (P5B): beacon fires `open` on this outbound click via data-track. -->
      <a class="src-link" href={item.url} data-track="open" data-item-id={item.id} rel="noopener noreferrer" title="open the original source">↗ source</a>
      <Metric score={item.metrics?.score} comments={item.metrics?.comments} />
    </span>
  </div>
</article>

<style>
  .card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
    padding: var(--s-5) var(--s-4);
    border: var(--hair) solid var(--rule);
    border-radius: var(--r-md);
    /* glass surface: translucent panel + subtle lit top edge. Gated by --glass. */
    background: color-mix(in oklab, var(--glass-bg) calc(var(--glass) * 92%), transparent);
    box-shadow:
      inset 0 var(--hair) 0 color-mix(in oklab, var(--ink) calc(var(--glass) * 6%), transparent),
      0 1px 0 var(--rule);
    backdrop-filter: blur(calc(var(--glass) * 8px));
    /* spring lift on hover (overshoot) — transform/shadow only */
    transition:
      transform var(--dur) var(--ease-overshoot),
      border-color var(--dur) var(--ease-out),
      box-shadow var(--dur) var(--ease-out);
    will-change: transform;
    overflow: hidden;
  }
  /* hover: a thin amber accent grows in from the left edge (transform-scaleY,
     no layout shift). */
  .card::before {
    content: "";
    position: absolute;
    left: 0;
    top: var(--s-5);
    bottom: var(--s-5);
    width: 2px;
    background: var(--accent);
    transform: scaleY(0);
    transform-origin: top;
    transition: transform var(--dur) var(--ease-out);
  }
  /* specular sheen on hover — glass-gated */
  .card::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(
      105deg,
      transparent 30%,
      color-mix(in oklab, var(--accent) 18%, transparent) 48%,
      transparent 62%
    );
    opacity: calc(var(--glass) * 1);
    transform: translateX(-120%);
    transition: transform var(--dur-slow) var(--ease-out);
  }
  .card:hover::before {
    transform: scaleY(1);
  }
  .card:hover {
    transform: translateY(-4px) scale(1.015);
    border-color: color-mix(in oklab, var(--accent) 24%, var(--rule));
    /* a warm rim-light on the top edge (the instrument light catching the card)
       layered over the drop shadow — art-direction §4 */
    box-shadow:
      inset 0 1px 0 color-mix(in oklab, var(--accent) 28%, transparent),
      0 16px 40px -14px rgba(0, 0, 0, 0.5);
  }
  .card:hover::after {
    transform: translateX(120%);
  }
  /* tall cells get a touch more vertical breathing room for their content */
  .card[data-bento="tall"] {
    justify-content: flex-start;
  }
  @media (prefers-reduced-motion: reduce) {
    .card,
    .card::before,
    .card::after {
      transition: none;
    }
    .card:hover {
      transform: none;
    }
  }
  /* keep card content above the .paper grain (which sits at z-index:0) */
  .card-meta,
  .card-title,
  .card-summary,
  .card-foot {
    position: relative;
    z-index: 1;
  }
  .card-meta {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--s-3);
  }
  .card-title {
    margin: 0;
    font-family: var(--font-sans);
    font-size: var(--t-md);
    line-height: var(--lh-tight);
    font-weight: 540;
    letter-spacing: -0.01em;
  }
  /* wide + tall cells earn a larger, more editorial title */
  .card[data-bento="wide"] .card-title,
  .card[data-bento="tall"] .card-title {
    font-size: var(--t-lg);
  }
  .card-title a {
    color: var(--ink);
    /* amber underline draws in from the left on card hover (background-size,
       composited; no layout) */
    background-image: linear-gradient(var(--accent), var(--accent));
    background-size: 0% 1.5px;
    background-repeat: no-repeat;
    background-position: 0 1.1em;
    transition:
      color var(--dur-fast) var(--ease-out),
      background-size var(--dur) var(--ease-out);
  }
  .card:hover .card-title a {
    color: var(--accent);
    background-size: 100% 1.5px;
    text-decoration: none;
    text-shadow: 0 0 8px color-mix(in oklab, var(--accent) 35%, transparent);
  }
  .card-summary {
    margin: 0;
    color: var(--ink-dim);
    font-family: var(--font-read);
    font-size: var(--t-base);
    line-height: 1.5;
    max-width: 62ch;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--s-3);
    flex-wrap: wrap;
  }
  .chips {
    display: inline-flex;
    gap: var(--s-2);
    flex-wrap: wrap;
  }
  .foot-end {
    display: inline-flex;
    align-items: center;
    gap: var(--s-3);
  }
  /* the small secondary jump to the original — quiet until hovered */
  .src-link {
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    color: var(--ink-faint);
    white-space: nowrap;
    transition: color var(--dur-fast) var(--ease-out);
  }
  .src-link:hover {
    color: var(--accent);
    text-decoration: none;
  }
  /* reading-time — quiet mono telemetry in the foot, same weight as src-link */
  .read-min {
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    color: var(--ink-faint);
    white-space: nowrap;
  }

  /* ── video thumbnail + play facade ─────────────────────────────────── */
  .card-thumb-wrap {
    position: relative;
    display: block;
    overflow: hidden;
    border-radius: calc(var(--r-md) - 2px);
    border: var(--hair) solid var(--rule);
    /* aspect-ratio for the standard 16:9 YouTube hqdefault */
    aspect-ratio: 16 / 9;
    background: var(--bg-inset);
    flex-shrink: 0;
  }
  .card-thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    /* smooth reveal once the image loads */
    transition: transform var(--dur-slow) var(--ease-out), filter var(--dur) var(--ease-out);
  }
  .card:hover .card-thumb {
    transform: scale(1.03);
    filter: brightness(0.85);
  }
  /* amber ▶ centred over the thumbnail — appears on card hover */
  .card-play {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
    color: var(--accent);
    text-shadow: 0 0 12px color-mix(in oklab, var(--accent) 70%, transparent), 0 2px 8px rgba(0,0,0,0.6);
    opacity: 0;
    transition: opacity var(--dur-fast) var(--ease-out);
    pointer-events: none;
    /* backdrop so ▶ pops on any frame */
    background: radial-gradient(ellipse 50% 55% at 50% 50%, rgba(0,0,0,0.35), transparent);
  }
  .card:hover .card-play {
    opacity: 1;
  }
  /* always show a subtle ▶ indicator even without hover (touch) */
  .card-play::before {
    content: "";
    position: absolute;
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 50%;
    border: var(--hair) solid color-mix(in oklab, var(--accent) 40%, transparent);
    box-shadow: 0 0 14px -2px color-mix(in oklab, var(--accent) 45%, transparent);
    opacity: 0.55;
  }
  @media (prefers-reduced-motion: reduce) {
    .card-thumb, .card-play { transition: none; }
    .card:hover .card-thumb { transform: none; filter: none; }
  }

  /* ── audio / podcast glyph ──────────────────────────────────────────── */
  .card-audio-mark {
    display: inline-flex;
    align-items: center;
    gap: 0.5ch;
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    letter-spacing: 0.05em;
    opacity: 0.75;
    transition: opacity var(--dur-fast) var(--ease-out);
  }
  .card:hover .card-audio-mark {
    opacity: 1;
  }
  .card-audio-icon {
    flex-shrink: 0;
  }
</style>
