---
import type { FeedItem } from "@khazana/core";
import ChannelChip from "./ChannelChip.astro";
import SourceBadge from "./SourceBadge.astro";
import Metric from "./Metric.astro";
import TimeAgo from "./TimeAgo.astro";

interface Props {
  item: FeedItem;
  now: string;
}
const { item, now } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const channelHref = (c: string) => `${base}/?channel=${c}`;
---

<article class="card" data-channels={item.topics.join(" ")} data-kind={item.kind}>
  <div class="card-meta">
    <SourceBadge source={item.source} sourceType={item.sourceType} trustScore={item.trustScore} />
    <TimeAgo iso={item.publishedAt} now={now} />
  </div>

  <h2 class="card-title">
    <!-- SEAM (P5B): beacon fires `open` on this outbound click via data-track. -->
    <a href={item.url} data-track="open" data-item-id={item.id} rel="noopener noreferrer">
      {item.title}
    </a>
  </h2>

  {item.summary && <p class="card-summary">{item.summary}</p>}

  <div class="card-foot">
    <span class="chips">
      {item.topics.slice(0, 4).map((c) => <ChannelChip channel={c} href={channelHref(c)} />)}
    </span>
    <Metric score={item.metrics?.score} comments={item.metrics?.comments} />
  </div>
</article>

<style>
  .card {
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
    padding: var(--s-5) 0;
    border-bottom: var(--hair) solid var(--rule);
  }
  .card-meta {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--s-3);
  }
  .card-title {
    margin: 0;
    font-family: var(--font-sans);
    font-size: var(--t-md);
    line-height: var(--lh-tight);
    font-weight: 540;
    letter-spacing: -0.01em;
  }
  .card-title a {
    color: var(--ink);
  }
  .card-title a:hover {
    color: var(--accent);
    text-decoration: none;
    text-shadow: 0 0 8px color-mix(in oklab, var(--accent) 40%, transparent);
  }
  .card-summary {
    margin: 0;
    color: var(--ink-dim);
    font-family: var(--font-read);
    font-size: var(--t-base);
    line-height: 1.5;
    max-width: 62ch;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--s-3);
    flex-wrap: wrap;
  }
  .chips {
    display: inline-flex;
    gap: var(--s-2);
    flex-wrap: wrap;
  }
</style>
