---
import type { FeedItem } from "@khazana/core";
import ChannelChip from "./ChannelChip.astro";
import SourceBadge from "./SourceBadge.astro";
import Metric from "./Metric.astro";
import TimeAgo from "./TimeAgo.astro";
import type { BentoSize } from "../lib/bento.js";

interface Props {
  item: FeedItem;
  now: string;
  /** Scroll-reveal stagger delay in ms (capped by the caller). */
  revealDelay?: number;
  /** Bento cell size — drives the grid span (see index.astro grid CSS). */
  size?: BentoSize;
}
const { item, now, revealDelay = 0, size = "regular" } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const channelHref = (c: string) => `${base}/?channel=${c}`;
---

<article
  class="card"
  data-channels={item.topics.join(" ")}
  data-kind={item.kind}
  data-bento={size}
  data-reveal
  style={`--reveal-delay:${revealDelay}ms`}
>
  <div class="card-meta">
    <SourceBadge source={item.source} sourceType={item.sourceType} trustScore={item.trustScore} />
    <TimeAgo iso={item.publishedAt} now={now} />
  </div>

  <h2 class="card-title">
    <!-- SEAM (P5B): beacon fires `open` on this outbound click via data-track. -->
    <a href={item.url} data-track="open" data-item-id={item.id} rel="noopener noreferrer">
      {item.title}
    </a>
  </h2>

  {item.summary && <p class="card-summary">{item.summary}</p>}

  <div class="card-foot">
    <span class="chips">
      {item.topics.slice(0, 4).map((c) => <ChannelChip channel={c} href={channelHref(c)} />)}
    </span>
    <Metric score={item.metrics?.score} comments={item.metrics?.comments} />
  </div>
</article>

<style>
  .card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
    padding: var(--s-5) var(--s-4);
    border: var(--hair) solid var(--rule);
    border-radius: var(--r-md);
    /* glass surface: translucent panel + subtle lit top edge. Gated by --glass. */
    background: color-mix(in oklab, var(--glass-bg) calc(var(--glass) * 92%), transparent);
    box-shadow:
      inset 0 var(--hair) 0 color-mix(in oklab, var(--ink) calc(var(--glass) * 6%), transparent),
      0 1px 0 var(--rule);
    backdrop-filter: blur(calc(var(--glass) * 8px));
    /* spring lift on hover (overshoot) — transform/shadow only */
    transition:
      transform var(--dur) var(--ease-overshoot),
      border-color var(--dur) var(--ease-out),
      box-shadow var(--dur) var(--ease-out);
    will-change: transform;
    overflow: hidden;
  }
  /* hover: a thin amber accent grows in from the left edge (transform-scaleY,
     no layout shift). */
  .card::before {
    content: "";
    position: absolute;
    left: 0;
    top: var(--s-5);
    bottom: var(--s-5);
    width: 2px;
    background: var(--accent);
    transform: scaleY(0);
    transform-origin: top;
    transition: transform var(--dur) var(--ease-out);
  }
  /* specular sheen on hover — glass-gated */
  .card::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(
      105deg,
      transparent 30%,
      color-mix(in oklab, var(--accent) 18%, transparent) 48%,
      transparent 62%
    );
    opacity: calc(var(--glass) * 1);
    transform: translateX(-120%);
    transition: transform var(--dur-slow) var(--ease-out);
  }
  .card:hover::before {
    transform: scaleY(1);
  }
  .card:hover {
    transform: translateY(-4px);
    border-color: color-mix(in oklab, var(--accent) 24%, var(--rule));
    box-shadow: 0 16px 40px -14px rgba(0, 0, 0, 0.5);
  }
  .card:hover::after {
    transform: translateX(120%);
  }
  /* tall cells get a touch more vertical breathing room for their content */
  .card[data-bento="tall"] {
    justify-content: flex-start;
  }
  @media (prefers-reduced-motion: reduce) {
    .card,
    .card::before,
    .card::after {
      transition: none;
    }
    .card:hover {
      transform: none;
    }
  }
  .card-meta {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--s-3);
  }
  .card-title {
    margin: 0;
    font-family: var(--font-sans);
    font-size: var(--t-md);
    line-height: var(--lh-tight);
    font-weight: 540;
    letter-spacing: -0.01em;
  }
  /* wide + tall cells earn a larger, more editorial title */
  .card[data-bento="wide"] .card-title,
  .card[data-bento="tall"] .card-title {
    font-size: var(--t-lg);
  }
  .card-title a {
    color: var(--ink);
    /* amber underline draws in from the left on card hover (background-size,
       composited; no layout) */
    background-image: linear-gradient(var(--accent), var(--accent));
    background-size: 0% 1.5px;
    background-repeat: no-repeat;
    background-position: 0 1.1em;
    transition:
      color var(--dur-fast) var(--ease-out),
      background-size var(--dur) var(--ease-out);
  }
  .card:hover .card-title a {
    color: var(--accent);
    background-size: 100% 1.5px;
    text-decoration: none;
    text-shadow: 0 0 8px color-mix(in oklab, var(--accent) 35%, transparent);
  }
  .card-summary {
    margin: 0;
    color: var(--ink-dim);
    font-family: var(--font-read);
    font-size: var(--t-base);
    line-height: 1.5;
    max-width: 62ch;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--s-3);
    flex-wrap: wrap;
  }
  .chips {
    display: inline-flex;
    gap: var(--s-2);
    flex-wrap: wrap;
  }
</style>
