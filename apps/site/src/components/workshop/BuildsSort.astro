---
// The Workshop board's sort control — a small client-enhanced instrument
// button group, sibling to the maker-channel filter chips. Three keys
// (lib/sort-builds.ts): newest (SSR default), channel (the canonical
// WORKSHOP_BROWSE_CHANNELS sequence), and source (alphabetical). Mirrors
// reads/ReadsSort.astro's mechanism exactly — the two sort instruments feel
// like one coherent system rather than two libraries bolted together.
//
// Progressive enhancement: without JS the buttons are simply inert (type=
// "button", no form action) — the board already shows the maker-score-ranked
// SSR order. With JS, clicking a key reorders the rendered `.build` elements
// in place (no re-fetch, no re-render) via a FLIP pass — the same technique
// ReadsSort/ReadsFilter use for their reflow.
import { BUILD_SORT_KEYS, BUILD_SORT_DEFAULT, type BuildSortKey } from "./lib/sort-builds.js";

interface Props {
  channelOrder: readonly string[];
}
const { channelOrder } = Astro.props;

const LABELS: Record<BuildSortKey, string> = {
  newest: "newest",
  channel: "by channel",
  source: "by source",
};
---

<div class="wsort" data-ws-sort data-channel-order={channelOrder.join(",")}>
  <span class="wsort-label">sort /</span>
  <div class="wsort-chips" role="group" aria-label="Sort builds">
    {
      BUILD_SORT_KEYS.map((key) => (
        <button
          type="button"
          class="wsort-chip"
          class:list={{ "wsort-active": key === BUILD_SORT_DEFAULT }}
          data-sort={key}
          aria-pressed={key === BUILD_SORT_DEFAULT ? "true" : "false"}
        >
          {LABELS[key]}
        </button>
      ))
    }
  </div>
  <p class="wsort-status" data-ws-sort-status aria-live="polite"></p>
</div>

<script>
  import { compareBuilds, isBuildSortKey, BUILD_SORT_DEFAULT, type BuildSortKey } from "./lib/sort-builds.js";

  function initBuildsSort(): void {
    const root = document.querySelector<HTMLElement>("[data-ws-sort]");
    if (!root) return;
    if (root.dataset.sortReady === "1") return;
    root.dataset.sortReady = "1";

    const board = document.querySelector<HTMLElement>("[data-ws-board]");
    const status = root.querySelector<HTMLElement>("[data-ws-sort-status]");
    if (!board) return;

    const channelOrder = (root.dataset.channelOrder ?? "").split(",").filter(Boolean);
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    let active: BuildSortKey = BUILD_SORT_DEFAULT;

    function cardsOf(): HTMLElement[] {
      return Array.from(board!.querySelectorAll<HTMLElement>(".build"));
    }

    function sortableOf(card: HTMLElement) {
      return {
        id: card.dataset.buildId ?? "",
        source: card.dataset.source ?? "",
        channel: card.dataset.primaryChannel ?? "",
        publishedAt: card.dataset.published ?? "",
        el: card,
      };
    }

    function apply(key: BuildSortKey): void {
      const cards = cardsOf();
      const firstRects = new Map<HTMLElement, DOMRect>();
      if (!reduce) {
        for (const card of cards) firstRects.set(card, card.getBoundingClientRect());
      }

      const sorted = cards.map(sortableOf).sort((a, b) => compareBuilds(a, b, key, channelOrder));
      for (const { el } of sorted) board!.appendChild(el);
      // Ghost pin-slot fillers (sparse-board motif) aren't part of `sorted` —
      // re-append them after so they keep trailing the real builds instead of
      // drifting to the front of the board on every reorder.
      for (const filler of board!.querySelectorAll<HTMLElement>(".slot-filler")) {
        board!.appendChild(filler);
      }

      if (status) status.textContent = `Sorted by ${key === "channel" ? "maker channel" : key}.`;

      if (reduce) return;
      for (const card of cards) {
        if (card.hidden) continue;
        const last = card.getBoundingClientRect();
        const first = firstRects.get(card);
        if (!first) continue;
        const dx = first.left - last.left;
        const dy = first.top - last.top;
        if (dx === 0 && dy === 0) continue;
        card.animate(
          [{ transform: `translate(${dx}px, ${dy}px)` }, { transform: "translate(0, 0)" }],
          { duration: 320, easing: "cubic-bezier(0.2, 0.7, 0.2, 1)" },
        );
      }
    }

    root.addEventListener("click", (ev) => {
      const chip = (ev.target as HTMLElement | null)?.closest<HTMLButtonElement>("[data-sort]");
      if (!chip) return;
      const key = chip.dataset.sort ?? "";
      if (!isBuildSortKey(key) || key === active) return;
      active = key;

      root.querySelectorAll<HTMLButtonElement>("[data-sort]").forEach((c) => {
        const on = c.dataset.sort === key;
        c.classList.toggle("wsort-active", on);
        c.setAttribute("aria-pressed", on ? "true" : "false");
      });

      apply(key);
    });
  }

  initBuildsSort();
  document.addEventListener("astro:page-load", initBuildsSort);
</script>

<style>
  .wsort {
    display: flex;
    align-items: baseline;
    gap: var(--s-2) var(--s-3);
    flex: none;
    margin-left: auto;
  }
  .wsort-label {
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-faint);
  }
  .wsort-chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-2);
  }
  .wsort-chip {
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    color: var(--ink-dim);
    background: transparent;
    border: var(--hair) solid var(--rule);
    border-radius: var(--r-sm);
    padding: 0.22em 0.6em;
    letter-spacing: 0.02em;
    white-space: nowrap;
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out),
      background var(--dur-fast) var(--ease-out),
      transform var(--dur-fast) var(--ease-overshoot);
  }
  .wsort-chip:hover {
    color: var(--accent);
    border-color: var(--rule-bright);
    transform: translateY(-1px);
  }
  .wsort-chip:active {
    transform: translateY(0);
  }
  .wsort-chip:focus-visible {
    outline: 2px solid var(--focus);
    outline-offset: 2px;
  }
  .wsort-active {
    color: var(--accent);
    border-color: color-mix(in oklab, var(--accent) 38%, var(--rule));
    background: color-mix(in oklab, var(--accent) 8%, transparent);
    text-shadow: 0 0 8px color-mix(in oklab, var(--accent) 35%, transparent);
  }
  .wsort-status {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
  }

  @media (prefers-reduced-motion: reduce) {
    .wsort-chip {
      transition: color var(--dur-fast) var(--ease-out);
      transform: none !important;
    }
  }

  @media (max-width: 720px) {
    .wsort {
      margin-left: 0;
      flex-basis: 100%;
    }
  }
</style>
