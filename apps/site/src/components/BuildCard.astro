---
// A pinned BUILD card for the Workshop board. Deliberately distinct from the
// Feed's IdeaCard: it reads top-down like something tacked to a workbench
// pinboard — a pin head + tear line, the project title, then a maker's stat
// strip (source as credibility, maker channel, est. build time, a difficulty
// band DERIVED from read-time and labelled honestly). Same design tokens as the
// Feed (hairline rules, mono chrome, amber signal) so it belongs to khazana,
// but its own object identity.
import type { FeedItem } from "@khazana/core";
import ChannelChip from "./ChannelChip.astro";
import { readTimeFromHtml } from "../lib/read-time.js";

interface Props {
  item: FeedItem;
  /** Maker channels the board filters by — used to surface the item's primary one. */
  makerChannels: readonly string[];
  revealDelay?: number;
}
const { item, makerChannels, revealDelay = 0 } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const readHref = `${base}/item/${item.id}`;

// Est. build/read time from the rendered body (the same telemetry the Feed uses).
const minutes = item.body ? readTimeFromHtml(item.body) : null;

// Difficulty is a HONEST heuristic — a read-time BAND, nothing fabricated. Short
// reads tend to be quick mods; long deep-dives are involved projects. Labelled
// "est." in the UI so it never pretends to be a real parts/skill estimate.
function difficultyBand(min: number | null): { label: string; level: 1 | 2 | 3 } {
  if (min === null) return { label: "quick", level: 1 };
  if (min >= 18) return { label: "involved", level: 3 };
  if (min >= 9) return { label: "moderate", level: 2 };
  return { label: "quick", level: 1 };
}
const diff = difficultyBand(minutes);

// The item's primary MAKER channel (first maker tag, else first topic) — the
// board's filter pivots on `data-channels`, this just labels the card.
const makerSet = new Set(makerChannels);
const primaryMaker = item.topics.find((t) => makerSet.has(t)) ?? item.topics[0] ?? "build";

const image = item.media.find((m) => m.type === "image");
---

<article
  class="build"
  data-channels={item.topics.join(" ")}
  data-reveal
  style={`--reveal-delay:${revealDelay}ms`}
>
  {/* pin head + tear line — the "tacked to the board" affordance */}
  <span class="build-pin" aria-hidden="true"></span>

  {
    image && (
      <a class="build-shot" href={readHref} tabindex="-1" aria-hidden="true">
        <img src={image.url} alt="" loading="lazy" />
      </a>
    )
  }

  <div class="build-body">
    <p class="build-kicker">
      <span class="build-src" title={`source · ${item.source}`}>{item.source}</span>
      <ChannelChip channel={primaryMaker} />
    </p>

    <h2 class="build-title">
      <a href={readHref}>{item.title}</a>
    </h2>

    {item.summary && <p class="build-sum">{item.summary}</p>}

    <dl class="build-stats" aria-label="build telemetry">
      <div class="stat">
        <dt>est. build</dt>
        <dd>{minutes !== null ? `${minutes} min` : "—"}</dd>
      </div>
      <div class="stat">
        <dt>effort</dt>
        <dd class={`diff diff-${diff.level}`}>
          <span class="diff-bars" aria-hidden="true">
            <i class:list={[{ on: diff.level >= 1 }]}></i>
            <i class:list={[{ on: diff.level >= 2 }]}></i>
            <i class:list={[{ on: diff.level >= 3 }]}></i>
          </span>
          {diff.label}
        </dd>
      </div>
      <div class="stat stat-end">
        <a
          class="build-srclink"
          href={item.url}
          data-track="open"
          data-item-id={item.id}
          rel="noopener noreferrer"
          title="open the original source"
        >↗ source</a>
      </div>
    </dl>
  </div>
</article>

<style>
  .build {
    position: relative;
    break-inside: avoid;
    margin-bottom: var(--s-5);
    border: var(--hair) solid var(--rule);
    border-radius: var(--r-md);
    background: var(--bg-card);
    /* a hairline "tear" along the top edge — like card stock pinned to a board */
    box-shadow: inset 0 var(--hair) 0 color-mix(in oklab, var(--ink) 8%, transparent);
    overflow: hidden;
    transition:
      border-color var(--dur) var(--ease-out),
      transform var(--dur) var(--ease-out);
  }
  .build:hover {
    border-color: color-mix(in oklab, var(--accent) 30%, var(--rule));
    transform: translateY(-2px);
  }
  .build:active {
    transform: translateY(0);
  }

  /* the pin — an amber gem head tacking the card to the board */
  .build-pin {
    position: absolute;
    top: var(--s-3);
    right: var(--s-3);
    z-index: 3;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow:
      0 0 0 3px color-mix(in oklab, var(--accent) 16%, transparent),
      0 2px 4px rgba(0, 0, 0, 0.5),
      var(--halo-star, 0 0 8px color-mix(in oklab, var(--accent) 50%, transparent));
  }

  .build-shot {
    display: block;
    overflow: hidden;
  }
  .build-shot img {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    border-bottom: var(--hair) solid var(--rule);
    filter: saturate(0.92);
    transition: transform var(--dur-slow) var(--ease-out), filter var(--dur) var(--ease-out);
  }
  .build:hover .build-shot img {
    transform: scale(1.03);
    filter: saturate(1);
  }

  .build-body {
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
    padding: var(--s-4);
  }

  .build-kicker {
    display: flex;
    align-items: center;
    gap: var(--s-2);
    flex-wrap: wrap;
    margin: 0;
    /* leave room for the pin head */
    padding-right: var(--s-5);
  }
  .build-src {
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    letter-spacing: 0.04em;
    color: var(--accent);
    text-transform: uppercase;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 22ch;
  }

  .build-title {
    margin: 0;
    font-family: var(--font-sans);
    font-size: var(--t-base);
    line-height: var(--lh-tight);
    font-weight: 580;
    letter-spacing: -0.01em;
  }
  .build-title a {
    color: var(--ink);
  }
  .build-title a:hover {
    color: var(--accent);
    text-decoration: none;
  }

  .build-sum {
    margin: 0;
    font-family: var(--font-read);
    font-size: var(--t-sm);
    color: var(--ink-dim);
    line-height: 1.45;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* stat strip — workbench telemetry, hairline-ruled, mono */
  .build-stats {
    display: flex;
    align-items: center;
    gap: var(--s-4);
    margin: var(--s-1) 0 0;
    padding-top: var(--s-3);
    border-top: var(--hair) solid var(--rule);
    flex-wrap: wrap;
  }
  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.15em;
  }
  .stat-end {
    margin-left: auto;
    align-self: center;
  }
  .stat dt {
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }
  .stat dd {
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--t-sm);
    color: var(--ink-dim);
    font-variant-numeric: tabular-nums;
  }

  .diff {
    display: inline-flex;
    align-items: center;
    gap: 0.5ch;
    text-transform: lowercase;
  }
  .diff-bars {
    display: inline-flex;
    gap: 2px;
    align-items: flex-end;
  }
  .diff-bars i {
    width: 3px;
    height: 7px;
    border-radius: 1px;
    background: var(--rule-bright);
  }
  .diff-bars i.on {
    background: var(--accent);
  }
  .diff-1 { color: var(--good, var(--ink-dim)); }
  .diff-3 .diff-bars i.on { background: var(--editorial); }
  .diff-3 { color: color-mix(in oklab, var(--editorial) 75%, var(--ink-dim)); }

  .build-srclink {
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    color: var(--ink-faint);
    white-space: nowrap;
    transition: color var(--dur-fast) var(--ease-out);
  }
  .build-srclink:hover {
    color: var(--accent);
    text-decoration: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .build,
    .build-shot img {
      transition: none;
    }
    .build:hover {
      transform: none;
    }
    .build:hover .build-shot img {
      transform: none;
    }
  }
</style>
