---
// A pinned BUILD card for the Workshop board. Deliberately distinct from the
// Feed's IdeaCard: it reads top-down like something tacked to a workbench
// pinboard — a pin head + tear line, the project title, then a maker's stat
// strip (source as credibility, est. build time, a difficulty band DERIVED
// from read-time and labelled honestly). Same design tokens as the Feed
// (hairline rules, mono chrome, amber signal) so it belongs to khazana, but
// its own object identity.
//
// Per-maker-channel identity (level-up): `makerChannelStyle` — the ONE
// centralized map in workshop/lib/maker-channel-style.ts — tints the pin head
// and a left "spine" accent (mirroring ReadGalleryCard's format spine), plus a
// small mono ticker code, so an iot build and an ai-projects build read as
// visually distinct kinds of object at a glance, not just different chip text.
//
// Hover-preview (level-up): a CSS-ONLY reveal (no JS) — hovering OR focusing
// the card (:focus-within) expands a panel showing a genuine opening line of
// the item's real body (`excerptFromHtml`, grounded, never invented — distinct
// from the hand-tagged `summary` teaser already always visible). Keyboard
// users get the IDENTICAL reveal via focus, so it's never mouse-only.
import type { FeedItem } from "@khazana/core";
import { readTimeFromHtml } from "../lib/read-time.js";
import { makerChannelStyle, primaryMakerChannel } from "./workshop/lib/maker-channel-style.js";
import { excerptFromHtml } from "./workshop/lib/build-excerpt.js";

interface Props {
  item: FeedItem;
  revealDelay?: number;
}
const { item, revealDelay = 0 } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const readHref = `${base}/item/${item.id}`;

// Est. build/read time from the rendered body (the same telemetry the Feed uses).
const minutes = item.body ? readTimeFromHtml(item.body) : null;

// Difficulty is a HONEST heuristic — a read-time BAND, nothing fabricated. Short
// reads tend to be quick mods; long deep-dives are involved projects. Labelled
// "est." in the UI so it never pretends to be a real parts/skill estimate.
function difficultyBand(min: number | null): { label: string; level: 1 | 2 | 3 } {
  if (min === null) return { label: "quick", level: 1 };
  if (min >= 18) return { label: "involved", level: 3 };
  if (min >= 9) return { label: "moderate", level: 2 };
  return { label: "quick", level: 1 };
}
const diff = difficultyBand(minutes);

// The item's primary MAKER channel + its centralized identity (color + code).
const channel = primaryMakerChannel(item);
const chan = makerChannelStyle(channel);

// `publishedAt` is a required, validated ISO datetime on every FeedItem — the
// YYYY-MM-DD slice matches the exact convention build-reads.ts uses for reads.
const dateLabel = item.publishedAt.slice(0, 10);

// Honest, plain-language label for the item's `kind` — no invented taxonomy,
// just the canonical ITEM_KINDS vocabulary rendered for humans.
const KIND_LABEL: Record<string, string> = {
  link: "article",
  discussion: "thread",
  paper: "paper",
  idea: "idea",
  video: "video",
  audio: "audio",
};
const kindLabel = KIND_LABEL[item.kind] ?? item.kind;

// A real opening line of the actual source body — "" (and no reveal panel) when
// there's no body to draw from. Never a placeholder, never invented.
const excerpt = excerptFromHtml(item.body);

const image = item.media.find((m) => m.type === "image");
---

<article
  class="build"
  data-channels={item.topics.join(" ")}
  data-primary-channel={channel}
  data-source={item.source}
  data-published={item.publishedAt}
  data-build-id={item.id}
  data-reveal
  style={`--reveal-delay:${revealDelay}ms; --chan-accent:${chan.color};`}
>
  {/* pin head + tear line — the "tacked to the board" affordance, tinted by
      the build's maker channel so the pinboard itself carries the identity
      system, not just the metadata row below. */}
  <span class="build-pin" aria-hidden="true"></span>

  {
    image && (
      <a class="build-shot" href={readHref} tabindex="-1" aria-hidden="true">
        <img src={image.url} alt="" loading="lazy" />
      </a>
    )
  }

  <div class="build-body">
    <p class="build-kicker">
      <span class="build-code tnum" aria-hidden="true">{chan.code}</span>
      <span class="build-chan">{channel}</span>
      <span class="build-kind">{kindLabel}</span>
      <time class="build-date tnum" datetime={item.publishedAt}>{dateLabel}</time>
    </p>

    <h2 class="build-title">
      <a href={readHref}>{item.title}</a>
    </h2>

    {item.summary && <p class="build-sum">{item.summary}</p>}

    {
      excerpt && (
        <div class="build-preview" aria-hidden="true">
          <div class="build-preview-inner">
            <p class="build-excerpt">“{excerpt}”</p>
          </div>
        </div>
      )
    }

    <dl class="build-stats" aria-label="build telemetry">
      <div class="stat">
        <dt>est. build</dt>
        <dd>{minutes !== null ? `${minutes} min` : "—"}</dd>
      </div>
      <div class="stat">
        <dt>effort</dt>
        <dd class={`diff diff-${diff.level}`}>
          <span class="diff-bars" aria-hidden="true">
            <i class:list={[{ on: diff.level >= 1 }]}></i>
            <i class:list={[{ on: diff.level >= 2 }]}></i>
            <i class:list={[{ on: diff.level >= 3 }]}></i>
          </span>
          {diff.label}
        </dd>
      </div>
      <div class="stat stat-end">
        <dt>source</dt>
        <dd>
          <a
            class="build-srclink"
            href={item.url}
            data-track="open"
            data-item-id={item.id}
            rel="noopener noreferrer"
            title="open the original source"
          >{item.source} ↗</a>
        </dd>
      </div>
    </dl>
  </div>
</article>

<style>
  .build {
    position: relative;
    break-inside: avoid;
    margin-bottom: var(--s-5);
    border: var(--hair) solid var(--rule);
    border-radius: var(--r-md);
    background: var(--bg-card);
    /* a hairline "tear" along the top edge — like card stock pinned to a board */
    box-shadow: inset 0 var(--hair) 0 color-mix(in oklab, var(--ink) 8%, transparent);
    overflow: hidden;
    transition:
      border-color var(--dur) var(--ease-out),
      transform var(--dur) var(--ease-out);
  }
  .build:hover,
  .build:focus-within {
    border-color: color-mix(in oklab, var(--chan-accent) 30%, var(--rule));
    transform: translateY(-2px);
  }
  .build:active {
    transform: translateY(0);
  }

  /* the pin — a channel-tinted gem head tacking the card to the board. The
     outer glow deliberately stays the site's fixed amber halo-star (every pin
     catches the SAME overhead workbench light) while the pin body itself is
     tinted per maker channel — one shared light source, distinct objects. */
  .build-pin {
    position: absolute;
    top: var(--s-3);
    right: var(--s-3);
    z-index: 3;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--chan-accent);
    box-shadow:
      0 0 0 3px color-mix(in oklab, var(--chan-accent) 16%, transparent),
      0 2px 4px rgba(0, 0, 0, 0.5),
      var(--halo-star, 0 0 8px color-mix(in oklab, var(--chan-accent) 50%, transparent));
  }

  .build-shot {
    display: block;
    overflow: hidden;
  }
  .build-shot img {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    border-bottom: var(--hair) solid var(--rule);
    filter: saturate(0.92);
    transition: transform var(--dur-slow) var(--ease-out), filter var(--dur) var(--ease-out);
  }
  .build:hover .build-shot img {
    transform: scale(1.03);
    filter: saturate(1);
  }

  .build-body {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
    padding: var(--s-4) var(--s-4) var(--s-4) calc(var(--s-4) + 4px);
  }
  /* the maker-channel "spine" — a left edge accent in the channel's own color,
     faintly present at rest (so the channel reads as distinct even before any
     interaction) and full-strength on hover/focus — mirrors ReadGalleryCard's
     format spine so the two boards share one visual grammar. */
  .build-body::before {
    content: "";
    position: absolute;
    left: 0;
    top: var(--s-3);
    bottom: var(--s-3);
    width: 3px;
    border-radius: 0 2px 2px 0;
    background: var(--chan-accent);
    opacity: 0.42;
    transform: scaleY(0.8);
    transform-origin: center;
    transition:
      opacity var(--dur) var(--ease-out),
      transform var(--dur) var(--ease-out);
  }
  .build:hover .build-body::before,
  .build:focus-within .build-body::before {
    opacity: 1;
    transform: scaleY(1);
  }

  .build-kicker {
    display: flex;
    align-items: center;
    gap: var(--s-2);
    flex-wrap: wrap;
    margin: 0;
    /* leave room for the pin head */
    padding-right: var(--s-5);
  }
  .build-code {
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    letter-spacing: 0.1em;
    color: var(--chan-accent);
    opacity: 0.85;
  }
  .build-chan {
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    letter-spacing: 0.02em;
    text-transform: lowercase;
    color: var(--chan-accent);
    border: var(--hair) solid color-mix(in oklab, var(--chan-accent) 45%, var(--rule));
    border-radius: var(--r-sm);
    padding: 0.1em 0.45em;
    white-space: nowrap;
  }
  .build-kind {
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    letter-spacing: 0.02em;
    text-transform: lowercase;
    color: var(--ink-faint);
    white-space: nowrap;
  }
  .build-date {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    color: var(--ink-faint);
    white-space: nowrap;
  }

  .build-title {
    margin: 0;
    font-family: var(--font-sans);
    font-size: var(--t-base);
    line-height: var(--lh-tight);
    font-weight: 580;
    letter-spacing: -0.01em;
  }
  .build-title a {
    color: var(--ink);
  }
  .build-title a:hover {
    color: var(--chan-accent);
    text-decoration: none;
  }

  .build-sum {
    margin: 0;
    font-family: var(--font-read);
    font-size: var(--t-sm);
    color: var(--ink-dim);
    line-height: 1.45;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── hover-preview: CSS-only reveal, no JS ────────────────────────────────
     Same grid-rows 0fr→1fr trick as ReadGalleryCard: content stays in the DOM
     (screen readers always have it via the visible summary above) — only its
     visual presentation is gated behind :hover / :focus-within, so keyboard
     focus reveals it exactly like a mouse hover does. */
  .build-preview {
    display: grid;
    grid-template-rows: 0fr;
    transition:
      grid-template-rows var(--dur-slow) var(--ease-out),
      margin-block var(--dur-slow) var(--ease-out);
    margin-block: calc(var(--s-2) * -1);
  }
  .build:hover .build-preview,
  .build:focus-within .build-preview {
    grid-template-rows: 1fr;
    margin-block: 0;
  }
  .build-preview-inner {
    overflow: hidden;
  }
  .build-excerpt {
    margin: var(--s-2) 0 0;
    padding-left: var(--s-3);
    border-left: var(--hair) solid var(--chan-accent);
    font-family: var(--font-read);
    font-style: italic;
    color: var(--read);
    font-size: var(--t-xs);
    line-height: 1.5;
    opacity: 0;
    transform: translateY(-2px);
    transition:
      opacity var(--dur) var(--ease-out),
      transform var(--dur) var(--ease-out);
  }
  .build:hover .build-excerpt,
  .build:focus-within .build-excerpt {
    opacity: 1;
    transform: translateY(0);
  }

  /* stat strip — workbench telemetry, hairline-ruled, mono */
  .build-stats {
    display: flex;
    align-items: center;
    gap: var(--s-4);
    margin: var(--s-1) 0 0;
    padding-top: var(--s-3);
    border-top: var(--hair) solid var(--rule);
    flex-wrap: wrap;
  }
  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.15em;
    min-width: 0;
  }
  .stat-end {
    margin-left: auto;
    align-self: center;
    max-width: 22ch;
  }
  .stat dt {
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }
  .stat dd {
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--t-sm);
    color: var(--ink-dim);
    font-variant-numeric: tabular-nums;
  }
  .stat-end dd {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .diff {
    display: inline-flex;
    align-items: center;
    gap: 0.5ch;
    text-transform: lowercase;
  }
  .diff-bars {
    display: inline-flex;
    gap: 2px;
    align-items: flex-end;
  }
  .diff-bars i {
    width: 3px;
    height: 7px;
    border-radius: 1px;
    background: var(--rule-bright);
  }
  .diff-bars i.on {
    background: var(--accent);
  }
  .diff-1 { color: var(--good, var(--ink-dim)); }
  .diff-3 .diff-bars i.on { background: var(--editorial); }
  .diff-3 { color: color-mix(in oklab, var(--editorial) 75%, var(--ink-dim)); }

  .build-srclink {
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    color: var(--ink-faint);
    white-space: nowrap;
    transition: color var(--dur-fast) var(--ease-out);
  }
  .build-srclink:hover {
    color: var(--chan-accent);
    text-decoration: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .build,
    .build-shot img,
    .build-body::before,
    .build-preview,
    .build-excerpt {
      transition: none;
    }
    .build:hover,
    .build:focus-within {
      transform: none;
    }
    .build:hover .build-shot img {
      transform: none;
    }
  }
</style>
