---
import type { FeedItem } from "@khazana/core";
import ChannelChip from "./ChannelChip.astro";
import SourceBadge from "./SourceBadge.astro";
import Metric from "./Metric.astro";
import TimeAgo from "./TimeAgo.astro";
import { readTimeFromHtml } from "../lib/read-time.js";
import { extractYouTubeId, buildYouTubeThumbnail } from "../lib/media.js";

interface Props {
  item: FeedItem;
  now: string;
  revealDelay?: number;
}
const { item, now, revealDelay = 0 } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const channelHref = (c: string) => `${base}/?channel=${c}`;
const readHref = `${base}/item/${item.id}`;
// Only show reading time for items with real full-text body (on-khazana reads).
// Link-only items have no body — showing a fake time for those would mislead.
const readMin = item.body ? readTimeFromHtml(item.body) : null;

// Video affordance — feature card: thumbnail shown as a right-side panel on desktop
const videoId = item.kind === "video" ? extractYouTubeId(item.url) : null;
const thumbnailUrl = videoId ? buildYouTubeThumbnail(videoId) : null;
const isAudio = item.kind === "audio";
---

<article
  class="feature card"
  data-channels={item.topics.join(" ")}
  data-kind={item.kind}
  data-bento="feature"
  data-item-id={item.id}
  data-reveal
  style={`--reveal-delay:${revealDelay}ms`}
>
  <!-- amber progress hairline that traces the top edge on hover (scaleX) -->
  <span class="feature-trace" aria-hidden="true"></span>

  <div class={`feature-inner${thumbnailUrl ? " feature-has-thumb" : ""}`}>
    <div class="feature-content">
      <div class="feature-meta">
        <span class="feature-flag">lead</span>
        <SourceBadge source={item.source} sourceType={item.sourceType} trustScore={item.trustScore} />
        <TimeAgo iso={item.publishedAt} now={now} />
      </div>

      {/* Audio glyph in the lead meta row for podcast feature items */}
      {isAudio && (
        <span class="feature-audio-mark" aria-label="podcast" title="audio / podcast">
          <svg viewBox="0 0 20 20" fill="none" aria-hidden="true" width="16" height="16">
            <path d="M10 2a7 7 0 0 0-7 7v3a2 2 0 0 0 2 2h1a1 1 0 0 0 1-1V9a1 1 0 0 0-1-1H4.07A6.002 6.002 0 0 1 16 9v4a1 1 0 0 0 1 1h1a2 2 0 0 0 2-2V9a7 7 0 0 0-7-7z" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          podcast
        </span>
      )}

      <h2 class="feature-title display">
        <!-- Primary target is the in-app reader; ↗ source jumps to the original. -->
        <a href={readHref}>
          {item.title}
        </a>
      </h2>

      {item.summary && <p class="feature-summary">{item.summary}</p>}
    </div>

    {/* Video thumbnail panel — right side of the feature card on desktop */}
    {thumbnailUrl && (
      <a href={readHref} class="feature-thumb-wrap" tabindex="-1" aria-hidden="true">
        <img
          class="feature-thumb"
          src={thumbnailUrl}
          alt=""
          loading="lazy"
          decoding="async"
          width="480"
          height="270"
          onerror="this.closest('.feature-thumb-wrap').style.display='none'"
        />
        <span class="feature-play" aria-hidden="true">▶</span>
      </a>
    )}
  </div>

  <div class="feature-foot">
    <span class="chips">
      {item.topics.slice(0, 5).map((c) => <ChannelChip channel={c} href={channelHref(c)} />)}
    </span>
    <span class="foot-end">
      {readMin !== null && (
        <span class="read-min tnum">{readMin} min</span>
      )}
      <a class="src-link" href={item.url} data-track="open" data-item-id={item.id} rel="noopener noreferrer" title="open the original source">↗ source</a>
      <Metric score={item.metrics?.score} comments={item.metrics?.comments} />
    </span>
  </div>
</article>

<style>
  .feature {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--s-4);
    padding: var(--s-6);
    border: var(--hair) solid var(--rule);
    border-radius: var(--r-md);
    background: color-mix(in oklab, var(--bg-raised) 70%, transparent);
    box-shadow:
      inset 0 var(--hair) 0 color-mix(in oklab, var(--ink) calc(var(--glass) * 7%), transparent),
      0 1px 0 var(--rule);
    backdrop-filter: blur(calc(var(--glass) * 10px));
    overflow: hidden;
    /* spring lift on hover */
    transition:
      transform var(--dur) var(--ease-overshoot),
      border-color var(--dur) var(--ease-out),
      box-shadow var(--dur) var(--ease-out);
    will-change: transform;
  }
  /* a faint amber pool behind the title, top-left, for editorial weight */
  .feature::before {
    content: "";
    position: absolute;
    top: -30%;
    left: -10%;
    width: 60%;
    height: 80%;
    background: radial-gradient(
      closest-side,
      color-mix(in oklab, var(--accent) 10%, transparent),
      transparent
    );
    opacity: 0.7;
    pointer-events: none;
    transition: opacity var(--dur-slow) var(--ease-out);
  }
  .feature:hover {
    transform: translateY(-5px);
    border-color: color-mix(in oklab, var(--accent) 30%, var(--rule));
    /* the lead card is the brightest star — a warmer rim-light catches it */
    box-shadow:
      inset 0 1px 0 color-mix(in oklab, var(--accent) 34%, transparent),
      0 20px 50px -16px rgba(0, 0, 0, 0.55);
  }
  .feature:hover::before {
    opacity: 1;
  }
  .feature-trace {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--accent), var(--editorial));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--dur-slow) var(--ease-out);
  }
  .feature:hover .feature-trace {
    transform: scaleX(1);
  }

  /* feature-inner: flex row so thumbnail can sit right of content on wide screens */
  .feature-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: var(--s-4);
    flex: 1;
    min-width: 0;
  }
  .feature-has-thumb {
    flex-direction: row;
    align-items: flex-start;
    gap: var(--s-5);
  }
  .feature-content {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
  }
  /* On narrow screens, stack thumbnail below the text */
  @media (max-width: 700px) {
    .feature-has-thumb {
      flex-direction: column;
    }
  }

  /* feature content sits above the amber pool (::before) */
  .feature-meta,
  .feature-title,
  .feature-summary,
  .feature-foot {
    position: relative;
    z-index: 1;
  }
  .feature-meta {
    display: flex;
    align-items: baseline;
    gap: var(--s-3);
    flex-wrap: wrap;
  }
  .feature-flag {
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--bg);
    background: var(--accent);
    border-radius: var(--r-sm);
    padding: 0.1em 0.5em;
  }
  .feature-title {
    margin: 0;
    font-size: var(--t-display-sm);
    position: relative;
  }
  .feature-title a {
    color: var(--ink);
    background-image: linear-gradient(var(--accent), var(--accent));
    background-size: 0% 2px;
    background-repeat: no-repeat;
    background-position: 0 100%;
    transition:
      color var(--dur-fast) var(--ease-out),
      background-size var(--dur) var(--ease-out);
  }
  .feature:hover .feature-title a {
    color: var(--accent);
    background-size: 100% 2px;
    text-decoration: none;
  }
  .feature-summary {
    margin: 0;
    color: var(--ink-dim);
    font-family: var(--font-read);
    font-size: var(--t-md);
    line-height: 1.55;
    max-width: 54ch;
  }
  .feature-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--s-3);
    flex-wrap: wrap;
    margin-top: auto;
  }
  .chips {
    display: inline-flex;
    gap: var(--s-2);
    flex-wrap: wrap;
  }
  .foot-end {
    display: inline-flex;
    align-items: center;
    gap: var(--s-3);
  }
  .src-link {
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    color: var(--ink-faint);
    white-space: nowrap;
    transition: color var(--dur-fast) var(--ease-out);
  }
  .src-link:hover {
    color: var(--accent);
    text-decoration: none;
  }
  /* reading-time — quiet mono telemetry, consistent with other foot meta */
  .read-min {
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    color: var(--ink-faint);
    white-space: nowrap;
  }

  /* ── feature video thumbnail panel ─────────────────────────────────── */
  .feature-thumb-wrap {
    flex-shrink: 0;
    width: clamp(160px, 28%, 240px);
    position: relative;
    overflow: hidden;
    border-radius: calc(var(--r-md) - 2px);
    border: var(--hair) solid var(--rule);
    aspect-ratio: 16 / 9;
    align-self: flex-start;
    background: var(--bg-inset);
  }
  .feature-thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--dur-slow) var(--ease-out), filter var(--dur) var(--ease-out);
  }
  .feature:hover .feature-thumb {
    transform: scale(1.04);
    filter: brightness(0.8);
  }
  .feature-play {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
    color: var(--accent);
    text-shadow: 0 0 14px color-mix(in oklab, var(--accent) 70%, transparent), 0 2px 8px rgba(0,0,0,0.6);
    opacity: 0;
    transition: opacity var(--dur-fast) var(--ease-out);
    pointer-events: none;
    background: radial-gradient(ellipse 50% 55% at 50% 50%, rgba(0,0,0,0.35), transparent);
  }
  .feature:hover .feature-play {
    opacity: 1;
  }
  .feature-play::before {
    content: "";
    position: absolute;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    border: var(--hair) solid color-mix(in oklab, var(--accent) 40%, transparent);
    opacity: 0.55;
  }

  /* ── audio / podcast mark on feature card ───────────────────────────── */
  .feature-audio-mark {
    display: inline-flex;
    align-items: center;
    gap: 0.5ch;
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    letter-spacing: 0.05em;
    color: var(--accent);
    opacity: 0.75;
    transition: opacity var(--dur-fast) var(--ease-out);
  }
  .feature:hover .feature-audio-mark {
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .feature,
    .feature::before,
    .feature-trace,
    .feature-title a,
    .feature-thumb,
    .feature-play {
      transition: none;
    }
    .feature:hover .feature-thumb { transform: none; filter: none; }
  }
</style>
