---
import type { FeedItem } from "@khazana/core";

interface Props {
  item: FeedItem;
}
const { item } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const readHref = `${base}/item/${item.id}`;

// The pipeline carries no cover art for audio (media[] is empty), so every
// LISTEN card renders a typographic tile. If a future item DOES carry an image
// enclosure we use it; otherwise the designed tile stands on its own.
const cover = item.media.find((m) => m.type === "image")?.url ?? null;
// A large ghost glyph in the tile — the first letter of the show's MEANINGFUL
// name, in Fraunces. Many sources are prefixed "podcast-…", which would make
// every tile show the same "P"; strip that (and a leading article) so each tile
// gets a distinct character (odd-lots→O, latent-space→L, huberman-lab→H).
const showName = item.source
  .trim()
  .replace(/^(podcast|pod|the)\b[\s\-_·]*/i, "")
  .trim();
const initial = ((showName || item.source.trim())[0] ?? "◉").toUpperCase();
// FeedItem has no duration field → omit it gracefully.
---

<a class="lcard" href={readHref} data-channels={item.topics.join(" ")}>
  {cover ? (
    <span class="lcard-tile lcard-tile--cover">
      <img
        class="lcard-cover"
        src={cover}
        alt=""
        loading="lazy"
        decoding="async"
        width="320"
        height="320"
        onerror="this.classList.add('is-broken')"
      />
      <span class="lcard-mark" aria-hidden="true">◉</span>
    </span>
  ) : (
    <span class="lcard-tile" aria-hidden="true">
      <span class="lcard-ghost">{initial}</span>
      <span class="lcard-wave"></span>
      <span class="lcard-mark">◉</span>
      <span class="lcard-show">{item.source}</span>
    </span>
  )}
  <div class="lcard-body">
    <h3 class="lcard-title">{item.title}</h3>
    <span class="lcard-src">{item.source}</span>
  </div>
</a>

<style>
  .lcard {
    flex: 0 0 auto;
    width: clamp(180px, 20vw, 210px);
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
    color: inherit;
    text-decoration: none;
  }
  .lcard:hover {
    text-decoration: none;
  }

  /* ── the tile: a designed square, NOT a missing-image void ────────────── */
  .lcard-tile {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: var(--r-md);
    border: var(--hair) solid var(--rule);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: var(--s-3);
    /* clay-tinted warm ground — LISTEN owns the editorial accent, distinct from
       WATCH's amber, so the two rails read as different instruments. */
    background:
      radial-gradient(130% 100% at 22% 8%, color-mix(in oklab, var(--editorial) 13%, transparent), transparent 62%),
      linear-gradient(168deg, var(--bg-raised), var(--bg-card));
    transition:
      border-color var(--dur) var(--ease-out),
      box-shadow var(--dur) var(--ease-out),
      transform var(--dur) var(--ease-overshoot);
    will-change: transform;
  }
  .lcard:hover .lcard-tile {
    transform: translateY(-3px);
    border-color: color-mix(in oklab, var(--editorial) 42%, var(--rule));
    box-shadow:
      inset 0 1px 0 color-mix(in oklab, var(--editorial) 28%, transparent),
      0 16px 32px -16px rgba(0, 0, 0, 0.6);
  }

  /* huge ghosted Fraunces initial — the tile's character */
  .lcard-ghost {
    position: absolute;
    top: -0.18em;
    right: 0.02em;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 7.4rem;
    line-height: 1;
    color: color-mix(in oklab, var(--ink) 8%, transparent);
    font-variation-settings: "opsz" 144, "SOFT" 0, "WONK" 1;
    pointer-events: none;
    user-select: none;
  }
  /* a faint mono "waveform" rule — three stacked hairlines, the audio motif */
  .lcard-wave {
    position: absolute;
    left: var(--s-3);
    right: var(--s-3);
    top: 38%;
    height: 22px;
    pointer-events: none;
    opacity: 0.5;
    background-image: repeating-linear-gradient(
      90deg,
      color-mix(in oklab, var(--editorial) 40%, transparent) 0 2px,
      transparent 2px 7px
    );
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 18%, #000 82%, transparent);
    mask-image: linear-gradient(90deg, transparent, #000 18%, #000 82%, transparent);
  }
  .lcard-mark {
    position: relative;
    z-index: 1;
    font-family: var(--font-mono);
    font-size: 1rem;
    line-height: 1;
    color: var(--editorial);
    margin-bottom: var(--s-2);
    transition: text-shadow var(--dur) var(--ease-out);
  }
  .lcard:hover .lcard-mark {
    text-shadow: 0 0 14px color-mix(in oklab, var(--editorial) 60%, transparent);
  }
  .lcard-show {
    position: relative;
    z-index: 1;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--t-md);
    line-height: 1.08;
    letter-spacing: -0.012em;
    color: var(--ink);
    font-variation-settings: "opsz" 40, "SOFT" 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* cover-art variant (used only if an image enclosure ever appears) */
  .lcard-tile--cover {
    padding: 0;
  }
  .lcard-cover {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .lcard-cover.is-broken {
    display: none;
  }
  .lcard-tile--cover .lcard-mark {
    position: absolute;
    bottom: var(--s-3);
    left: var(--s-3);
    margin: 0;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.8);
  }

  /* ── caption below the tile ───────────────────────────────────────────── */
  .lcard-body {
    display: flex;
    flex-direction: column;
    gap: var(--s-1);
  }
  .lcard-title {
    margin: 0;
    font-family: var(--font-sans);
    font-size: var(--t-sm);
    line-height: var(--lh-tight);
    font-weight: 540;
    letter-spacing: -0.005em;
    color: var(--ink);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color var(--dur-fast) var(--ease-out);
  }
  .lcard:hover .lcard-title {
    color: var(--editorial);
  }
  .lcard-src {
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    color: var(--ink-faint);
    letter-spacing: 0.03em;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  @media (prefers-reduced-motion: reduce) {
    .lcard-tile,
    .lcard-mark {
      transition: none;
    }
    .lcard:hover .lcard-tile {
      transform: none;
    }
  }
</style>
