---
import Shell from "../layouts/Shell.astro";
import FeedCard from "../components/FeedCard.astro";
import FeatureCard from "../components/FeatureCard.astro";
import { loadCurated, tickerTitles } from "../lib/feed.js";
import { assignBento } from "../lib/bento.js";
import { CHANNELS } from "@khazana/core";
import { dataDir } from "../lib/data.js";

const now = new Date().toISOString();
const all = loadCurated(dataDir());
const ticker = tickerTitles(all, 8);
// live instrument readout: total signals + how many arrived in the last 24h
const nowMs = Date.parse(now);
const freshCount = all.filter((it) => nowMs - Date.parse(it.publishedAt) < 24 * 60 * 60 * 1000).length;
// SSR-safe: at static build time there is no request channel; the inline script
// applies the ?channel= filter on the client. We render ALL cards (tagged with
// data-channels) and let the script show/hide. Framework-free, static-host OK.
const cells = assignBento(all);
const channels = CHANNELS;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// Stagger: ~60ms per card, capped so the last card isn't held back too long.
const delay = (i: number) => Math.min(i, 8) * 60;
---

<Shell
  title="khazana — feed"
  active="feed"
  tickerTitles={ticker}
  signalCount={all.length}
  freshCount={freshCount}
>
  <!-- compact editorial masthead — no canvas, no WebGL -->
  <div class="masthead" data-reveal>
    <p class="mh-eyebrow">
      <span class="mh-dot" aria-hidden="true"></span>
      the observatory
    </p>
    <h1 class="mh-title display">first light<span class="mh-stop">.</span></h1>
    <p class="mh-sub reading">
      {all.length > 0 ? (
        <>{all.length} signals · <span class="mh-fresh">{freshCount} fresh</span> — the day's best catch, ranked by resonance.</>
      ) : (
        <>awaiting first light — the observatory is dark until the pipeline runs.</>
      )}
    </p>
  </div>

  {
    all.length > 0 ? (
      <>
        <header class="feed-head" data-reveal>
          <div class="filterbar" role="group" aria-label="Filter by channel">
            <div class="filters" id="filters">
              <span class="filter-indicator" aria-hidden="true" />
              <a class="filter is-active" href={`${base}/`} data-filter="">all</a>
              {channels.map((c) => (
                <a class="filter" href={`${base}/?channel=${c}`} data-filter={c}>
                  {c}
                </a>
              ))}
            </div>
          </div>
        </header>

        <section class="bento" aria-live="polite">
          {cells.map((cell) =>
            cell.size === "feature" ? (
              <FeatureCard item={cell.item} now={now} revealDelay={delay(cell.index)} />
            ) : (
              <FeedCard item={cell.item} now={now} size={cell.size} revealDelay={delay(cell.index)} />
            ),
          )}
          <p class="empty" hidden>
            No items in this channel yet.
          </p>
        </section>
      </>
    ) : (
      /* Honest empty state — no fake sample items. The feed populates from the
         pipeline; until then we say so plainly. */
      <section class="feed-empty" data-reveal>
        <p class="fe-eyebrow">no signal yet</p>
        <p class="fe-line">The feed updates from the pipeline.</p>
        <p class="fe-cmd">
          <code>khazana ingest &amp;&amp; khazana curate</code>
        </p>
        <p class="fe-note">
          Once a <code>data/feed/curated.json</code> lands, the day's best catch appears here —
          ranked, re-rendered, and readable in khazana's own study.
        </p>
      </section>
    )
  }
</Shell>

<style>
  /* ── compact masthead ─────────────────────────────────────────────── */
  .masthead {
    padding: var(--s-8) 0 var(--s-6);
    position: relative;
  }
  /* soft amber glow behind the title — CSS only, no canvas */
  .masthead::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 70% 60% at 30% 60%, color-mix(in oklab, var(--accent) 8%, transparent), transparent 70%);
    pointer-events: none;
    z-index: 0;
  }
  .mh-eyebrow {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 0.5ch;
    margin: 0 0 var(--s-3);
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    letter-spacing: 0.06em;
    text-transform: lowercase;
    color: var(--ink-faint);
  }
  .mh-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: var(--halo-star);
    animation: mh-pulse 2.6s ease-in-out infinite;
  }
  @keyframes mh-pulse {
    0%, 100% { opacity: 0.55; }
    50% { opacity: 1; }
  }
  .mh-title {
    position: relative;
    z-index: 1;
    margin: 0 0 var(--s-3);
    font-size: clamp(var(--t-xl), 5vw, var(--t-display));
    color: var(--ink);
    line-height: 0.95;
  }
  .mh-stop {
    color: var(--accent);
    text-shadow: var(--halo-display);
  }
  .mh-sub {
    position: relative;
    z-index: 1;
    margin: 0;
    color: var(--ink-dim);
    font-size: var(--t-sm);
    max-width: 52ch;
  }
  .mh-fresh {
    color: var(--accent);
  }
  @media (prefers-reduced-motion: reduce) {
    .mh-dot {
      animation: none;
      opacity: 1;
    }
  }

  /* the feed's controls sit just under the hero, as the instrument's tuning row.
     A hairline above ties the filter bar to the constellation it settled from. */
  .feed-head {
    margin-bottom: var(--s-6);
    padding-top: var(--s-2);
    border-top: var(--hair) solid var(--rule);
  }

  /* ── animated channel filter — sliding active pill ──────────────────── */
  .filterbar {
    position: relative;
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-mask-image: linear-gradient(90deg, #000 96%, transparent);
    mask-image: linear-gradient(90deg, #000 96%, transparent);
  }
  .filterbar::-webkit-scrollbar {
    display: none;
  }
  .filters {
    position: relative;
    display: flex;
    flex-wrap: nowrap;
    gap: var(--s-2);
    width: max-content;
  }
  /* the gliding pill behind the active filter (transform+width on a small
     element; positioned by the feed script). */
  .filter-indicator {
    position: absolute;
    left: 0;
    top: 0;
    height: 100%;
    width: 0;
    border-radius: var(--r-sm);
    background: var(--accent);
    box-shadow: 0 0 14px -2px color-mix(in oklab, var(--accent) 55%, transparent);
    transform: translateX(0);
    opacity: 0;
    pointer-events: none;
    transition:
      transform var(--dur) var(--ease-spring),
      width var(--dur) var(--ease-spring),
      opacity var(--dur-fast) var(--ease-out);
    z-index: 0;
  }
  .filter {
    position: relative;
    z-index: 1;
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    color: var(--ink-dim);
    border: var(--hair) solid var(--rule);
    border-radius: var(--r-sm);
    padding: 0.2em 0.6em;
    white-space: nowrap;
    transition:
      color var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out),
      transform var(--dur-fast) var(--ease-out);
  }
  .filter:hover {
    color: var(--accent);
    text-decoration: none;
    border-color: var(--rule-bright);
    transform: translateY(-1px);
  }
  .filter:active {
    transform: translateY(0);
  }
  .filter.is-active {
    color: var(--bg);
    border-color: var(--accent);
  }
  /* When the JS indicator is live, the active pill's own bg is redundant; keep
     the text contrast but let the gliding pill provide the fill. */
  .filters.has-indicator .filter.is-active {
    background: transparent;
  }
  .filters:not(.has-indicator) .filter.is-active {
    background: var(--accent);
  }
  @media (prefers-reduced-motion: reduce) {
    .filter-indicator {
      transition: none;
    }
  }

  /* ── bento mosaic ────────────────────────────────────────────────────
     Asymmetric grid: a 4-col base on desktop with dense auto-flow so hidden
     (filtered-out) cards re-pack cleanly. Feature spans the full lead row;
     wide spans 2 cols; tall spans 2 rows. Collapses to 1 col on phones. */
  .bento {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: minmax(168px, auto);
    grid-auto-flow: row dense;
    gap: var(--s-4);
  }
  .bento :global([data-bento="feature"]) {
    grid-column: span 4;
    grid-row: span 1;
  }
  .bento :global([data-bento="wide"]) {
    grid-column: span 2;
  }
  .bento :global([data-bento="tall"]) {
    grid-row: span 2;
  }
  .bento :global([data-bento="regular"]) {
    grid-column: span 2;
  }

  /* tablet: 2-col mosaic */
  @media (max-width: 900px) {
    .bento {
      grid-template-columns: repeat(2, 1fr);
    }
    .bento :global([data-bento="feature"]),
    .bento :global([data-bento="wide"]),
    .bento :global([data-bento="regular"]) {
      grid-column: span 2;
    }
    .bento :global([data-bento="tall"]) {
      grid-row: span 1;
    }
  }
  /* phone: single column, even rhythm, fully scannable */
  @media (max-width: 600px) {
    .bento {
      grid-template-columns: 1fr;
      grid-auto-rows: auto;
    }
    .bento :global([data-bento]) {
      grid-column: span 1 !important;
      grid-row: span 1 !important;
    }
  }

  .empty {
    grid-column: 1 / -1;
    padding: var(--s-8) 0;
    color: var(--ink-faint);
    font-family: var(--font-mono);
    text-align: center;
  }

  /* ── honest empty state (no curated.json) ────────────────────────────── */
  .feed-empty {
    margin-top: var(--s-6);
    padding: var(--s-8) var(--s-6);
    border: var(--hair) solid var(--rule);
    border-radius: var(--r-md);
    background:
      radial-gradient(120% 100% at 20% 0%, color-mix(in oklab, var(--accent) 5%, transparent), transparent 60%),
      var(--bg-card);
    max-width: var(--measure);
  }
  .fe-eyebrow {
    margin: 0 0 var(--s-3);
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .fe-line {
    margin: 0 0 var(--s-4);
    font-family: var(--font-read);
    font-size: var(--t-lg);
    color: var(--ink);
  }
  .fe-cmd {
    margin: 0 0 var(--s-5);
  }
  .fe-cmd code,
  .fe-note code {
    font-family: var(--font-mono);
    font-size: var(--t-sm);
    background: var(--bg-inset);
    border: var(--hair) solid var(--rule);
    border-radius: var(--r-sm);
    padding: 0.2em 0.5em;
    color: var(--ink-dim);
  }
  .fe-note {
    margin: 0;
    font-family: var(--font-read);
    font-size: var(--t-base);
    line-height: 1.55;
    color: var(--ink-dim);
    max-width: 52ch;
  }
</style>

<script>
  // Framework-free channel filter + sliding active pill. Progressive
  // enhancement: with JS off, all cards show and each filter is a real href.
  // The mosaic's `grid-auto-flow: dense` re-packs around hidden cards.
  const params = new URLSearchParams(location.search);
  const active = params.get("channel") ?? "";

  function applyFilter() {
    const cards = document.querySelectorAll<HTMLElement>(".bento [data-channels]");
    const empty = document.querySelector<HTMLElement>(".bento .empty");
    let shown = 0;
    cards.forEach((card) => {
      const channels = (card.dataset.channels ?? "").split(" ");
      const match = active === "" || channels.includes(active);
      card.hidden = !match;
      if (match) shown++;
    });
    if (empty) empty.hidden = shown !== 0;

    document.querySelectorAll<HTMLElement>(".filter").forEach((el) => {
      el.classList.toggle("is-active", (el.dataset.filter ?? "") === active);
    });
  }

  // Slide the indicator pill under the active filter (transform + width only).
  function positionIndicator() {
    const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;
    const filters = document.querySelector<HTMLElement>("#filters");
    const indicator = document.querySelector<HTMLElement>(".filter-indicator");
    const activeEl = document.querySelector<HTMLElement>(".filter.is-active");
    if (!filters || !indicator || !activeEl) return;
    filters.classList.add("has-indicator");
    const frect = filters.getBoundingClientRect();
    const arect = activeEl.getBoundingClientRect();
    indicator.style.opacity = "1";
    indicator.style.width = `${arect.width}px`;
    indicator.style.transform = `translateX(${arect.left - frect.left}px)`;
    if (reduce) indicator.style.transitionDuration = "0ms";
  }

  function init() {
    applyFilter();
    positionIndicator();
  }

  init();
  // Re-measure after fonts settle (pill widths shift) and on resize.
  if ("fonts" in document) document.fonts.ready.then(positionIndicator).catch(() => {});
  window.addEventListener("resize", positionIndicator);
  // Re-run after View Transition navigations (e.g. clicking a channel filter).
  document.addEventListener("astro:page-load", init);
</script>
