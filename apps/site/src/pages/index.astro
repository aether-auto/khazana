---
import Shell from "../layouts/Shell.astro";
import FeedCard from "../components/FeedCard.astro";
import FeatureCard from "../components/FeatureCard.astro";
import MediaRail from "../components/MediaRail.astro";
import WatchCard from "../components/WatchCard.astro";
import ListenCard from "../components/ListenCard.astro";
import CategoryRail from "../components/CategoryRail.astro";
import {
  loadCurated,
  tickerTitles,
  splitFeaturedGated,
  dropShorts,
  dropJunkVideos,
  selectWatchRail,
  selectListenRail,
  bucketByChannel,
  dropBelowFeedFloor,
  CATEGORY_MIN_MINUTES,
} from "../lib/feed.js";
import { assignBento } from "../lib/bento.js";
import { CHANNELS } from "@khazana/core";
import { dataDir } from "../lib/data.js";
import { readTimeFromHtml } from "../lib/read-time.js";
import { extractYouTubeId, buildYouTubeThumbnail } from "../lib/media.js";

const now = new Date().toISOString();
// Content-quality gate applied ONCE on the full list so EVERY downstream surface
// — bento, rails, register — sees a clean feed: drop YouTube Shorts and obvious
// non-content raw video clips (MIT-OCW lab footage etc.). Neither is "best signal."
// `dropBelowFeedFloor` then enforces the SACRED ≥5-min Feed floor: curate now keeps
// short (3–5 min) maker tutorials in curated.json for the Workshop, and this guard
// stops them leaking into the Feed (the register/firehose has no floor of its own).
// No-body bare links are kept, exactly as before.
const all = dropBelowFeedFloor(dropJunkVideos(dropShorts(loadCurated(dataDir()))));
const ticker = tickerTitles(all, 8);
// Live instrument readout: total signals + how many arrived in the last 24h
const nowMs = Date.parse(now);
const freshCount = all.filter((it) => nowMs - Date.parse(it.publishedAt) < 24 * 60 * 60 * 1000).length;

// THE SHOWCASE vs THE TAIL.
// curated.json is rank-ordered (best first), so the FEATURED set is just the
// top qualifying slice — the freshest, highest-resonance SUBSTANTIVE catch.
// Gate is content-agnostic: any item (article, video transcript, podcast
// transcript) whose RENDERED body clocks ≥ 7 min qualifies.
// Expanded from 10 → 30 for the redesigned bento (richer browsable area).
// Structure preserved for future personalization: ordering is pure score-rank
// today; a personalization layer can slot into the ordering without API changes.
const { featured, rest } = splitFeaturedGated(all, 30);
const cells = assignBento(featured);

// Category browse: bucket the rest by primary topic, filter to channels with
// enough substantial (≥5-min) items to warrant a rail.
const CATEGORY_MIN_ITEMS = 3;
const allBuckets = bucketByChannel(rest);
// Category channels in display order — match CHANNELS canonical order.
const categoryRails = CHANNELS.flatMap((ch) => {
  const bucket = allBuckets.get(ch);
  if (!bucket) return [];
  const substantial = bucket.filter((it) => it.body && readTimeFromHtml(it.body) >= CATEGORY_MIN_MINUTES);
  if (substantial.length < CATEGORY_MIN_ITEMS) return [];
  return [{ channel: ch, items: substantial }];
});

// Media rails draw from `rest` — the top-ranked video/audio that didn't clear
// the 7-min featured gate. Shorts are already gone (dropShorts).
const watchItems = selectWatchRail(rest, 12);
const listenItems = selectListenRail(rest, 10);

// The tail ships as a single JSON payload (text, not DOM) — the register script
// builds compact rows/cards from it in small batches. Trim to just the fields
// the register needs (smaller payload, no body/media blobs). readMinutes is
// pre-computed here at build time so the client never sees raw body HTML.
const registerData = rest.map((it) => {
  // Derive YouTube videoId at build time from the canonical URL so the client
  // never needs to parse URLs or make API calls. Only set for video kind.
  const videoId = it.kind === "video" ? extractYouTubeId(it.url) : null;
  return {
    id: it.id,
    title: it.title,
    summary: it.summary ?? "",
    url: it.url,
    source: it.source,
    sourceType: it.sourceType,
    kind: it.kind,
    trustScore: it.trustScore,
    publishedAt: it.publishedAt,
    topics: it.topics,
    score: it.metrics?.score,
    comments: it.metrics?.comments,
    // Only include readMinutes for full-text items (body present); null means link-only.
    readMinutes: it.body ? readTimeFromHtml(it.body) : null,
    // Video affordance: pre-computed at build time, null for non-video items.
    videoId: videoId ?? null,
    thumbnailUrl: videoId ? buildYouTubeThumbnail(videoId) : null,
  };
});
// A small no-JS fallback so the tail isn't blank without the register script.
const fallback = rest.slice(0, 20);

// Channel filter — initial state read from URL at SSR time
const urlParams = new URLSearchParams(Astro.url.search);
const activeChannel = urlParams.get("channel") ?? "";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
// Default register view — LIST. Densest, fastest-scanning.
const defaultView = "list";

// Stagger: ~60ms per card, capped so the last card isn't held back too long.
const delay = (i: number) => Math.min(i, 8) * 60;
---

<Shell
  title="khazana — feed"
  active="feed"
  tickerTitles={ticker}
  signalCount={all.length}
  freshCount={freshCount}
  feedPage={true}
  activeChannel={activeChannel}
>
  <!-- compact editorial masthead — no canvas, no WebGL -->
  <div class="masthead" data-reveal>
    <p class="mh-eyebrow">
      <span class="mh-dot" aria-hidden="true"></span>
      the observatory
    </p>
    <h1 class="mh-title display">first light<span class="mh-stop">.</span></h1>
    <p class="mh-sub reading">
      {all.length > 0 ? (
        <>{all.length} signals · <span class="mh-fresh">{freshCount} fresh</span> — the day's best catch, ranked by resonance.</>
      ) : (
        <>awaiting first light — the observatory is dark until the pipeline runs.</>
      )}
    </p>
  </div>

  {
    all.length > 0 ? (
      <>
        <!-- Bento: top 30 featured reads — rich, browsable, intentional structure.
             Hero lead (1 full-width feature) + varied mosaic grid beneath.
             Filtering is driven by the header chips via khz:channelchange. -->
        <section class="bento" aria-label="Featured signals" aria-live="polite" data-section="bento">
          {cells.map((cell) =>
            cell.size === "feature" ? (
              <FeatureCard item={cell.item} now={now} revealDelay={delay(cell.index)} />
            ) : (
              <FeedCard item={cell.item} now={now} size={cell.size} revealDelay={delay(cell.index)} />
            ),
          )}
          <p class="bento-empty" hidden>
            No featured items in this channel.
          </p>
        </section>

        {watchItems.length > 0 && (
          <div data-section="watch" data-section-all-channels="video">
            <MediaRail
              glyph="▶"
              label="watch"
              count={watchItems.length}
              blurb="long-form video from the channels worth watching — re-read as transcript on khazana, or play in place."
              accent="signal"
            >
              {watchItems.map((it) => (
                <WatchCard item={it} />
              ))}
            </MediaRail>
          </div>
        )}

        {listenItems.length > 0 && (
          <div data-section="listen" data-section-all-channels="audio">
            <MediaRail
              glyph="◉"
              label="listen"
              count={listenItems.length}
              blurb="the day's best long-form audio — podcasts and talks, with their transcripts re-set in khazana's study."
              accent="editorial"
            >
              {listenItems.map((it) => (
                <ListenCard item={it} />
              ))}
            </MediaRail>
          </div>
        )}

        <!-- Browse by category: per-channel horizontal rails.
             Only channels with ≥3 substantial (≥5-min) reads get a row.
             Filtering collapses rows whose channel doesn't match. -->
        {categoryRails.length > 0 && (
          <div class="browse" data-reveal data-section="browse">
            <div class="browse-head">
              <span class="browse-rule" aria-hidden="true"></span>
              <p class="browse-eyebrow">browse by topic</p>
            </div>
            {categoryRails.map(({ channel, items }) => (
              <CategoryRail channel={channel} items={items} now={now} />
            ))}
            <p class="browse-empty" hidden>
              No category rows for this channel.
            </p>
          </div>
        )}

        {
          rest.length > 0 && (
            <section
              class="register"
              data-register
              data-base={base}
              data-default-view={defaultView}
              aria-label="The register"
            >
              <div class="reg-head" data-reveal>
                <div class="reg-head-left">
                  <p class="reg-eyebrow">
                    <span class="reg-rule" aria-hidden="true" />
                    the register
                  </p>
                  <p class="reg-sub reading">
                    the rest of the catch — <span data-register-count>{`0 of ${rest.length}`}</span>
                  </p>
                </div>
                {/* card / list toggle — persisted in localStorage by the register script */}
                <div class="view-toggle" data-view-toggle role="group" aria-label="View mode">
                  <button type="button" class="vt-btn" data-view="list" aria-pressed="true" title="List view">
                    <span class="vt-icon" aria-hidden="true">≣</span>
                    <span class="vt-label">list</span>
                  </button>
                  <button type="button" class="vt-btn" data-view="card" aria-pressed="false" title="Card view">
                    <span class="vt-icon" aria-hidden="true">▦</span>
                    <span class="vt-label">cards</span>
                  </button>
                </div>
              </div>

              {/* live list — the register script fills + repaints this on view/filter change */}
              <div class="reg-list" data-register-list data-view={defaultView} />

              <p class="reg-empty" data-register-empty hidden>
                No further signals in this channel.
              </p>

              <div class="reg-more-wrap">
                <button type="button" class="reg-more" data-register-more>
                  load more
                </button>
              </div>

              {/* no-JS fallback: a small plain list so the tail is never blank */}
              <noscript>
                <ul class="reg-noscript">
                  {fallback.map((it) => (
                    <li>
                      <a href={`${base}/item/${it.id}`}>{it.title}</a>{" "}
                      <span class="reg-ns-src">{it.source}</span>
                    </li>
                  ))}
                </ul>
              </noscript>

              {/* tail data payload (text, not DOM) — parsed by the register script */}
              <script
                type="application/json"
                id="register-data"
                set:html={JSON.stringify(registerData)}
              />
            </section>
          )
        }
      </>
    ) : (
      /* Honest empty state — no fake sample items. The feed populates from the
         pipeline; until then we say so plainly. */
      <section class="feed-empty" data-reveal>
        <p class="fe-eyebrow">no signal yet</p>
        <p class="fe-line">The feed updates from the pipeline.</p>
        <p class="fe-cmd">
          <code>khazana ingest &amp;&amp; khazana curate</code>
        </p>
        <p class="fe-note">
          Once a <code>data/feed/curated.json</code> lands, the day's best catch appears here —
          ranked, re-rendered, and readable in khazana's own study.
        </p>
      </section>
    )
  }
</Shell>

<style>
  /* ── compact masthead ─────────────────────────────────────────────── */
  .masthead {
    padding: var(--s-8) 0 var(--s-6);
    position: relative;
  }
  /* soft amber glow behind the title — CSS only, no canvas */
  .masthead::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 70% 60% at 30% 60%, color-mix(in oklab, var(--accent) 8%, transparent), transparent 70%);
    pointer-events: none;
    z-index: 0;
  }
  .mh-eyebrow {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 0.5ch;
    margin: 0 0 var(--s-3);
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    letter-spacing: 0.06em;
    text-transform: lowercase;
    color: var(--ink-faint);
  }
  .mh-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: var(--halo-star);
    animation: mh-pulse 2.6s ease-in-out infinite;
  }
  @keyframes mh-pulse {
    0%, 100% { opacity: 0.55; }
    50% { opacity: 1; }
  }
  .mh-title {
    position: relative;
    z-index: 1;
    margin: 0 0 var(--s-3);
    font-size: clamp(var(--t-xl), 5vw, var(--t-display));
    color: var(--ink);
    line-height: 0.95;
    overflow-wrap: normal;
    word-break: normal;
    hyphens: none;
  }
  .mh-stop {
    color: var(--accent);
    text-shadow: var(--halo-display);
  }
  .mh-sub {
    position: relative;
    z-index: 1;
    margin: 0;
    color: var(--ink-dim);
    font-size: var(--t-sm);
    max-width: 52ch;
  }
  .mh-fresh {
    color: var(--accent);
  }
  @media (prefers-reduced-motion: reduce) {
    .mh-dot {
      animation: none;
      opacity: 1;
    }
  }

  /* Hidden bento cards must collapse out of the grid (they have display:flex
     which overrides the browser default for [hidden]). grid-auto-flow: dense
     then re-packs the remaining visible cards cleanly. */
  .bento :global([data-bento][hidden]) {
    display: none !important;
  }
  /* Hidden category rows similarly collapse */
  :global([data-catrow][hidden]) {
    display: none !important;
  }

  /* ── bento mosaic ────────────────────────────────────────────────────
     Asymmetric grid: a 4-col base on desktop with dense auto-flow so hidden
     (filtered-out) cards re-pack cleanly. Feature spans the full lead row;
     wide spans 2 cols; tall spans 2 rows. Collapses to 1 col on phones.
     With 30 items, the grid becomes a rich browsable featured area — a
     curated library section, not just a wall. */
  .bento {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: minmax(168px, auto);
    grid-auto-flow: row dense;
    gap: var(--s-4);
    margin-top: var(--s-2);
  }
  .bento :global([data-bento="feature"]) {
    grid-column: span 4;
    grid-row: span 1;
  }
  .bento :global([data-bento="wide"]) {
    grid-column: span 2;
  }
  .bento :global([data-bento="tall"]) {
    grid-row: span 2;
  }
  .bento :global([data-bento="regular"]) {
    grid-column: span 2;
  }

  /* tablet: 2-col mosaic */
  @media (max-width: 900px) {
    .bento {
      grid-template-columns: repeat(2, 1fr);
    }
    .bento :global([data-bento="feature"]),
    .bento :global([data-bento="wide"]),
    .bento :global([data-bento="regular"]) {
      grid-column: span 2;
    }
    .bento :global([data-bento="tall"]) {
      grid-row: span 1;
    }
  }
  /* phone: single column, even rhythm, fully scannable */
  @media (max-width: 600px) {
    .bento {
      grid-template-columns: 1fr;
      grid-auto-rows: auto;
    }
    .bento :global([data-bento]) {
      grid-column: span 1 !important;
      grid-row: span 1 !important;
    }
  }

  .bento-empty {
    grid-column: 1 / -1;
    padding: var(--s-8) 0;
    color: var(--ink-faint);
    font-family: var(--font-mono);
    text-align: center;
  }

  /* ── Browse by topic section ───────────────────────────────────────── */
  .browse {
    margin-top: var(--s-10);
  }
  .browse-head {
    display: flex;
    align-items: center;
    gap: var(--s-3);
    padding-top: var(--s-3);
    border-top: var(--hair) solid var(--rule);
    margin-bottom: var(--s-2);
  }
  .browse-rule {
    display: inline-block;
    width: 1.6em;
    height: 1px;
    background: var(--editorial);
    opacity: 0.65;
    flex-shrink: 0;
  }
  .browse-eyebrow {
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    letter-spacing: 0.08em;
    text-transform: lowercase;
    color: var(--ink-faint);
  }
  .browse-empty {
    margin-top: var(--s-6);
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    color: var(--ink-faint);
    text-align: center;
  }

  /* ── honest empty state (no curated.json) ────────────────────────────── */
  .feed-empty {
    margin-top: var(--s-6);
    padding: var(--s-8) var(--s-6);
    border: var(--hair) solid var(--rule);
    border-radius: var(--r-md);
    background:
      radial-gradient(120% 100% at 20% 0%, color-mix(in oklab, var(--accent) 5%, transparent), transparent 60%),
      var(--bg-card);
    max-width: var(--measure);
  }
  .fe-eyebrow {
    margin: 0 0 var(--s-3);
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .fe-line {
    margin: 0 0 var(--s-4);
    font-family: var(--font-read);
    font-size: var(--t-lg);
    color: var(--ink);
  }
  .fe-cmd {
    margin: 0 0 var(--s-5);
  }
  .fe-cmd code,
  .fe-note code {
    font-family: var(--font-mono);
    font-size: var(--t-sm);
    background: var(--bg-inset);
    border: var(--hair) solid var(--rule);
    border-radius: var(--r-sm);
    padding: 0.2em 0.5em;
    color: var(--ink-dim);
  }
  .fe-note {
    margin: 0;
    font-family: var(--font-read);
    font-size: var(--t-base);
    line-height: 1.55;
    color: var(--ink-dim);
    max-width: 52ch;
  }

  /* ── THE REGISTER — the long tail, cheap + paginated ──────────────────────
     Deliberately glassless: NO backdrop-filter, NO per-node scroll-reveal. Just
     hairline-ruled rows / flat cards. This is the instrument's telemetry log
     under the showcase, built to stay fast at hundreds of items. */
  .register {
    margin-top: var(--s-10);
  }
  .reg-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--s-4);
    flex-wrap: wrap;
    margin-bottom: var(--s-5);
    padding-top: var(--s-3);
    border-top: var(--hair) solid var(--rule);
  }
  .reg-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.6ch;
    margin: var(--s-3) 0 var(--s-2);
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    letter-spacing: 0.08em;
    text-transform: lowercase;
    color: var(--ink-faint);
  }
  .reg-rule {
    display: inline-block;
    width: 1.6em;
    height: 1px;
    background: var(--accent);
    opacity: 0.7;
  }
  .reg-sub {
    margin: 0;
    font-size: var(--t-sm);
    color: var(--ink-dim);
  }
  .reg-sub [data-register-count] {
    font-family: var(--font-mono);
    color: var(--accent);
  }

  /* card / list toggle — a small machined segmented control */
  .view-toggle {
    display: inline-flex;
    gap: 2px;
    padding: 2px;
    border: var(--hair) solid var(--rule);
    border-radius: var(--r-md);
    background: var(--bg-card);
  }
  .vt-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5ch;
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    color: var(--ink-dim);
    background: transparent;
    border: 0;
    border-radius: var(--r-sm);
    padding: 0.3em 0.7em;
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease-out),
      background var(--dur-fast) var(--ease-out);
  }
  .vt-btn:hover {
    color: var(--ink);
  }
  .vt-btn.is-active {
    color: var(--bg);
    background: var(--accent);
  }
  .vt-icon {
    font-size: var(--t-sm);
    line-height: 1;
  }
  @media (max-width: 480px) {
    .vt-label {
      display: none;
    }
  }

  /* ── LIST view — compact hairline rows ─────────────────────────────────── */
  .reg-list[data-view="list"] {
    display: flex;
    flex-direction: column;
    border-top: var(--hair) solid var(--rule);
  }
  .reg-list[data-view="list"] :global(.reg-row) {
    display: grid;
    grid-template-columns: 3.5ch 1fr auto;
    align-items: baseline;
    gap: var(--s-4);
    padding: var(--s-3) var(--s-2);
    border-bottom: var(--hair) solid var(--rule);
    /* color-only hover — no transform, no glass, cheap at scale */
    transition: background var(--dur-fast) var(--ease-out);
  }
  .reg-list[data-view="list"] :global(.reg-row:hover) {
    background: var(--bg-card);
  }
  :global(.reg-time) {
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    color: var(--ink-faint);
    white-space: nowrap;
  }
  :global(.reg-body) {
    min-width: 0;
  }
  :global(.reg-title) {
    display: block;
    color: var(--ink);
    font-family: var(--font-sans);
    font-size: var(--t-md);
    line-height: var(--lh-tight);
    font-weight: 520;
    letter-spacing: -0.01em;
    transition: color var(--dur-fast) var(--ease-out);
  }
  :global(.reg-title:hover) {
    color: var(--accent);
    text-decoration: none;
  }
  :global(.reg-meta) {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--s-2) var(--s-3);
    margin-top: var(--s-2);
  }
  :global(.reg-src) {
    display: inline-flex;
    align-items: baseline;
    gap: 0.4em;
    font-family: var(--font-mono);
    font-size: var(--t-xs);
  }
  :global(.reg-src-type) {
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  :global(.reg-src-name) {
    color: var(--ink-dim);
  }
  :global(.reg-chip) {
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    color: var(--ink-faint);
    border: var(--hair) solid var(--rule);
    border-radius: var(--r-sm);
    padding: 0.05em 0.4em;
    white-space: nowrap;
    transition: color var(--dur-fast) var(--ease-out), border-color var(--dur-fast) var(--ease-out);
  }
  :global(.reg-chip:hover) {
    color: var(--accent);
    border-color: var(--rule-bright);
    text-decoration: none;
  }
  :global(.reg-end) {
    display: inline-flex;
    align-items: center;
    gap: var(--s-3);
    white-space: nowrap;
  }
  :global(.reg-score) {
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    color: var(--ink-faint);
  }
  /* reading-time telemetry — same mono-faint register as score + src, no badge */
  :global(.reg-readmin) {
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    color: var(--ink-faint);
    font-variant-numeric: tabular-nums;
    font-feature-settings: "tnum" 1;
    white-space: nowrap;
  }
  :global(.reg-srclink) {
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    color: var(--ink-faint);
    transition: color var(--dur-fast) var(--ease-out);
  }
  :global(.reg-srclink:hover) {
    color: var(--accent);
    text-decoration: none;
  }

  /* ── CARD view — light flat cards, NO glass ────────────────────────────── */
  .reg-list[data-view="card"] {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--s-4);
  }
  .reg-list[data-view="card"] :global(.reg-card) {
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
    padding: var(--s-4);
    border: var(--hair) solid var(--rule);
    border-radius: var(--r-md);
    background: var(--bg-card);
    transition: border-color var(--dur-fast) var(--ease-out);
  }
  .reg-list[data-view="card"] :global(.reg-card:hover) {
    border-color: color-mix(in oklab, var(--accent) 22%, var(--rule));
  }
  :global(.reg-card-top) {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--s-3);
  }
  :global(.reg-card-title) {
    color: var(--ink);
    font-family: var(--font-sans);
    font-size: var(--t-md);
    line-height: var(--lh-tight);
    font-weight: 540;
    letter-spacing: -0.01em;
    transition: color var(--dur-fast) var(--ease-out);
  }
  :global(.reg-card-title:hover) {
    color: var(--accent);
    text-decoration: none;
  }
  :global(.reg-card-sum) {
    margin: 0;
    color: var(--ink-dim);
    font-family: var(--font-read);
    font-size: var(--t-base);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  :global(.reg-card-foot) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--s-3);
    flex-wrap: wrap;
    margin-top: auto;
  }
  :global(.reg-chips) {
    display: inline-flex;
    gap: var(--s-2);
    flex-wrap: wrap;
  }

  /* ── load more + empty ─────────────────────────────────────────────────── */
  .reg-more-wrap {
    display: flex;
    justify-content: center;
    padding: var(--s-6) 0 var(--s-4);
  }
  .reg-more {
    font-family: var(--font-mono);
    font-size: var(--t-sm);
    color: var(--ink-dim);
    background: var(--bg-card);
    border: var(--hair) solid var(--rule);
    border-radius: var(--r-md);
    padding: var(--s-3) var(--s-6);
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out),
      background var(--dur-fast) var(--ease-out);
  }
  .reg-more:hover {
    color: var(--ink);
    border-color: color-mix(in oklab, var(--accent) 40%, var(--rule));
    background: var(--bg-hover);
  }
  .reg-empty {
    padding: var(--s-8) 0;
    color: var(--ink-faint);
    font-family: var(--font-mono);
    text-align: center;
  }
  .reg-noscript {
    margin: var(--s-4) 0 0;
    padding-left: 1.2em;
    color: var(--ink-dim);
    font-family: var(--font-read);
    line-height: 1.7;
  }
  .reg-ns-src {
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    color: var(--ink-faint);
  }

  /* ── Register media affordances (video + audio kind glyphs) ──────────── */
  /* Inline kind glyph — appears before the source tag in the meta row */
  :global(.reg-kind-glyph) {
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }
  :global(.reg-kind-video) {
    color: var(--accent);
    letter-spacing: 0;
  }
  :global(.reg-kind-audio) {
    color: var(--editorial);
    letter-spacing: 0;
  }

  /* Card-view video thumbnail — hairline framed, lazy-loaded, graceful fallback */
  :global(.reg-card-thumb-wrap) {
    display: block;
    position: relative;
    overflow: hidden;
    border-radius: calc(var(--r-md) - 3px);
    border: var(--hair) solid var(--rule);
    aspect-ratio: 16 / 9;
    background: var(--bg-inset);
    flex-shrink: 0;
    /* full-bleed: break out of the card padding slightly */
    margin: calc(-1 * var(--s-4)) calc(-1 * var(--s-4)) 0;
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
    border-bottom: none;
  }
  :global(.reg-card-thumb) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--dur-slow) var(--ease-out), filter var(--dur) var(--ease-out);
  }
  :global(.reg-card:hover .reg-card-thumb) {
    transform: scale(1.03);
    filter: brightness(0.82);
  }
  :global(.reg-card-play) {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    color: var(--accent);
    text-shadow: 0 0 12px color-mix(in oklab, var(--accent) 70%, transparent), 0 2px 8px rgba(0,0,0,0.6);
    opacity: 0;
    transition: opacity var(--dur-fast) var(--ease-out);
    pointer-events: none;
    background: radial-gradient(ellipse 50% 55% at 50% 50%, rgba(0,0,0,0.3), transparent);
  }
  :global(.reg-card:hover .reg-card-play) {
    opacity: 1;
  }
  @media (prefers-reduced-motion: reduce) {
    :global(.reg-card-thumb),
    :global(.reg-card-play) {
      transition: none;
    }
    :global(.reg-card:hover .reg-card-thumb) {
      transform: none;
      filter: none;
    }
  }
</style>

<script>
  // ── Bento + browse channel filtering ────────────────────────────────────
  // Listens to the khz:channelchange event dispatched by Shell's header filter
  // script. Filters bento cards and category rows live without a page reload.
  // The register's own initRegister() also listens to this event.

  // Resolve the effective channel set from a khz:channelchange detail.
  // Single channel → [ch]; group → channels[]; "all" → [] (no filter).
  function resolveChannelSet(detail: { channel: string; channels?: string[] }): string[] {
    if (detail.channels && detail.channels.length > 0) return detail.channels;
    if (detail.channel) return [detail.channel];
    return [];
  }

  function applyBentoFilter(activeChannels: string[]): void {
    const cards = document.querySelectorAll<HTMLElement>(".bento [data-channels]");
    const empty = document.querySelector<HTMLElement>(".bento-empty");
    let shown = 0;
    cards.forEach((card) => {
      const cardChannels = (card.dataset.channels ?? "").split(" ").filter(Boolean);
      const match = activeChannels.length === 0 || cardChannels.some((c) => activeChannels.includes(c));
      card.hidden = !match;
      if (match) shown++;
    });
    if (empty) empty.hidden = shown !== 0;
  }

  function applyBrowseFilter(activeChannels: string[]): void {
    const browse = document.querySelector<HTMLElement>("[data-section='browse']");
    if (!browse) return;
    const rows = browse.querySelectorAll<HTMLElement>("[data-catrow]");
    const empty = browse.querySelector<HTMLElement>(".browse-empty");
    let shown = 0;
    rows.forEach((row) => {
      const rowChannel = row.dataset.catrowChannel ?? "";
      const match = activeChannels.length === 0 || activeChannels.includes(rowChannel);
      row.hidden = !match;
      if (match) shown++;
    });
    if (empty) empty.hidden = shown !== 0 || activeChannels.length === 0;
  }

  function applyWatchFilter(activeChannels: string[]): void {
    const section = document.querySelector<HTMLElement>("[data-section='watch']");
    if (!section) return;
    const cards = section.querySelectorAll<HTMLElement>("[data-channels]");
    if (cards.length === 0) return;
    let shown = 0;
    cards.forEach((card) => {
      const cardChannels = (card.dataset.channels ?? "").split(" ").filter(Boolean);
      const match = activeChannels.length === 0 || cardChannels.some((c) => activeChannels.includes(c));
      card.hidden = !match;
      if (match) shown++;
    });
    section.hidden = shown === 0 && activeChannels.length > 0;
  }

  function applyListenFilter(activeChannels: string[]): void {
    const section = document.querySelector<HTMLElement>("[data-section='listen']");
    if (!section) return;
    const cards = section.querySelectorAll<HTMLElement>("[data-channels]");
    if (cards.length === 0) return;
    let shown = 0;
    cards.forEach((card) => {
      const cardChannels = (card.dataset.channels ?? "").split(" ").filter(Boolean);
      const match = activeChannels.length === 0 || cardChannels.some((c) => activeChannels.includes(c));
      card.hidden = !match;
      if (match) shown++;
    });
    section.hidden = shown === 0 && activeChannels.length > 0;
  }

  function initFeedFilter(): void {
    // Apply filter from URL on load (SSR renders correct active state, but
    // client needs to hide mismatched items too)
    const params = new URLSearchParams(location.search);
    const initial = params.get("channel") ?? "";
    if (initial) {
      const initialSet = [initial];
      applyBentoFilter(initialSet);
      applyBrowseFilter(initialSet);
      applyWatchFilter(initialSet);
      applyListenFilter(initialSet);
    }

    // Listen for filter changes from the header — extended event now includes
    // `channels` array for group-level filtering (union of group's sub-channels).
    document.addEventListener("khz:channelchange", (ev) => {
      const detail = (ev as CustomEvent<{ channel: string; channels?: string[] }>).detail;
      const activeChannels = resolveChannelSet(detail);
      applyBentoFilter(activeChannels);
      applyBrowseFilter(activeChannels);
      applyWatchFilter(activeChannels);
      applyListenFilter(activeChannels);
    });
  }

  initFeedFilter();
  document.addEventListener("astro:page-load", initFeedFilter);
</script>

<!-- The Register: lightweight, paginated card/list view for the feed tail.
     Bundled module (no CDN). Reads the JSON payload + the ?channel= param and
     builds compact rows/cards in small batches — keeps the live DOM small. -->
