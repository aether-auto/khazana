---
import Shell from "../../layouts/Shell.astro";
import ReadCard from "../../components/ReadCard.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime(),
);
---

<Shell title="khazana — reads" active="reads">
  <header class="reads-head" data-reveal>
    <p class="eyebrow">reads</p>
    <h1 class="reads-h1">long-form, in your voice</h1>
    <p class="reads-sub">
      Original, interactive, AI-authored reads — grounded in the day's signal and
      cited to the source.
    </p>
  </header>

  <section class="reads-grid">
    {
      posts.map((post, i) => (
        <ReadCard
          slug={post.id}
          title={post.data.title}
          format={post.data.format}
          summary={post.data.summary}
          publishedAt={post.data.publishedAt}
          revealDelay={Math.min(i, 6) * 60}
        />
      ))
    }
  </section>
</Shell>

<style>
  .reads-head {
    margin-bottom: var(--s-8);
    max-width: var(--measure);
  }
  .reads-h1 {
    font-family: var(--font-read);
    font-size: var(--t-2xl);
    line-height: var(--lh-tight);
    letter-spacing: -0.02em;
    margin: 0 0 var(--s-3);
  }
  .reads-sub {
    font-family: var(--font-read);
    color: var(--ink-dim);
    font-size: var(--t-md);
    margin: 0;
  }
  .reads-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 22rem), 1fr));
    gap: var(--s-5);
  }
</style>
