---
import Shell from "../../layouts/Shell.astro";
import FeaturedRead from "../../components/reads/FeaturedRead.astro";
import ReadGalleryCard from "../../components/reads/ReadGalleryCard.astro";
import ReadsFilter from "../../components/reads/ReadsFilter.astro";
import ReadsSort from "../../components/reads/ReadsSort.astro";
import { buildReadsIndex, type ReadInput } from "../../components/reads/lib/build-reads.js";
import { getCollection } from "astro:content";
import { FORMAT_NAMES } from "@khazana/core";

// Pull the published reads, map to the lib's input shape (raw MDX body so the
// lib derives read-time exactly like the read page does), then let the PURE lib
// sort, split off the featured read, and compute facets + the editorial stats.
const posts = await getCollection("blog", ({ data }) => !data.draft);
const inputs: ReadInput[] = posts.map((post) => ({
  slug: post.id,
  title: post.data.title,
  format: post.data.format,
  channels: post.data.channels,
  summary: post.data.summary,
  publishedAt: post.data.publishedAt.toISOString(),
  body: post.body ?? "",
  sourceCount: post.data.sources.length,
}));

const { featured, gallery, formatFacet, channelFacet, stats } = buildReadsIndex(inputs, {
  base: import.meta.env.BASE_URL,
  formatOrder: FORMAT_NAMES,
});
---

<Shell title="khazana — reads" active="reads">
  <header class="reads-head" data-reveal>
    <p class="eyebrow">reads</p>
    <h1 class="reads-h1 display">a daily long-form, <em>set</em> in your voice</h1>
    <p class="reads-sub">
      Original, interactive reads — grounded in the day's signal, set in Fraunces
      &amp; Newsreader, cited to the source.
    </p>

    <!-- editorial readout — the collection's telemetry as a tasteful mono row -->
    {
      stats.total > 0 && (
        <dl class="reads-stats tnum" aria-label="collection telemetry">
          <div class="rstat">
            <dt>reads</dt>
            <dd data-countup={stats.total}>{stats.total}</dd>
          </div>
          <div class="rstat">
            <dt>minutes</dt>
            <dd data-countup={stats.totalMinutes}>{stats.totalMinutes}</dd>
          </div>
          <div class="rstat">
            <dt>formats</dt>
            <dd data-countup={stats.formats}>{stats.formats}</dd>
          </div>
          <div class="rstat">
            <dt>channels</dt>
            <dd data-countup={stats.channels}>{stats.channels}</dd>
          </div>
          <div class="rstat">
            <dt>sources</dt>
            <dd data-countup={stats.sources}>{stats.sources}</dd>
          </div>
        </dl>
      )
    }
  </header>

  {
    featured && (
      <FeaturedRead
        slug={featured.slug}
        title={featured.title}
        format={featured.format}
        channels={featured.channels}
        summary={featured.summary}
        href={featured.href}
        publishedAt={featured.publishedAt}
        dateLabel={featured.dateLabel}
        readMin={featured.readMin}
        sourceCount={featured.sourceCount}
      />
    )
  }

  {
    gallery.length > 0 && (
      <section class="reads-collection" aria-labelledby="collection-heading">
        <div class="collection-head" data-reveal>
          {/* a real <h2> section header (was an aria-label-only div) so the
              heading order is page h1 → hero h2 → this h2 → card h3, no skips. */}
          <h2 id="collection-heading" class="eyebrow collection-heading">the collection</h2>
          <span class="collection-rule" aria-hidden="true" />
          <ReadsSort formatOrder={FORMAT_NAMES} />
        </div>

        <ReadsFilter
          formatFacet={formatFacet}
          channelFacet={channelFacet}
          collectionCount={stats.total}
        />

        <div class="reads-grid" data-reads-grid>
          {gallery.map((card, i) => (
            <ReadGalleryCard
              slug={card.slug}
              title={card.title}
              format={card.format}
              channels={card.channels}
              summary={card.summary}
              href={card.href}
              publishedAt={card.publishedAt}
              dateLabel={card.dateLabel}
              readMin={card.readMin}
              sourceCount={card.sourceCount}
              excerpt={card.excerpt}
              revealDelay={Math.min(i, 6) * 60}
            />
          ))}
        </div>
      </section>
    )
  }
</Shell>

<script>
  // ── "new since your last visit" ──────────────────────────────────────────
  // Reads a khz.reads.lastVisit timestamp from localStorage (last-visit.ts —
  // the ONLY place that key lives) and un-hides the quiet amber "new" badge on
  // every hero/card published since then, then bumps the stored timestamp to
  // now. Progressive enhancement only: no-JS visitors, or anyone with storage
  // unavailable (private mode), simply never see the badge — the rest of the
  // page is already meaningful without it.
  import { READS_LAST_VISIT_KEY, isNewSinceVisit } from "../../components/reads/lib/last-visit.js";

  function markNewSinceVisit(): void {
    let lastVisit: string | null = null;
    try {
      lastVisit = localStorage.getItem(READS_LAST_VISIT_KEY);
    } catch {
      return; // storage unavailable — degrade to no markers, no crash
    }

    for (const el of document.querySelectorAll<HTMLElement>("[data-published]")) {
      const published = el.dataset.published;
      if (!published || !isNewSinceVisit(published, lastVisit)) continue;
      const badge = el.querySelector<HTMLElement>("[data-new-badge]");
      if (badge) badge.hidden = false;
    }

    try {
      localStorage.setItem(READS_LAST_VISIT_KEY, new Date().toISOString());
    } catch {
      /* private mode / quota — the badge just won't persist between visits */
    }
  }

  markNewSinceVisit();
  document.addEventListener("astro:page-load", markNewSinceVisit);
</script>

<script>
  // ── editorial-readout count-up ────────────────────────────────────────────
  // Same technique as the Observatory (graph.astro): SSR renders the real
  // number so no-JS/reduced-motion visitors see it immediately; on reveal, JS
  // counts up from 0 for a touch of "live instrument" life. Progressive
  // enhancement only — never the source of truth for the value itself.
  function initCountUps(): void {
    const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduce || !("IntersectionObserver" in window)) return;
    const els = document.querySelectorAll<HTMLElement>("[data-countup]");
    const io = new IntersectionObserver(
      (entries, obs) => {
        for (const e of entries) {
          if (!e.isIntersecting) continue;
          const el = e.target as HTMLElement;
          obs.unobserve(el);
          const target = parseFloat(el.dataset.countup ?? "0");
          if (!Number.isFinite(target)) continue;
          const dur = 700;
          const start = performance.now();
          const tick = (t: number) => {
            const p = Math.min(1, (t - start) / dur);
            const eased = 1 - Math.pow(1 - p, 3);
            el.textContent = String(Math.round(target * eased));
            if (p < 1) requestAnimationFrame(tick);
            else el.textContent = String(target);
          };
          requestAnimationFrame(tick);
        }
      },
      { threshold: 0.4 },
    );
    for (const el of els) io.observe(el);
  }
  initCountUps();
  document.addEventListener("astro:page-load", initCountUps);
</script>

<style>
  .reads-head {
    margin-bottom: var(--s-8);
    max-width: var(--maxw);
  }
  .reads-h1 {
    font-size: var(--t-2xl);
    line-height: var(--lh-tight);
    letter-spacing: -0.02em;
    margin: 0 0 var(--s-3);
    max-width: 22ch;
  }
  .reads-sub {
    font-family: var(--font-read);
    color: var(--ink-dim);
    font-size: var(--t-md);
    margin: 0;
    max-width: var(--measure);
  }

  /* ── editorial readout — a hairline-ruled row of mono stat cells ─────────── */
  .reads-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 0;
    margin: var(--s-6) 0 0;
    border: var(--hair) solid var(--rule);
    border-radius: var(--r-md);
    overflow: hidden;
    width: fit-content;
    max-width: 100%;
  }
  .rstat {
    display: flex;
    flex-direction: column;
    gap: 0.15em;
    padding: var(--s-3) var(--s-5);
    border-right: var(--hair) solid var(--rule);
  }
  .rstat:last-child {
    border-right: 0;
  }
  .rstat dt {
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-faint);
  }
  .rstat dd {
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--t-lg);
    color: var(--accent);
    line-height: 1;
  }

  /* ── the collection ─────────────────────────────────────────────────────── */
  .reads-collection {
    margin-top: var(--s-4);
  }
  .collection-head {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--s-2) var(--s-4);
    margin-bottom: var(--s-5);
  }
  .collection-head .eyebrow {
    margin: 0;
    flex: none;
  }
  /* the <h2> wears the mono eyebrow voice — reset the UA heading weight/size so
     it reads as chrome, not a big title (the eyebrow class drives its look). */
  .collection-heading {
    font-weight: 400;
  }
  .collection-rule {
    flex: 1;
    height: var(--hair);
    background: linear-gradient(90deg, var(--rule), transparent);
  }

  .reads-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 22rem), 1fr));
    gap: var(--s-5);
    align-items: start;
  }

  @media (max-width: 560px) {
    .reads-stats {
      width: 100%;
    }
    .rstat {
      flex: 1 1 33%;
      border-bottom: var(--hair) solid var(--rule);
    }
  }
</style>
