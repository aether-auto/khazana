---
import { getCollection, render } from "astro:content";
import Article from "../../layouts/Article.astro";
import ReadPlayer from "../../components/reads/ReadPlayer.tsx";
import { countWords } from "../../lib/read-time.js";
import { loadNarration } from "../../lib/narration-manifest.js";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, format, channels, summary, publishedAt, sources } = post.data;

// Approximate read-time from the raw MDX body. We strip import lines, JSX tags,
// and code fences so component markup doesn't inflate the prose word count.
const prose = (post.body ?? "")
  .replace(/^import\s.+$/gm, "")
  .replace(/```[\s\S]*?```/g, "")
  .replace(/<[^>]+>/g, " ")
  .replace(/\{[^}]*\}/g, " ");
const words = countWords(prose);

// Pre-rendered narration, if this Read has a manifest on disk. The player only
// mounts when a manifest exists; its paragraph marks line up with the
// `data-para-index` attributes the narration-index rehype plugin stamps on the
// prose. `track.src` is base-prefixed here so the deployed (project-page) base
// resolves correctly. Absent manifest → no player, prose renders as before.
const narration = loadNarration(post.id, import.meta.env.BASE_URL);
---

<Article
  slug={post.id}
  title={title}
  format={format}
  channels={channels}
  summary={summary}
  publishedAt={publishedAt}
  sources={sources}
  words={words}
>
  {
    narration && (
      <ReadPlayer
        slot="player"
        client:visible
        tracks={narration.tracks}
        paragraphs={narration.paragraphs}
        title={title}
      />
    )
  }
  <Content />
</Article>
