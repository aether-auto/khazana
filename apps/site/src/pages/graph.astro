<script>
  // Count-up on reveal — progressive enhancement only. SSR renders the full
  // value; under no-JS / reduced-motion this never runs and the value stays put.
  function initCountUps(): void {
    const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduce || !("IntersectionObserver" in window)) return;
    const els = document.querySelectorAll<HTMLElement>("[data-countup]");
    const io = new IntersectionObserver(
      (entries, obs) => {
        for (const e of entries) {
          if (!e.isIntersecting) continue;
          const el = e.target as HTMLElement;
          obs.unobserve(el);
          const target = parseFloat(el.dataset.countup ?? "0");
          if (!Number.isFinite(target)) continue;
          const decimals = (el.dataset.countup ?? "").includes(".") ? 1 : 0;
          const dur = 900;
          const start = performance.now();
          const tick = (t: number) => {
            const p = Math.min(1, (t - start) / dur);
            const eased = 1 - Math.pow(1 - p, 3);
            el.textContent = (target * eased).toFixed(decimals);
            if (p < 1) requestAnimationFrame(tick);
            else el.textContent = target.toFixed(decimals);
          };
          requestAnimationFrame(tick);
        }
      },
      { threshold: 0.4 },
    );
    for (const el of els) io.observe(el);
  }
  initCountUps();
  document.addEventListener("astro:page-load", initCountUps);
</script>
