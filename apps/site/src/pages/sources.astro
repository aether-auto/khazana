---
// SOURCES — the faceted, searchable source explorer. The registry is the
// instrument's intake manifold: every feed khazana pulls from. We read it
// directly (live sources.json, else the committed seed), JOIN it to the curated
// feed (item.source === entry.id) via `buildSources`, and hand the enriched
// SourcesData to an interactive island (search · facet · sort · per-source
// dossier drawer). SSR renders an honest health overview + a no-JS grouped
// fallback so the page is readable before — or without — hydration. The Scout's
// candidate queue (sources.pending.json) lists what it proposes to add next.
import Shell from "../layouts/Shell.astro";
import { loadRegistry, loadPending, groupByChannel } from "../lib/sources.js";
import { loadCurated } from "../lib/feed.js";
import { repoDataDir, dataDir } from "../lib/data.js";
import { CHANNELS } from "@khazana/core";
import {
  buildSources,
  toSourcesEntry,
  type SourcesItem,
  type SourcesEntry,
} from "../components/sources/lib/build-sources.js";
import SourcesExplorer from "../components/sources/SourcesExplorer.tsx";
import "../components/sources/sources.css";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const registry = loadRegistry(repoDataDir());
const sources = registry.sources;
const pending = loadPending(repoDataDir());
const curated = loadCurated(dataDir());

// Project the registry + feed onto the lib's minimal structural inputs. Both
// `sources` and `pending` are `SourceEntry[]` from the same registry schema, so
// one shared projection (`toSourcesEntry`) covers both — no per-array repeat.
const srcInput: SourcesEntry[] = sources.map(toSourcesEntry);
const pendingInput: SourcesEntry[] = pending.map(toSourcesEntry);
const itemInput: SourcesItem[] = curated.map((it) => ({
  id: it.id,
  source: it.source,
  sourceType: it.sourceType,
  url: it.url,
  title: it.title,
  publishedAt: it.publishedAt,
  topics: it.topics,
  trustScore: it.trustScore,
  tasteScore: it.tasteScore,
  body: it.body,
  kind: it.kind,
}));

const data = buildSources(srcInput, itemInput, pendingInput, { base });
const { health } = data;
const empty = health.total === 0;

// ── by-type breakdown — a horizontal stacked bar. Type → color: the richer
// media types get their distinct hues (matching the badges); the rest fall to
// restrained instrument tones so the bar reads as "signal vs. the long tail".
const TYPE_COLORS: Record<string, string> = {
  youtube: "#ff6b6b",
  podcast: "#b48cff",
  arxiv: "var(--editorial)",
  "eng-blog": "var(--accent)",
  rss: "var(--accent-dim)",
  news: "var(--good)",
  reddit: "var(--ink-dim)",
  hn: "var(--ink-faint)",
  x: "var(--rule-bright)",
};
const typeColor = (t: string) => TYPE_COLORS[t] ?? "var(--ink-faint)";
const barTotal = health.byType.reduce((s, t) => s + t.count, 0);
const segPct = (n: number) => (barTotal > 0 ? `${(n / barTotal) * 100}%` : "0%");
const avgTrustPct = Math.round(health.avgTrust * 100);

// No-JS fallback — the old grouped-by-channel view, so something readable shows
// before/without hydration. Trust shown as a 0–100 ◆ score.
const groups = groupByChannel(sources, CHANNELS);
const hostOf = (url: string): string => {
  try {
    return new URL(url).host.replace(/^www\./, "");
  } catch {
    return url;
  }
};
const trustPct = (t?: number) => (t != null ? Math.round(t * 100) : null);
---

<Shell
  title="khazana — sources"
  description="The source registry: every feed khazana pulls from — searchable, faceted, with a per-source dossier."
  active="sources"
>
  <header class="src-head" data-reveal>
    <p class="eyebrow">sources</p>
    <h1 class="src-h1">the intake manifold</h1>
    <p class="src-sub">
      Every feed khazana pulls from — searchable, faceted, each with its own
      dossier of what it's actually produced. The Scout proposes new ones after
      each nightly run; the ones gone quiet or failing are where it looks first.
    </p>
  </header>

  {
    empty ? (
      <div class="src-empty" data-reveal>
        <p class="src-empty-glyph" aria-hidden="true">∅</p>
        <p class="src-empty-text">
          No sources registered yet — add entries to <code>data/sources.json</code>{" "}
          (or the committed <code>sources.seed.json</code>) matching the registry
          schema, and they'll appear here.
        </p>
      </div>
    ) : (
      <>
        {/* ── Health overview band ───────────────────────────────────── */}
        <section class="src-health" data-reveal aria-label="registry health">
          <dl class="src-health-stats tnum">
            <div class="src-stat">
              <dt>sources</dt>
              <dd>{health.total}</dd>
            </div>
            <div class="src-stat">
              <dt>enabled</dt>
              <dd>{health.enabled}</dd>
            </div>
            <div class="src-stat src-stat--signal">
              <dt>producing</dt>
              <dd>{health.producing}</dd>
            </div>
            <div class="src-stat src-stat--muted">
              <dt>dormant</dt>
              <dd>{health.dormant}</dd>
            </div>
            <div class="src-stat src-stat--info">
              <dt>deferred</dt>
              <dd>{health.deferred}</dd>
            </div>
            <div class="src-stat src-stat--attention">
              <dt>failing</dt>
              <dd>{health.failing}</dd>
            </div>
            <div class="src-stat src-stat--muted">
              <dt>disabled</dt>
              <dd>{health.disabled}</dd>
            </div>
            <div class="src-stat">
              <dt>candidates</dt>
              <dd>{health.candidates}</dd>
            </div>
            <div class="src-stat">
              <dt>avg trust</dt>
              <dd>{avgTrustPct}</dd>
            </div>
          </dl>

          <div class="src-bytype">
            <p class="src-bytype-label">by type</p>
            <div class="src-bar" role="img" aria-label="source count by type">
              {health.byType.map((t) => (
                <span
                  class="src-bar-seg"
                  style={`width:${segPct(t.count)};background:${typeColor(t.value)}`}
                  title={`${t.value} · ${t.count}`}
                />
              ))}
            </div>
            <ul class="src-bytype-legend">
              {health.byType.map((t) => (
                <li class="src-legend-item">
                  <span class="src-legend-dot" style={`background:${typeColor(t.value)}`} />
                  {t.value}
                  <span class="src-legend-count tnum">{t.count}</span>
                </li>
              ))}
            </ul>
          </div>
        </section>

        {/* ── The explorer ──────────────────────────────────────────────
            SourcesData ships exactly once, as a component prop — the island
            renders its own real controls (search/facet/sort/drawer) from that
            prop on first client render, so there's no separate disabled SSR
            control-bar scaffold to desync or double-ship as inline JSON.
            `client:visible`: this section sits below the header + health band
            (stats + by-type bar), i.e. below the fold on typical viewports, so
            deferring hydration until scrolled into view avoids paying for the
            largest island on the page before anyone's looked at it. */}
        <section class="src-explorer" data-reveal aria-label="source explorer">
          <SourcesExplorer client:visible data={data} base={base} />

          {/* No-JS / pre-hydration fallback — the grouped-by-channel list. */}
          <noscript>
            <p class="src-fallback-head">grouped by channel</p>
            <div class="src-channels">
              {groups.map((group) => (
                <section class="chan">
                  <header class="chan-head">
                    <h2 class="chan-name">{group.channel}</h2>
                    <span class="chan-count tnum">{group.sources.length}</span>
                    <span class="chan-rule" aria-hidden="true" />
                  </header>
                  <ul class="src-list">
                    {group.sources.map((s) => {
                      const pct = trustPct(s.trustScore);
                      return (
                        <li class="src-row" class:list={[{ "is-off": !s.enabled }]}>
                          <span class={`type-badge type-${s.type}`}>{s.type}</span>
                          <a class="src-id" href={s.url} rel="noopener noreferrer" title={s.url}>
                            <span class="src-id-name">{s.id}</span>
                            <span class="src-id-host">{hostOf(s.url)}</span>
                          </a>
                          {pct != null && (
                            <span class="src-trust tnum" title="trust score">
                              {pct}
                            </span>
                          )}
                        </li>
                      );
                    })}
                  </ul>
                </section>
              ))}
            </div>
          </noscript>
        </section>
      </>
    )
  }

  {/* ── Candidates — the Scout's proposed additions ─────────────────────── */}
  <section class="candidates" data-reveal>
    <header class="cand-head">
      <h2 class="cand-title">candidates to add</h2>
      <span class="cand-rule" aria-hidden="true"></span>
    </header>
    {
      pending.length > 0 ? (
        <ul class="src-list">
          {pending.map((s) => {
            const pct = trustPct(s.trustScore);
            return (
              <li class="src-row src-row--cand">
                <span class={`type-badge type-${s.type}`}>{s.type}</span>
                <a class="src-id" href={s.url} rel="noopener noreferrer" title={s.url}>
                  <span class="src-id-name">{s.id}</span>
                  <span class="src-id-host">{hostOf(s.url)}</span>
                </a>
                {s.channels.length > 0 && (
                  <span class="cand-channels">{s.channels.join(" · ")}</span>
                )}
                {pct != null && (
                  <span class="src-trust tnum" title="proposed trust score">
                    {pct}
                  </span>
                )}
              </li>
            );
          })}
        </ul>
      ) : (
        <p class="cand-empty">
          The Scout proposes new sources here after each nightly run — quiet, for now.
        </p>
      )
    }
  </section>
</Shell>
